# =============================================================================
# ~/.config/hypr/hyprland.conf
# Entry point — No editar directamente. Modificar los archivos en conf.d/
# Generado por chezmoi desde dot_config/hypr/hyprland.conf.tmpl
# =============================================================================

# ── Variables de Entorno (NVIDIA, Wayland, Qt, GTK) ─────────────────────────
source = ~/.config/hypr/conf.d/env.conf

# ── Monitores ────────────────────────────────────────────────────────────────
source = ~/.config/hypr/conf.d/monitors.conf

# ── Entrada (Teclado, Ratón, Touchpad) ───────────────────────────────────────
source = ~/.config/hypr/conf.d/input.conf

# ── Aspecto Visual (Colores, Bordes, Blur, Sombras) ──────────────────────────
source = ~/.config/hypr/conf.d/theme.conf

# ── Animaciones ──────────────────────────────────────────────────────────────
source = ~/.config/hypr/conf.d/animations.conf

# ── Reglas de Ventanas ───────────────────────────────────────────────────────
source = ~/.config/hypr/conf.d/rules.conf

# ── Atajos de Teclado ────────────────────────────────────────────────────────
source = ~/.config/hypr/conf.d/keybinds.conf

# ── Inicio Automático ────────────────────────────────────────────────────────
source = ~/.config/hypr/conf.d/autostart.conf
