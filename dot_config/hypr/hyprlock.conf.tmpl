# =============================================================================
# hyprlock.conf — Pantalla de Bloqueo
# =============================================================================

# Colores de respaldo (Fallback)
$accent = rgb(cba6f7)
$foreground = rgb(cfcfcf)

# Importar colores dinámicos de wallust
source = ~/.config/hypr/conf.d/hyprlock-colors.conf

general {
    disable_loading_bar = false
    hide_cursor         = true
    grace               = 5         # Segundos sin pedir contraseña al desbloquear
    no_fade_in          = false
}

background {
    monitor =
    path    = screenshot            # Captura la pantalla actual y aplica blur
    blur_size    = 7
    blur_passes  = 3
    brightness   = 0.5
    contrast     = 0.9
    vibrancy     = 0.2
    vibrancy_darkness = 0.0
}

input-field {
    monitor =
    size = 280, 55
    outline_thickness = 3
    dots_size         = 0.33
    dots_spacing      = 0.15
    dots_center       = false

    outer_color = $accent
    inner_color = rgba(20, 20, 30, 0.6)
    font_color  = $foreground
    fade_on_empty = true

    placeholder_text = <i>Contraseña...</i>
    hide_input = false

    position = 0, -80
    halign   = center
    valign   = center
}

label {
    monitor =
    text     = cmd[update:1000] echo "$(date +'%H:%M')"
    color    = $accent
    font_size = 64
    font_family = JetBrainsMono Nerd Font Bold

    position = 0, 200
    halign   = center
    valign   = center
}

label {
    monitor =
    text        = {{ .chezmoi.username }}
    color       = $foreground
    font_size   = 16
    font_family = JetBrainsMono Nerd Font

    position = 0, -30
    halign   = center
    valign   = center
}
