# =============================================================================
# hyprlock.conf — Pantalla de Bloqueo
# =============================================================================

general {
    disable_loading_bar = false
    hide_cursor         = true
    grace               = 5         # Segundos sin pedir contraseña al desbloquear
    no_fade_in          = false
}

background {
    monitor =
    path    = screenshot            # Captura la pantalla actual y aplica blur
    blur_size    = 7
    blur_passes  = 3
    brightness   = 0.5
    contrast     = 0.9
    vibrancy     = 0.2
    vibrancy_darkness = 0.0
}

input-field {
    monitor =
    size = 280, 55
    outline_thickness = 3
    dots_size         = 0.33
    dots_spacing      = 0.15
    dots_center       = false

    outer_color = rgba({{ get . "accentColor" | default "cba6f7" }}ff)
    inner_color = rgba(20203099)
    font_color  = rgb(cfcfcf)
    fade_on_empty = true

    placeholder_text = <i>Contraseña...</i>
    hide_input = false

    position = 0, -80
    halign   = center
    valign   = center
}

label {
    monitor =
    text     = cmd[update:1000] echo "$(date +'%H:%M')"
    color    = rgba({{ get . "accentColor" | default "cba6f7" }}ff)
    font_size = 64
    font_family = JetBrainsMono Nerd Font Bold

    position = 0, 200
    halign   = center
    valign   = center
}

label {
    monitor =
    text        = {{ .chezmoi.username }}
    color       = rgba(cfcfcfcc)
    font_size   = 16
    font_family = JetBrainsMono Nerd Font

    position = 0, -30
    halign   = center
    valign   = center
}
