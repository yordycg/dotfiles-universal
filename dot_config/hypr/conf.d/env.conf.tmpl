# =============================================================================
# env.conf — Variables de Entorno para Hyprland
# Generado por chezmoi. Crítico para funcionamiento correcto con NVIDIA.
# =============================================================================

# ── Wayland ──────────────────────────────────────────────────────────────────
env = XDG_SESSION_TYPE,wayland
env = XDG_CURRENT_DESKTOP,Hyprland
env = XDG_SESSION_DESKTOP,Hyprland

# ── NVIDIA (Driver propietario) ───────────────────────────────────────────────
# Requerido para aceleración de hardware correcta en Hyprland con NVIDIA.
# Sin estas variables: pantalla negra, alto uso de CPU, tearing.
env = LIBVA_DRIVER_NAME,nvidia
env = GBM_BACKEND,nvidia-drm
env = __GLX_VENDOR_LIBRARY_NAME,nvidia
env = NVD_BACKEND,direct
env = __NV_PRIME_RENDER_OFFLOAD,1

# ── Cursor (evitar cursor invisible en NVIDIA) ────────────────────────────────
env = XCURSOR_THEME,{{ get . "cursorTheme" | default "Adwaita" }}
env = XCURSOR_SIZE,24
env = HYPRCURSOR_THEME,{{ get . "cursorTheme" | default "Adwaita" }}
env = HYPRCURSOR_SIZE,24

# ── GTK ───────────────────────────────────────────────────────────────────────
env = GTK_THEME,{{ get . "gtkTheme" | default "Adwaita-dark" }}

# ── Qt (Wayland nativo) ───────────────────────────────────────────────────────
env = QT_QPA_PLATFORM,wayland;xcb
env = QT_QPA_PLATFORMTHEME,kvantum
env = QT_WAYLAND_DISABLE_WINDOWDECORATION,1
env = QT_AUTO_SCREEN_SCALE_FACTOR,1

# ── Electron / Chromium apps (Wayland nativo) ─────────────────────────────────
env = ELECTRON_OZONE_PLATFORM_HINT,wayland

# ── Mozilla (Firefox Wayland) ─────────────────────────────────────────────────
env = MOZ_ENABLE_WAYLAND,1
