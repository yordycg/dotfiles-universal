# =============================================================================
# monitors.conf — Configuración de Monitores
# Generado por chezmoi.
# =============================================================================

{{ if .isDesktop -}}
# ── Monitores (Acer Z271 principal + Huawei secundario) ───────────────────────
# Principal: Acer Z271 (DP-2) — al frente, 144Hz
monitor = DP-2,     1920x1080@144, 0x0,    1

# Secundario: Huawei (HDMI-A-3) — a la derecha, 75Hz
monitor = HDMI-A-3, 1920x1080@75,  1920x0, 1

# Fallback
monitor = , preferred, auto, 1

# ── Workspaces fijos por monitor ─────────────────────────────────────────────
# Principal (frente) — trabajo, código, browser
workspace = 1,  monitor:DP-2,     default:true
workspace = 2,  monitor:DP-2
workspace = 3,  monitor:DP-2
workspace = 4,  monitor:DP-2
workspace = 5,  monitor:DP-2

# Secundario (derecha) — comunicación, música, referencias
workspace = 6,  monitor:HDMI-A-3, default:true
workspace = 7,  monitor:HDMI-A-3
workspace = 8,  monitor:HDMI-A-3
workspace = 9,  monitor:HDMI-A-3
workspace = 10, monitor:HDMI-A-3
{{ else -}}
# ── Fallback genérico (auto-detectar) ────────────────────────────────────────
monitor = , preferred, auto, 1
{{ end -}}
