# =============================================================================
# autostart.conf — Programas al Inicio de Sesión
# exec-once: se ejecuta solo la primera vez que inicia Hyprland
# exec: se ejecuta en cada reload de config
# =============================================================================

# ── Status bar ────────────────────────────────────────────────────────────────
{{- if .isDesktop }}
exec-once = qs -n -d -c desktop
exec-once = qs -n -d -c song-slide
exec-once = qs -n -d -c clipboard-ripple
{{- else }}
exec-once = waybar
{{- end }}

# ── Wallpaper (swww con transición al cambiar) ────────────────────────────────
exec-once = swww-daemon
exec-once = {{ .chezmoi.homeDir }}/.local/bin/rofi-wallpaper.sh --restore

# ── Notificaciones ────────────────────────────────────────────────────────────
exec-once = mako

# ── Autenticación Polkit ──────────────────────────────────────────────────────
exec-once = /usr/libexec/mate-polkit/polkit-mate-authentication-agent-1

# ── Portapapeles (historial con cliphist) ────────────────────────────────────
exec-once = wl-paste --type text  --watch cliphist store
exec-once = wl-paste --type image --watch cliphist store

# ── Cursor (aplicar tema al inicio) ──────────────────────────────────────────
exec-once = hyprctl setcursor {{ get . "cursorTheme" | default "Adwaita" }} 24

# ── Theming GTK (aplicar via gsettings) ──────────────────────────────────────
exec-once = gsettings set org.gnome.desktop.interface gtk-theme   '{{ get . "gtkTheme" | default "Adwaita-dark" }}'
exec-once = gsettings set org.gnome.desktop.interface icon-theme  '{{ get . "iconTheme" | default "Papirus-Dark" }}'
exec-once = gsettings set org.gnome.desktop.interface cursor-theme '{{ get . "cursorTheme" | default "Adwaita" }}'

# ── Idle management (hypridle) ────────────────────────────────────────────────
exec-once = hypridle
exec-once = hypridle-audio-inhibit.sh

# ── Keyring de GNOME ─────────────────────────────────────────────────────────
exec-once = /usr/bin/gnome-keyring-daemon --start --components=secrets

# ── Launcher Vicinae (Precarga de Servidor) ───────────────────────────────────
exec-once = vicinae server &>/dev/null
