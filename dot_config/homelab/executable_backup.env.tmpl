{{- if .isServer -}}
# =============================================================================
# homelab/backup.env
# Archivo de entorno para el backup diario (Restic + B2)
# Generado automáticamente por Chezmoi desde Bitwarden
# =============================================================================

# Credenciales de Backblaze B2 (Cargadas desde Vaultwarden)
B2_ACCOUNT_ID="{{ (bitwarden "item" "Backblaze B2 - Homelab Backup").login.username }}"
B2_ACCOUNT_KEY="{{ (bitwarden "item" "Backblaze B2 - Homelab Backup").login.password }}"

# Configuración de Repositorio Restic
RESTIC_REPOSITORY="b2:{{ (bitwarden "item" "Backblaze B2 - Homelab Backup").notes }}:/backups"
RESTIC_PASSWORD="{{ (bitwarden "item" "Restic Master Password - Homelab Backup").notes }}"
{{- end -}}
