{{- if .isServer -}}
# =============================================================================
# homelab/backup.env
# Archivo de entorno para el backup diario (Restic + B2)
# Generado automáticamente por Chezmoi desde Bitwarden
# =============================================================================

# Credenciales de Backblaze B2 (Cargadas desde Vaultwarden - Bucle de Búsqueda Robusto)
{{- $vault := (bitwarden "item" "Restic - Homelab Backup") -}}
{{- $keyID := "" -}}
{{- $appKey := "" -}}
{{- $bucket := "" -}}
{{- $pass := "" -}}
{{- range $vault.fields -}}
  {{- if eq .name "keyID" }}{{ $keyID = .value }}{{ end -}}
  {{- if eq .name "applicationKey" }}{{ $appKey = .value }}{{ end -}}
  {{- if eq .name "BucketNameBlackBlazeB2" }}{{ $bucket = .value }}{{ end -}}
  {{- if eq .name "ResticMasterPassword" }}{{ $pass = .value }}{{ end -}}
{{- end -}}
B2_ACCOUNT_ID="{{ $keyID }}"
B2_ACCOUNT_KEY="{{ $appKey }}"

# Configuración de Repositorio Restic
RESTIC_REPOSITORY="b2:{{ $bucket }}:/backups"
RESTIC_PASSWORD="{{ $pass }}"
{{- end -}}
