{{- if .isServer -}}
# =============================================================================
# homelab/backup.env
# Archivo de entorno para el backup diario (Restic + B2)
# Generado automáticamente por Chezmoi desde Bitwarden
# =============================================================================

# Credenciales de Backblaze B2 (Cargadas desde Vaultwarden - PascalCase)
{{- $fields := (bitwardenFields "item" "Restic - Homelab Backup") -}}
B2_ACCOUNT_ID="{{ (index $fields "keyID").value }}"
B2_ACCOUNT_KEY="{{ (index $fields "applicationKey").value }}"

# Configuración de Repositorio Restic
RESTIC_REPOSITORY="b2:{{ (index $fields "BucketNameBlackBlazeB2").value }}:/backups"
RESTIC_PASSWORD="{{ (index $fields "ResticMasterPassword").value }}"
{{- end -}}
