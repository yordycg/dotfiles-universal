{{- if .isServer -}}
# =============================================================================
# homelab/backup.env
# Archivo de entorno para el backup diario (Restic + B2)
# Generado automáticamente por Chezmoi desde Bitwarden
# =============================================================================

# Credenciales de Backblaze B2 (Cargadas desde Vaultwarden - Campos Personalizados)
B2_ACCOUNT_ID="{{ (bitwardenFields "item" "Restic - Homelab Backup").keyID.value }}"
B2_ACCOUNT_KEY="{{ (bitwardenFields "item" "Restic - Homelab Backup").applicationKey.value }}"

# Configuración de Repositorio Restic
RESTIC_REPOSITORY="b2:{{ (bitwardenFields "item" "Restic - Homelab Backup").var_Bucket_Name_BlackBlaze_B2.value }}:/backups"
RESTIC_PASSWORD="{{ (bitwardenFields "item" "Restic - Homelab Backup").var_Restic_Master_Password.value }}"
{{- end -}}
