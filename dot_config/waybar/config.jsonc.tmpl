{{- if .isDesktop }}
[
  // ── Monitor Principal (DP-2) ────────────────────────────────────────────────
  {
    "output": "DP-2",
    "layer": "top",
    "position": "top",
    "height": 28,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "spacing": 0,

    "modules-left": [
      "custom/launcher",
      "hyprland/workspaces"
    ],
    "modules-center": ["clock"],
    "modules-right": [
      "backlight",
      "custom/sep",
      "bluetooth",
      "custom/sep",
      "network",
      "custom/sep",
      "pulseaudio",
      "custom/sep",
      "cpu",
      "custom/sep",
      "memory",
      "custom/sep",
      "idle_inhibitor",
      "custom/sep",
      "mpris",
      "custom/sep",
      "tray",
      "custom/session"
    ],

    // ── Cuadrado outline izquierdo (launcher / power) ───────────────────────
    "custom/launcher": {
      "format": "󰄱",
      "tooltip": false,
      "on-click": "~/.local/bin/logoutlaunch.sh"
    },

    // ── Workspaces ──────────────────────────────────────────────────────────
    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "format": "{icon}",
      "format-icons": {
        "1": "一",
        "2": "二",
        "3": "三",
        "4": "四",
        "5": "五"
      },
      "persistent-workspaces": {
        "DP-2": [1, 2, 3, 4, 5]
      }
    },

    // ── Reloj centrado, solo hora ───────────────────────────────────────────
    "clock": {
      "format": "{:%H:%M}",
      "format-alt": "{:%a %d %b}",
      "tooltip-format": "<tt><small>{calendar}</small></tt>",
      "calendar": {
        "mode": "month",
        "format": {
          "months":   "<span color='#c4a265'><b>{}</b></span>",
          "days":     "<span color='#d4c5a9'>{}</span>",
          "weekdays": "<span color='#c7362a'><b>{}</b></span>",
          "today":    "<span color='#c7362a'><b><u>{}</u></b></span>"
        }
      },
      "actions": {
        "on-click-right": "mode",
        "on-scroll-up":   "shift_up",
        "on-scroll-down": "shift_down"
      }
    },

    // ── Separador | ─────────────────────────────────────────────────────────
    "custom/sep": {
      "format": "|",
      "interval": "once",
      "tooltip": false
    },

    // ── Brillo (solo icono) ─────────────────────────────────────────────────
    "backlight": {
      "format": "{icon}",
      "format-icons": ["󰃞", "󰃟", "󰃠"],
      "tooltip-format": "Brillo: {percent}%",
      "on-scroll-up":   "brightnessctl set +5%",
      "on-scroll-down": "brightnessctl set 5%-"
    },

    // ── Bluetooth (solo icono) ──────────────────────────────────────────────
    "bluetooth": {
      "format":           "󰂯",
      "format-connected": "󰂱",
      "format-off":       "󰂲",
      "tooltip-format":   "{controller_alias}\n{num_connections} conectado(s)",
      "on-click": "blueman-manager"
    },

    // ── Red (solo icono) ────────────────────────────────────────────────────
    "network": {
      "format-wifi":         "󰤨",
      "format-ethernet":     "󰈀",
      "format-disconnected": "󰤭",
      "tooltip-format-wifi":     "{essid} {signalStrength}%\n{ipaddr}",
      "tooltip-format-ethernet": "{ifname} — {ipaddr}",
      "on-click": "nm-connection-editor"
    },

    // ── Audio (solo icono) ──────────────────────────────────────────────────
    "pulseaudio": {
      "format":       "{icon}",
      "format-muted": "󰝟",
      "format-icons": {
        "headphone": "󰋋",
        "headset":   "󰋎",
        "default":   ["󰕿", "󰖀", "󰕾"]
      },
      "tooltip-format": "Volumen: {volume}%",
      "on-click":       "pavucontrol",
      "on-scroll-up":   "pactl set-sink-volume @DEFAULT_SINK@ +2%",
      "on-scroll-down": "pactl set-sink-volume @DEFAULT_SINK@ -2%"
    },

    // ── CPU (solo icono) ────────────────────────────────────────────────────
    "cpu": {
      "format":         "󰍛",
      "tooltip-format": "CPU: {usage}%",
      "interval":       2
    },

    // ── RAM (solo icono) ────────────────────────────────────────────────────
    "memory": {
      "format":         "󰘚",
      "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G ({percentage}%)",
      "interval":       5
    },

    // ── Idle inhibitor ──────────────────────────────────────────────────────
    "idle_inhibitor": {
      "format": "{icon}",
      "format-icons": {
        "activated":   "",
        "deactivated": ""
      }
    },

    // ── Media Player (Music Pill) ───────────────────────────────────────────
    "mpris": {
      "format": "󰎆 {title}",
      "format-paused": "󰎊 {title}",
      "max-length": 25,
      "tooltip": false
    },

    // ── Tray ────────────────────────────────────────────────────────────────
    "tray": {
      "icon-size": 15,
      "spacing":   6
    },

    // ── Botón sesión (extremo derecho, fondo rojo) ──────────────────────────
    "custom/session": {
      "format": "⏻",
      "tooltip": false,
      "on-click": "~/.local/bin/logoutlaunch.sh"
    }
  },

  // ── Monitor Secundario (HDMI-A-3) ──────────────────────────────────────────
  {
    "output": "HDMI-A-3",
    "layer": "top",
    "position": "top",
    "height": 28,
    "exclusive": true,
    "passthrough": false,
    "gtk-layer-shell": true,
    "spacing": 0,

    "modules-left":   ["custom/launcher", "hyprland/workspaces"],
    "modules-center": ["clock"],
    "modules-right":  [
      "network",
      "custom/sep",
      "pulseaudio",
      "custom/sep",
      "cpu",
      "custom/sep",
      "memory"
    ],

    "custom/launcher": {
      "format": "󰄱",
      "tooltip": false,
      "on-click": "~/.local/bin/logoutlaunch.sh"
    },

    "hyprland/workspaces": {
      "disable-scroll": true,
      "all-outputs": false,
      "format": "{icon}",
      "format-icons": {
        "6":  "六",
        "7":  "七",
        "8":  "八",
        "9":  "九",
        "10": "十"
      },
      "persistent-workspaces": {
        "HDMI-A-3": [6, 7, 8, 9, 10]
      }
    },

    "clock": {
      "format":     "{:%H:%M}",
      "format-alt": "{:%a %d %b}"
    },

    "custom/sep": {
      "format": "|",
      "interval": "once",
      "tooltip": false
    },

    "network": {
      "format-wifi":         "󰤨",
      "format-ethernet":     "󰈀",
      "format-disconnected": "󰤭",
      "tooltip-format-wifi": "{essid} {signalStrength}%"
    },

    "pulseaudio": {
      "format":       "{icon}",
      "format-muted": "󰝟",
      "format-icons": { "default": ["󰕿", "󰖀", "󰕾"] },
      "tooltip-format": "Volumen: {volume}%",
      "on-click": "pavucontrol"
    },

    "cpu": {
      "format":         "󰍛",
      "tooltip-format": "CPU: {usage}%",
      "interval":       2
    },

    "memory": {
      "format":         "󰘚",
      "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G",
      "interval":       5
    }
  }
]
