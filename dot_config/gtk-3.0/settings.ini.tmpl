{{- $localPath := joinPath .chezmoi.homeDir ".config/gtk-3.0/settings.ini" -}}
{{- if and (or (eq .desktopEnv "kde") (eq .desktopEnv "both")) (stat $localPath) -}}
{{-   include $localPath -}}
{{- else -}}
[Settings]
gtk-theme-name=Gruvbox-Material-Dark
gtk-icon-theme-name=Gruvbox-Material-Dark
gtk-font-name=SF Pro 10.699
gtk-cursor-theme-name=default
gtk-cursor-theme-size=24
gtk-toolbar-style=GTK_TOOLBAR_BOTH_HORIZ
gtk-toolbar-icon-size=GTK_ICON_SIZE_LARGE_TOOLBAR
gtk-button-images=1
gtk-menu-images=1
gtk-enable-event-sounds=1
gtk-enable-input-feedback-sounds=0
gtk-xft-antialias=1
gtk-xft-hinting=1
gtk-xft-hintstyle=hintslight
gtk-xft-rgba=rgb
gtk-application-prefer-dark-theme=1
{{- end -}}
