/**
 * Rofi Theme Selector - HyDE Style Horizontal Cards (No Search, Full Width)
 * Styled with swatches, centered on screen, 4 columns.
 */

configuration {
    show-icons:                 true;
    drun-display-format:         "{name}";
    font:                        "JetBrainsMono Nerd Font 10";
}

@theme "/dev/null"
@import "{{ .chezmoi.homeDir }}/.config/rofi/colors.rasi"

* {
    /* Fallback colors */
    bg:                          #080808B3;
    bg-alt:                      #1e1e2eB3;
    fg:                          #cdd6f4;
    accent:                      #b4befe;

    background-color:            transparent;
    text-color:                  @fg;
}

window {
    enabled:                     true;
    fullscreen:                  false;
    transparency:                "real";
    cursor:                      "default";
    background-color:            rgba(8, 8, 8, 0.95); /* Full width bar background */
    width:                       100%;
    location:                    center;
    anchor:                      center;
}

mainbox {
    enabled:                     true;
    padding:                     35px 120px; /* Margins */
    children:                    [ "listview" ];
    background-color:            transparent;
}

listview {
    enabled:                     true;
    spacing:                     4em;
    columns:                     4; /* 4 columns for our 4 curated themes */
    lines:                       1;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    reverse:                     false;
    fixed-height:                false;
    fixed-columns:               true;
    background-color:            transparent;
    text-color:                  @fg;
}

element {
    enabled:                     true;
    spacing:                     0.8em;
    padding:                     1.2em;
    cursor:                      pointer;
    background-color:            transparent;
    text-color:                  @fg;
    orientation:                 vertical;
    border-radius:               16px;
}

element selected.normal {
    background-color:            @accent; /* Highlight the entire card */
    text-color:                  #080808; /* Dark text for contrast */
}

element-icon {
    cursor:                      inherit;
    size:                        11em; /* Size of the swatch image */
    background-color:            transparent;
    text-color:                  inherit;
    expand:                      false;
    border-radius:               10px;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.5;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
    font:                        "JetBrainsMono Nerd Font Bold 12";
}
