/**
 * Spotlight / Omni-Menu Rofi Theme - iamdothash Edition
 * A sleek, high-performance, modern command palette.
 */

configuration {
    modi:                       "drun,run,filebrowser,window";
    show-icons:                 true;
    display-drun:               " ";
    display-run:                " ";
    display-filebrowser:        " ";
    display-window:             "󰖲 ";
    drun-display-format:        "{name}";
    window-format:              "{w} · {c} · {t}";
    font:                       "JetBrainsMono NF 11";
    icon-theme:                 "Papirus-Dark";
}

@theme "/dev/null"
@import "{{ .chezmoi.homeDir }}/.config/rofi/current-colors.rasi"

* {
    /* Colores estáticos de respaldo - Tema Kanagawa Dragon */
    bg:                          #181616B3; /* Gris cálido al 70% */
    bg-alt:                      #2d3139B3; /* Gris azulado al 70% */
    fg:                          #c5c9c5;   /* Blanco arena suave */
    accent:                      #658594;   /* Azul pizarra / Indigo */

    background-color:            transparent;
    text-color:                  @fg;
}

/* ── Ventana Principal (Spotlight Centrado) ─────────────────────────────────── */
window {
    transparency:                "real";
    location:                    center;
    anchor:                      center;
    fullscreen:                  false;
    width:                       680px;
    x-offset:                    0px;
    y-offset:                    0px;

    enabled:                     true;
    margin:                      0px;
    padding:                     0px;
    border:                      1px solid;
    border-radius:               0px;
    border-color:                @accent;
    background-color:            @bg; /* Usa el fondo traslúcido dinámico de Wallust */
    cursor:                      "default";
}

/* ── Contenedor principal ───────────────────────────────────────────────────── */
mainbox {
    enabled:                     true;
    spacing:                     0px;
    margin:                      0px;
    padding:                     0px;
    background-color:            transparent;
    children:                    [ "inputbar", "listview" ];
}

/* ── Barra de Búsqueda Superior (Spotlight) ─────────────────────────────────── */
inputbar {
    enabled:                     true;
    spacing:                     14px;
    margin:                      0px;
    padding:                     24px 24px 20px 24px;
    border:                      0px 0px 1px 0px solid;
    border-color:                @bg-alt; /* Línea divisoria muy sutil */
    background-color:            transparent;
    text-color:                  @fg;
    children:                    [ "prompt", "entry" ];
}

prompt {
    enabled:                     true;
    background-color:            inherit;
    text-color:                  @accent;
    font:                        "JetBrainsMono NF 15";
}

entry {
    enabled:                     true;
    background-color:            inherit;
    text-color:                  inherit;
    font:                        "JetBrainsMono NF 14";
    cursor:                      text;
    placeholder:                 "Search applications, files, settings...";
    placeholder-color:           @bg-alt;
}

/* ── Lista de Resultados ────────────────────────────────────────────────────── */
listview {
    enabled:                     true;
    columns:                     1;
    lines:                       7;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical;
    reverse:                     false;
    fixed-height:                true;
    fixed-columns:               true;
    
    spacing:                     6px;
    margin:                      0px;
    padding:                     18px 20px 20px 20px;
    background-color:            transparent;
    text-color:                  @fg;
    cursor:                      "default";
}

/* ── Elemento Individual ────────────────────────────────────────────────────── */
element {
    enabled:                     true;
    spacing:                     12px;
    margin:                      0px;
    padding:                     6px 14px;
    border:                      0px solid;
    border-radius:               0px;
    background-color:            transparent;
    text-color:                  @fg;
    cursor:                      pointer;
}

/* Estado Seleccionado (Alineado con el Omni-Menu de Quickshell) */
element selected.normal {
    background-color:            @bg-alt;
    text-color:                  @fg;
    border:                      0px 0px 0px 3px;
    border-color:                @accent;
}

element-icon {
    background-color:            transparent;
    text-color:                  inherit;
    size:                        18px;
    cursor:                      inherit;
}

element-text {
    background-color:            transparent;
    text-color:                  inherit;
    highlight:                   inherit;
    cursor:                      inherit;
    vertical-align:              0.5;
    horizontal-align:            0.0;
}
