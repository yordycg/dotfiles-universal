/**
 * Rofi Wallpaper Theme - HyDE Style Horizontal Cards (No Search, Full Width)
 * Optimized with dynamic height to prevent clipping on different DPIs.
 */

configuration {
    show-icons:                 true;
    drun-display-format:         "{name}";
    font:                        "JetBrainsMono Nerd Font 10";
}

@theme "/dev/null"
@import "{{ .chezmoi.homeDir }}/.config/rofi/colors.rasi"

* {
    /* Fallback colors */
    bg:                          #080808B3;
    bg-alt:                      #1e1e2eB3;
    fg:                          #cdd6f4;
    accent:                      #b4befe;

    background-color:            transparent;
    text-color:                  @fg;
}

window {
    enabled:                     true;
    fullscreen:                  false;
    transparency:                "real";
    cursor:                      "default";
    background-color:            rgba(8, 8, 8, 0.95); /* Fondo de barra de ancho completo */
    width:                       100%;
    /* Sin altura fija para permitir que se ajuste dinámicamente según el DPI del monitor */
    location:                    center;
    anchor:                      center;
}

mainbox {
    enabled:                     true;
    padding:                     25px 80px; /* Márgenes laterales */
    children:                    [ "listview" ];
    background-color:            transparent;
}

listview {
    enabled:                     true;
    spacing:                     3em;
    columns:                     9; /* 9 columnas a lo ancho de la pantalla */
    lines:                       1;
    cycle:                       true;
    dynamic:                     true;
    scrollbar:                   false;
    layout:                      vertical; /* Fila horizontal de tarjetas usando las columnas */
    reverse:                     false;
    fixed-height:                false; /* Altura dinámica */
    fixed-columns:               true;
    background-color:            transparent;
    text-color:                  @fg;
}

element {
    enabled:                     true;
    spacing:                     0.5em;
    padding:                     0.8em;
    cursor:                      pointer;
    background-color:            transparent;
    text-color:                  @fg;
    orientation:                 vertical;
    border-radius:               12px;
}

element selected.normal {
    background-color:            @accent; /* Activa la card completa con fondo de acento */
    text-color:                  #080808; /* Texto oscuro para contraste */
}

element-icon {
    cursor:                      inherit;
    size:                        10em; /* Tamaño de miniatura cuadrada en ems */
    background-color:            transparent;
    text-color:                  inherit;
    expand:                      false;
    border-radius:               8px;
}

element-text {
    vertical-align:              0.5;
    horizontal-align:            0.5;
    cursor:                      inherit;
    background-color:            transparent;
    text-color:                  inherit;
}
