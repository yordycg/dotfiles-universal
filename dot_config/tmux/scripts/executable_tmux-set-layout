#!/usr/bin/env bash
# ~/.config/tmux/scripts/tmux-set-layout

LAYOUT_DIR="$HOME/.config/tmux/layouts"
STATE_DIR="$HOME/.config/tmux/state"
ACTIVE_SYM="$HOME/.config/tmux/active_layout.conf"

mkdir -p "$STATE_DIR"

if [[ -z "$1" ]]; then
    if ! command -v fzf &>/dev/null; then
        echo "Error: fzf no está instalado y no se especificó layout."
        exit 1
    fi
    layout=$(find "$LAYOUT_DIR" -name "*.conf" -exec basename {} .conf \; | fzf --reverse --prompt="Seleccionar layout tmux > ")
else
    layout="$1"
fi

if [[ -n "$layout" ]]; then
    target="$LAYOUT_DIR/${layout}.conf"
    if [[ -f "$target" ]]; then
        ln -sf "$target" "$ACTIVE_SYM"
        echo "$layout" > "$STATE_DIR/current-layout"
        tmux source-file "$HOME/.config/tmux/tmux.conf" 2>/dev/null && echo "✓ Layout '$layout' aplicado."
    else
        echo "Error: El layout '$layout' no existe."
        exit 1
    fi
fi
