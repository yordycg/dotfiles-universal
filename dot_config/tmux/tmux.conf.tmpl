# --- General Settings & Fixes ---
set-environment -g PATH "{{ .chezmoi.homeDir }}/.local/share/mise/shims:{{ .chezmoi.homeDir }}/.local/share/mise/bin:/usr/local/bin:/usr/bin:/bin"
set -g default-terminal "tmux-256color"
set -ga terminal-overrides ",*:RGB"
set -ga terminal-overrides ",xterm-256color:RGB"
set -ga terminal-overrides ",xterm-kitty:RGB"
set -ga terminal-overrides ",tmux-256color:RGB"
set -g mouse on
set -g set-clipboard on
set -g detach-on-destroy off
set -g escape-time 0
set -g history-limit 1000000
set -g status-interval 3
set -g status-left-length 100
set -g status-right-length 100

# --- Indexing & Naming ---
set -g base-index 1
set -g pane-base-index 1
setw -g pane-base-index 1
set -g renumber-windows on
set -g automatic-rename off

# --- Keybindings TMUX ---
# General and System
# ctrl+b ? - Mostrar lista de todos los atajos activos
# Session Managment
# ctrl+b $ - Renombrar la session actual
# ctrl+b ( - Cambia a la session/cliente anterior
# ctrl+b ) - Cambia a la session/cliente siguiente
# Windows Managment
# ctrl+b , - Renombrar la ventana actual
# ctrl+b & - Cerrar (matar) la ventana actual, pide confirmacion
# ctrl+b n - Ir a la siguiente ventana
# ctrl+b p - Ir a la ventana anterior
# ctrl+b w - Abrir el selector de ventanas y sessiones (choose-tree ?)
# Windows Layouts
# ctrl+b Space - Cambia al siguiente layout (cicla entre horizontal y vertical)
# ctrl+b Alt+1 - Layout equitativo horizontal
# ctrl+b Alt+2 - Layout equitativo vertical
# ctrl+b Alt+3 - Layout principal horizontal, secundarios abajo
# ctrl+b Alt+4 - Layout principal vertical, secundarios abajo
# ctrl+b Alt+5 - Layout en rejilla (?)
# Panes Managment
# ctrl+b o - Saltar al siguiente panel de la ventana
# ctrl+b ! - Convierte el panel actual en una ventana independiente
# ctrl+b Flechas - Moverse al panel continuo
# ctrl+b ctrl+Flechas- Redimensionar el panel actual

# --- Betters Keybindings ---
bind r source-file "~/.config/tmux/tmux.conf" \; display-message "Config reloaded..."
bind c new-window -c "#{pane_current_path}"
bind '"' split-window -v -c '#{pane_current_path}'
bind % split-window -h -c '#{pane_current_path}'

# --- Image Preview Support ---
set -g allow-passthrough on
set -g visual-activity off
set -ga update-environment TERM
set -ga update-environment TERM_PROGRAM

# --- Copy Mode (Vim Style) ---
setw -g mode-keys vi
set -s set-clipboard on                          # Habilitar soporte OSC 52 (Copia SSH)
bind-key -T copy-mode-vi v send-keys -X begin-selection
bind-key -T copy-mode-vi C-v send-keys -X rectangle-toggle
bind-key -T copy-mode-vi y send-keys -X copy-selection-and-cancel
bind-key -T copy-mode-vi MouseDragEnd1Pane send-keys -X copy-pipe-and-cancel "wl-copy"

# Click derecho para pegar en Tmux (Solo si no hay menu activo)
unbind-key -n MouseDown3Pane
bind-key -n MouseDown3Pane run "wl-paste | tmux load-buffer - && tmux paste-buffer"

# --- Plugins (TPM) ---
set -g @plugin 'tmux-plugins/tpm'
set -g @plugin 'tmux-plugins/tmux-sensible'
set -g @plugin 'christoomey/vim-tmux-navigator'
set -g @plugin 'omerxx/tmux-sessionx'
set -g @plugin 'tmux-plugins/tmux-resurrect'
set -g @plugin 'tmux-plugins/tmux-continuum'
set -g @plugin 'sainnhe/tmux-fzf'
set -g @plugin 'omerxx/tmux-floax'

# --- Plugin Configuration ---
set-environment -g TMUX_PLUGIN_MANAGER_PATH '~/.config/tmux/plugins/'

# Resurrect & Continuum (Persistencia Indestructible)
set -g @resurrect-capture-pane-contents 'on'
set -g @resurrect-strategy-nvim 'session'
set -g @continuum-restore 'on'
set -g @continuum-save-interval '10'

# SessionX (Fuzzy Session Selector & Command Palette)
set -g @sessionx-bind 's'
set -g @sessionx-zoxide-mode 'on'
set -g @sessionx-fzf-builtin-tmux 'on'
set -g @sessionx-window-height '55%'
set -g @sessionx-window-width '55%'
set -g @sessionx-preview-enabled 'false'
set -g @sessionx-auto-accept 'off'
set -g @sessionx-filter-current 'false'

# Floax (Floating Terminal Overlay)
set -g @floax-width '80%'
set -g @floax-height '80%'
set -g @floax-border-color "blue"
set -g @floax-text-color "default"
set -g @floax-bind 'p'
set -g @floax-change-path 'true'

# --- Theme & Layout (Dynamic Modular System) ---
source-file "~/.config/tmux/colors.conf"
source-file "~/.config/tmux/layouts/rectangular.conf"

# Definir Iconos Compartidos (estáticos) para los Layouts
set -g @icon_session ""
set -g @icon_prefix "󰌌"
set -g @icon_zoom "󰊓"
set -g @icon_ssh "󰌘"

bind-key f run-shell "~/.local/bin/tmux-sessionizer"
bind-key L display-popup -E -w 85% -h 80% -b rounded -T " 󰌌  Lazy-Tmux " "lazy-tmux"

# --- Auto-install TPM & Plugins ---
if "test ! -d ~/.config/tmux/plugins/tpm" \
   "run 'git clone https://github.com/tmux-plugins/tpm ~/.config/tmux/plugins/tpm && ~/.config/tmux/plugins/tpm/bin/install_plugins'"

run '~/.config/tmux/plugins/tpm/tpm'
