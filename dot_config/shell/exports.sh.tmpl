# =============================================================================
# Capa 1: Variables de Entorno y Entorno Base
# Compatible con Bash y Zsh
# =============================================================================

# -- Colores Homelab-Style --
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# -- Funciones de Logging (Senior UI) --
# Uso: log_ok "texto" "icono_opcional"
log_step() { echo -e "\n${CYAN}${BOLD}${2:-â–¶} $1${RESET}"; }
log_ok()   { echo -e "${GREEN}${2:-âś“} $1${RESET}"; }
log_info() { echo -e "${CYAN}${2:-â†’} $1${RESET}"; }
log_warn() { echo -e "${YELLOW}${2:-âš } $1${RESET}"; }
log_err()  { echo -e "${RED}${2:-âś—} $1${RESET}"; }

# -- Terminal Compatibility Fix (Kitty Fallback) --
if [[ "$TERM" == "xterm-kitty" ]] && ! infocmp xterm-kitty >/dev/null 2>&1; then
    export TERM="xterm-256color"
fi

# -- Editores y Pager --
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# -- Secretos y Seguridad --
export SOPS_AGE_KEY_FILE="$HOME/.config/chezmoi/key.txt"

# -- FZF Configuration (Senior Modern UI) --
[ -f "$HOME/.config/shell/fzf_colors.sh" ] && source "$HOME/.config/shell/fzf_colors.sh"

export FZF_DEFAULT_COMMAND="fd --hidden --strip-cwd-prefix --exclude .git "
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
export FZF_ALT_C_COMMAND="fd --type=d --hidden --strip-cwd-prefix --exclude .git"

export FZF_DEFAULT_OPTS=" \
  --height 45% \
  --layout=reverse \
  --border=rounded \
  --margin=0,1 \
  --padding=0 \
  --info=inline-right \
  --prompt='ó°­Ž ' \
  --pointer='îŠ¦ ' \
  --marker='ó°„˛ ' \
  ${FZF_COLORS:-} \
  --bind 'ctrl-u:preview-page-up,ctrl-d:preview-page-down' \
"

# -- Direnv Configuration (Invisible Automation) --
export DIRENV_LOG_FORMAT=""

# -- Homelab SSL / Trust (Capa de Infraestructura) --
{{ if eq .chezmoi.os "linux" -}}
{{   if eq .chezmoi.osRelease.id "fedora" -}}
HOMELAB_CA="/etc/pki/ca-trust/source/anchors/homelab-ca-bundle.crt"
{{   else -}}
HOMELAB_CA="/usr/local/share/ca-certificates/homelab-ca-bundle.crt"
{{   end -}}
[ -f "$HOMELAB_CA" ] && export NODE_EXTRA_CA_CERTS="$HOMELAB_CA"
{{ end -}}

# -- Paths --
# Precedencia: Mise Shims > Binarios de Usuario (bin, .local/bin) > Sistema
export PATH="$HOME/.local/share/mise/shims:$HOME/bin:$HOME/.local/bin:$PATH"

# -- Theming: GTK & Qt Integration (Senior UI Consistency) --
{{ if eq .chezmoi.os "linux" -}}
export QT_QPA_PLATFORMTHEME="qt5ct"
export QT_WAYLAND_DISABLE_WINDOWDECORATION="1"
export GDK_BACKEND="wayland,x11"
export SDL_VIDEODRIVER="wayland"
export CLUTTER_BACKEND="wayland"
{{ end -}}
