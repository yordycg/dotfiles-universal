# =============================================================================
# Capa 5: Activación de Herramientas del Sistema (Mise, Zoxide, Starship, etc.)
# =============================================================================

if command -v mise &>/dev/null; then
    run_cached "mise" "mise activate zsh" "Mise"
fi
command -v direnv  &>/dev/null && run_cached "direnv" "direnv hook zsh" "Direnv"
command -v zoxide  &>/dev/null && run_cached "zoxide" "zoxide init zsh" "Zoxide"
command -v starship &>/dev/null && run_cached "starship" "starship init zsh" "Starship"
