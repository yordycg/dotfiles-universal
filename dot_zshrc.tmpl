# -- MOTOR DE RENDIMIENTO (CACHING ENGINE) ------------------------------------
ZSH_CACHE_DIR="$HOME/.cache/zsh"
[[ -d "$ZSH_CACHE_DIR" ]] || mkdir -p "$ZSH_CACHE_DIR"

run_cached() {
    local name="${1:?run_cached requiere un nombre}"
    local cmd="${2:?run_cached requiere un comando}"
    local friendly_name="${3:-$name}"
    local cache_file="$ZSH_CACHE_DIR/${name}.zsh"
    
    if [[ ! -f "$cache_file" ]] || [[ -n "$(command find "$cache_file" -mmin +1440 2>/dev/null)" ]]; then
        log_info "Regenerando cach√©: $friendly_name..."
        ( eval "$cmd" ) > "$cache_file" 2>/dev/null || {
            rm -f "$cache_file"
            return 1
        }
        log_ok "$friendly_name sincronizado."
    fi
    [[ -f "$cache_file" ]] && builtin source "$cache_file"
}

# -- CAPA 1: ENTORNO BASE Y LOGS (SHELL AGNOSTIC) -----------------------------
source "$HOME/.config/shell/exports.sh"
source "$HOME/.config/shell/aliases.sh"
source "$HOME/.config/shell/functions.sh"

# -- CAPA 2: COMPLETADO (compinit DEBE IR ANTES QUE FZF-TAB) ------------------
source "$HOME/.config/zsh/completion.zsh"

# -- CAPA 3: PLUGINS (fzf-tab, autosuggestions, etc.) -------------------------
source "$HOME/.config/zsh/plugins.zsh"

# -- CAPA 4: FZF KEYBINDINGS (Despu√©s de plugins) -----------------------------
source "$HOME/.config/zsh/fzf.zsh"

# -- CAPA 5: HERRAMIENTAS (MISE/STARSHIP) -------------------------------------
# Al final para no interferir con el sistema de completado
if command -v mise &>/dev/null; then
    run_cached "mise" "mise activate zsh" "Mise"
fi
[[ -x $(command -v direnv) ]]  && run_cached "direnv" "direnv hook zsh" "Direnv"
[[ -x $(command -v zoxide) ]]   && run_cached "zoxide" "zoxide init zsh" "Zoxide"
[[ -x $(command -v starship) ]] && run_cached "starship" "starship init zsh" "Starship"

# -- CONFIGURACI√ďN DE HISTORIAL -----------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_FIND_NO_DUPS

# -- AUTO-TMUX / SESSION MANAGER (Senior Workflow) ----------------------------
if [[ -n "$SSH_CONNECTION" && -z "$TMUX" && -x $(command -v tmux) ]]; then
    {{ if and (eq .chezmoi.os "linux") .isServer -}}
    # Funci√≥n para listar sesiones y proyectos
    function s_manager() {
        # 1. Obtener sesiones activas
        local sessions=$(tmux list-sessions -F "ůĪďě Session: #S" 2>/dev/null || echo "")
        
        # 2. Escanear workspace buscando directorios que tengan .git (Proyectos reales)
        # Esto es mucho m√°s r√°pido y preciso
        local projects=$(fd -H -t d ".git$" "$HOME/workspace" 2>/dev/null | xargs -I{} dirname {} | sed "s|$HOME/|~/|g" | sed 's/^/ůįöĚ Project: /')
        
        # Fallback si fd falla o no hay .git (escanear directorios a profundidad 2)
        if [[ -z "$projects" ]]; then
            projects=$(find "$HOME/workspace" -maxdepth 2 -type d 2>/dev/null | sed "s|$HOME/|~/|g" | sed 's/^/ůįöĚ Project: /')
        fi
        
        local selection=$( (echo "$sessions"; echo "$projects") | grep -v "^$" | fzf --reverse --header "ůįíĄ Homelab Session Manager (Esc para Zsh puro)" --prompt "ÔÄā Buscar: " --height=60% --border --info=inline)
        
        # Escape Hatch: Si el usuario cancela (Esc o Ctrl-C), sale a Zsh normal
        [[ -z "$selection" ]] && return 0
        
        if [[ "$selection" == ůĪďě\ Session:* ]]; then
            local target=$(echo "$selection" | sed 's/ůĪďě Session: //')
            exec tmux attach -t "$target"
        else
            local target_dir=$(echo "$selection" | sed 's/ůįöĚ Project: //' | sed "s|~|$HOME|")
            # Generar nombre estilo 'categoria/proyecto' (ej. ipvg/arriendo-canchas)
            local name=$(echo "$target_dir" | sed "s|$HOME/workspace/||")
            # Crear sesi√≥n limpia en el directorio del proyecto
            exec tmux new -A -s "$name" -c "$target_dir"
        fi
    }

    s_manager
    {{- end }}
fi

# -- FINALIZACI√ďN -------------------------------------------------------------
if [[ -z "$TMUX" && -x $(command -v fastfetch) ]]; then
    fastfetch
fi
