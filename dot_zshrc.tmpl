# -- Entorno base ---------------------------------------------
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"

# -- Paths ---------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# -- Plugins (manual, sin framework) -------------------------
source_if() { [ -f "$1" ] && source "$1"; }

source_if /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source_if /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# -- Herramientas -------------------------------------------
eval "$(zoxide init zsh)"
eval "$(starship init zsh)"

# -- fzf ---------------------------------------------------
source_if /usr/share/fzf/shell/key-bindings.zsh
source_if /usr/share/fzf/shell/completion.zsh
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'

# -- Aliases y funciones -----------------------------------
source_if "$HOME/.config/shell/aliases.sh"
source_if "$HOME/.config/shell/functions.sh"

# -- Historial ---------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

