# -- MOTOR DE RENDIMIENTO (CACHING ENGINE) ------------------------------------
ZSH_CACHE_DIR="$HOME/.cache/zsh"
[[ -d "$ZSH_CACHE_DIR" ]] || mkdir -p "$ZSH_CACHE_DIR"

run_cached() {
    local name="${1:?run_cached requiere un nombre}"
    local cmd="${2:?run_cached requiere un comando}"
    local friendly_name="${3:-$name}"
    local cache_file="$ZSH_CACHE_DIR/${name}.zsh"
    
    if [[ ! -f "$cache_file" ]] || [[ -n "$(command find "$cache_file" -mmin +1440 2>/dev/null)" ]]; then
        log_info "Regenerando caché: $friendly_name..."
        ( eval "$cmd" ) > "$cache_file" 2>/dev/null || {
            rm -f "$cache_file"
            return 1
        }
        log_ok "$friendly_name sincronizado."
    fi
    [[ -f "$cache_file" ]] && builtin source "$cache_file"
}

# -- CAPA 1: ENTORNO BASE Y LOGS (SHELL AGNOSTIC) -----------------------------
source "$HOME/.config/shell/exports.sh"
source "$HOME/.config/shell/aliases.sh"
source "$HOME/.config/shell/functions.sh"

# -- CAPA 2: COMPLETADO (compinit DEBE IR ANTES QUE FZF-TAB) ------------------
source "$HOME/.config/zsh/completion.zsh"

# -- CAPA 3: PLUGINS (fzf-tab, autosuggestions, etc.) -------------------------
source "$HOME/.config/zsh/plugins.zsh"

# -- CAPA 4: FZF KEYBINDINGS (Después de plugins) -----------------------------
source "$HOME/.config/zsh/fzf.zsh"

# -- CAPA 5: HERRAMIENTAS (MISE/STARSHIP) -------------------------------------
# Al final para no interferir con el sistema de completado
if command -v mise &>/dev/null; then
    run_cached "mise" "mise activate zsh" "Mise"
fi
[[ -x $(command -v direnv) ]]  && run_cached "direnv" "direnv hook zsh" "Direnv"
[[ -x $(command -v zoxide) ]]   && run_cached "zoxide" "zoxide init zsh" "Zoxide"
[[ -x $(command -v starship) ]] && run_cached "starship" "starship init zsh" "Starship"

# -- CONFIGURACIÓN DE HISTORIAL -----------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_FIND_NO_DUPS

# -- AUTO-TMUX / SESSION MANAGER (Senior Workflow) ----------------------------
if [[ -n "$SSH_CONNECTION" && -z "$TMUX" && -x $(command -v tmux) && -x $(command -v fzf) ]]; then
    {{ if and (eq .chezmoi.os "linux") .isServer -}}
    # Función para listar sesiones y proyectos
    function s_manager() {
        # Verificar que estamos en un TTY real antes de hacer nada
        [[ ! -t 0 ]] && return 0

        local sessions projects tmpfile selection

        # 1. Obtener sesiones activas
        sessions=$(tmux list-sessions -F "󱓞 Session: #S" 2>/dev/null || echo "")
        
        # 2. Escanear workspace buscando directorios que tengan .git (Proyectos reales)
        projects=$(fd -H -t d ".git$" "$HOME/workspace" 2>/dev/null | xargs -I{} dirname {} | sed "s|$HOME/|~/|g" | sed 's/^/󰚝 Project: /')
        
        # Fallback si fd falla o no hay .git
        if [[ -z "$projects" ]]; then
            projects=$(find "$HOME/workspace" -maxdepth 2 -type d 2>/dev/null | sed "s|$HOME/|~/|g" | sed 's/^/󰚝 Project: /')
        fi
        
        # Añadir opción '󱓞 Session: main' si no existe en la lista para estandarizar
        if [[ ! "$sessions" =~ "Session: main" ]]; then
            sessions=$(echo -e "󱓞 Session: main\n$sessions" | sed '/^$/d')
        fi

        # --- SOLUCIÓN CLAUDE: Archivo temporal para liberar el TTY ---
        tmpfile=$(mktemp /tmp/s_manager.XXXXXX)
        trap "rm -f $tmpfile" EXIT INT TERM

        # fzf escribe al archivo, no a stdout - el TTY queda intacto
        { echo "$sessions"; echo "$projects"; } \
            | grep -v "^$" \
            | fzf --reverse \
                  --header "󰒄 Homelab Session Manager (Esc para Zsh puro)" \
                  --prompt " Buscar: " \
                  --height=60% \
                  --border \
                  --info=inline \
            > "$tmpfile"

        selection=$(cat "$tmpfile")
        rm -f "$tmpfile"
        trap - EXIT INT TERM

        [[ -z "$selection" ]] && return 0

        # Resetear estado del terminal antes de tmux
        stty sane 2>/dev/null || true
        clear

        if [[ "$selection" == 󱓞\ Session:* ]]; then
            local target=$(echo "$selection" | sed 's/󱓞 Session: //')
            exec tmux new-session -A -s "$target"
        else
            local target_dir=$(echo "$selection" | sed 's/󰚝 Project: //' | sed "s|~|$HOME|")
            # Generar nombre estilo 'categoria/proyecto'
            local name=$(echo "$target_dir" | sed "s|$HOME/workspace/||")
            exec tmux new-session -A -s "$name" -c "$target_dir"
        fi
    }

    s_manager
    {{- end }}
fi

# -- SSH agent bridge Windows → WSL (solo en WSL) -----------------
{{- if .isWSL }}
export SSH_AUTH_SOCK="$HOME/.ssh/agent.sock"

_start_agent_bridge() {
    if ! ss -a 2>/dev/null | grep -q "$SSH_AUTH_SOCK"; then
        rm -f "$SSH_AUTH_SOCK"
        ( setsid socat \
            UNIX-LISTEN:"$SSH_AUTH_SOCK",fork \
            EXEC:"npiperelay.exe -ei -s //./pipe/openssh-ssh-agent",nofork \
          & ) >/dev/null 2>&1
    fi
}
_start_agent_bridge
{{- end }}

# -- Vaultwarden — desbloqueo sin exponer master password ---------
bwu() {
    export BW_SESSION="$(bw unlock --raw)"
    echo "Vaultwarden desbloqueado."
}

# -- FINALIZACIÓN -------------------------------------------------------------
if [[ -z "$TMUX" && -x $(command -v fastfetch) ]]; then
    fastfetch
fi
