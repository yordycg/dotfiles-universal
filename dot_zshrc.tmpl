# -- Entorno base ---------------------------------------------
export EDITOR="nvim"
export VISUAL="nvim"
export PAGER="bat"
export MANPAGER="sh -c 'col -bx | bat -l man -p'"
export SOPS_AGE_KEY_FILE="$HOME/.config/chezmoi/key.txt"

# -- SSL / Trust ---------------------------------------------
# Enseñar a Node.js (bw cli) a confiar en la CA del Homelab
{{ if eq .chezmoi.os "linux" -}}
{{   if eq .chezmoi.osRelease.id "fedora" -}}
HOMELAB_CA="/etc/pki/ca-trust/source/anchors/homelab-caddy-ca.crt"
{{   else -}}
HOMELAB_CA="/usr/local/share/ca-certificates/homelab-caddy-ca.crt"
{{   end -}}
[ -f "$HOMELAB_CA" ] && export NODE_EXTRA_CA_CERTS="$HOMELAB_CA"
{{ end -}}

# -- Paths ---------------------------------------------------
export PATH="$HOME/.local/bin:$PATH"

# -- Plugins (manual, sin framework) -------------------------
source_if() { [ -f "$1" ] && source "$1"; }

source_if /usr/share/zsh-autosuggestions/zsh-autosuggestions.zsh
source_if /usr/share/zsh-syntax-highlighting/zsh-syntax-highlighting.zsh

# -- Herramientas -------------------------------------------
# Inicializar Mise (Gestiona nvim, tmux, zoxide, starship, etc)
if command -v mise &>/dev/null; then
    eval "$(mise activate zsh)"
fi

# Inicializar integraciones de herramientas (Mise garantiza que esten en el PATH)
eval "$(zoxide init zsh)"
eval "$(starship init zsh)"

# -- fzf ---------------------------------------------------
source_if /usr/share/fzf/shell/key-bindings.zsh
source_if /usr/share/fzf/shell/completion.zsh
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow'
export FZF_DEFAULT_OPTS='--height 40% --layout=reverse --border'

# -- Aliases y funciones -----------------------------------
source_if "$HOME/.config/shell/aliases.sh"
source_if "$HOME/.config/shell/functions.sh"

# -- Historial ---------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=10000
SAVEHIST=10000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE

