# =============================================================================
# ARCHIVO DE CONFIGURACIÓN PRINCIPAL DE ZSH (Senior Minimalist)
# =============================================================================

# -- CAPA 0: CACHÉ Y MOTOR DE RENDIMIENTO --
source "$HOME/.config/zsh/cache.zsh"

# -- CAPA 1: ENTORNO BASE Y ALIASES (SHELL AGNOSTIC) --
source "$HOME/.config/shell/exports.sh"
source "$HOME/.config/shell/aliases.sh"
source "$HOME/.config/shell/functions.sh"

# -- CAPA 2: COMPLETADO (compinit) --
source "$HOME/.config/zsh/completion.zsh"

# -- CAPA 3: PLUGINS Y BINDINGS --
source "$HOME/.config/zsh/plugins.zsh"

# -- CAPA 4: MOTOR DE BÚSQUEDA (FZF) --
source "$HOME/.config/zsh/fzf.zsh"

# -- CAPA 5: INTEGRACIÓN DE HERRAMIENTAS --
source "$HOME/.config/zsh/tools.zsh"

# -- CAPA 6: CONFIGURACIÓN DE HISTORIAL --
source "$HOME/.config/zsh/history.zsh"

# -- CAPA 7: INTEGRACIÓN WSL --
{{- if .isWSL }}
source "$HOME/.config/zsh/wsl.zsh"
{{- end }}
