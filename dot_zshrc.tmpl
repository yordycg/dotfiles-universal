# -- MOTOR DE RENDIMIENTO (CACHING ENGINE) ------------------------------------
ZSH_CACHE_DIR="$HOME/.cache/zsh"
[[ -d "$ZSH_CACHE_DIR" ]] || mkdir -p "$ZSH_CACHE_DIR"

run_cached() {
    local name="${1:?run_cached requiere un nombre}"
    local cmd="${2:?run_cached requiere un comando}"
    local friendly_name="${3:-$name}"
    local cache_file="$ZSH_CACHE_DIR/${name}.zsh"
    
    if [[ ! -f "$cache_file" ]] || [[ -n "$(command find "$cache_file" -mmin +1440 2>/dev/null)" ]]; then
        log_info "Regenerando caché: $friendly_name..."
        ( eval "$cmd" ) > "$cache_file" 2>/dev/null || {
            rm -f "$cache_file"
            return 1
        }
        log_ok "$friendly_name sincronizado."
    fi
    [[ -f "$cache_file" ]] && builtin source "$cache_file"
}

# -- CAPA 1: ENTORNO BASE Y LOGS (SHELL AGNOSTIC) -----------------------------
source "$HOME/.config/shell/exports.sh"
source "$HOME/.config/shell/aliases.sh"
source "$HOME/.config/shell/functions.sh"

# -- CAPA 2: COMPLETADO (compinit DEBE IR ANTES QUE FZF-TAB) ------------------
source "$HOME/.config/zsh/completion.zsh"

# -- CAPA 3: PLUGINS (fzf-tab, autosuggestions, etc.) -------------------------
source "$HOME/.config/zsh/plugins.zsh"

# -- CAPA 4: FZF KEYBINDINGS (Después de plugins) -----------------------------
source "$HOME/.config/zsh/fzf.zsh"

# -- CAPA 5: HERRAMIENTAS (MISE/STARSHIP) -------------------------------------
# Al final para no interferir con el sistema de completado
if command -v mise &>/dev/null; then
    run_cached "mise" "mise activate zsh" "Mise"
fi
[[ -x $(command -v direnv) ]]  && run_cached "direnv" "direnv hook zsh" "Direnv"
[[ -x $(command -v zoxide) ]]   && run_cached "zoxide" "zoxide init zsh" "Zoxide"
[[ -x $(command -v starship) ]] && run_cached "starship" "starship init zsh" "Starship"

# -- CONFIGURACIÓN DE HISTORIAL -----------------------------------------------
HISTFILE=~/.zsh_history
HISTSIZE=100000
SAVEHIST=100000
setopt SHARE_HISTORY
setopt HIST_IGNORE_DUPS
setopt HIST_IGNORE_SPACE
setopt HIST_REDUCE_BLANKS
setopt HIST_FIND_NO_DUPS

# -- AUTO-TMUX / SESSION MANAGER (Senior Workflow) ----------------------------
if [[ -n "$SSH_CONNECTION" && -z "$TMUX" && -x $(command -v tmux) ]]; then
    {{ if .isServer -}}
    # Intentar detectar sesiones activas
    local sessions=$(tmux list-sessions -F "#S" 2>/dev/null)
    
    if [[ -z "$sessions" ]]; then
        log_info "Iniciando sesión principal 'main'..."
        tmux new -s main
    else
        echo -e "\n${CYAN}${BOLD}󰒄 Gestión de Sesiones Remotas${RESET}"
        echo -e "${WHITE}Selecciona una opción o presiona Ctrl+C para Zsh puro${RESET}\n"
        echo -e "  ${GREEN}[m]${RESET} Conectar a 'main'"
        
        # Listar otras sesiones existentes
        echo "$sessions" | grep -v "^main$" | while read -r s; do
            echo -e "  ${BLUE}[$s]${RESET} Reanudar sesión"
        done
        
        echo -e "  ${YELLOW}[s]${RESET} Buscar proyecto (Zoxide + New Session)"
        echo -e "  ${CYAN}[n]${RESET} Nueva sesión temporal"
        
        read -k 1 "opt?  󰋇 Opción: "
        echo ""

        case "$opt" in
            m) tmux attach -t main ;;
            s) 
                local target=$(zoxide query -l | fzf --height=40% --reverse --header="Seleccionar proyecto para nueva sesión")
                if [[ -n "$target" ]]; then
                    local name=$(basename "$target")
                    tmux new -s "$name" -c "$target"
                fi
                ;;
            n) tmux new ;;
            *) 
                if echo "$sessions" | grep -q "^$opt$"; then
                    tmux attach -t "$opt"
                else
                    # Si la tecla coincide con el inicio de una sesión, conectar
                    local match=$(echo "$sessions" | grep "^$opt" | head -n 1)
                    if [[ -n "$match" ]]; then
                        tmux attach -t "$match"
                    fi
                fi
                ;;
        esac
    fi
    {{- end }}
fi

# -- FINALIZACIÓN -------------------------------------------------------------
if [[ -z "$TMUX" && -x $(command -v fastfetch) ]]; then
    fastfetch
fi
