{{- if eq .chezmoi.os "windows" -}}
# =============================================================================
# Microsoft.PowerShell_profile.ps1
# Gestionado por Chezmoi - Senior Windows Workflow
# =============================================================================

# -- 0. FIX PATH (Asegurar binarios de Dotfiles) ------------------------------
$PathsToAdd = @(
    "$HOME\bin",
    "$env:USERPROFILE\scoop\shims"
)

foreach ($p in $PathsToAdd) {
    if (Test-Path $p -and $env:Path -notlike "*$p*") {
        $env:Path = "$p;$env:Path"
    }
}

# -- 1. VARIABLES DE ENTORNO --------------------------------------------------
$env:STARSHIP_CONFIG = "$HOME\.config\starship.toml"

# -- 2. INICIALIZACIÓN DE HERRAMIENTAS ----------------------------------------
if (Get-Command starship.exe -ErrorAction SilentlyContinue) {
    Invoke-Expression (&starship init powershell)
}

if (Get-Command zoxide.exe -ErrorAction SilentlyContinue) {
    Invoke-Expression (&zoxide init powershell)
}

# -- 3. FUNCIONES DE ORQUESTACIÓN (Native PowerShell) -------------------------

# Aplicar dotfiles
function apply {
    Write-Host "▶ Aplicando dotfiles..." -ForegroundColor Cyan
    & chezmoi.exe apply --force
}

# Guardar cambios en el repo
function save {
    param([string]$msg = "feat: update dotfiles")
    Write-Host "▶ Guardando cambios en el repo..." -ForegroundColor Cyan
    & chezmoi.exe git add -- .
    & chezmoi.exe git commit -- -m $msg
    & chezmoi.exe git push
}

# Bootstrap de WSL (Zero-Touch)
function bootstrap-wsl {
    $script = "$HOME\.local\bin\bootstrap-wsl.ps1"
    if (Test-Path $script) {
        Write-Host "▶ Iniciando bootstrap de WSL..." -ForegroundColor Cyan
        powershell.exe -NoProfile -ExecutionPolicy Bypass -File $script
    } else {
        Write-Error "Script de bootstrap no encontrado en $script"
    }
}

# Acceso rápido al Homelab (Lanza WSL y conecta)
function hl {
    param([string]$session = "main")
    wsl -d Ubuntu-24.04 -- bash -ic "~/.local/bin/hl $session"
}

function hls { wsl -d Ubuntu-24.04 -- bash -ic "hls" }

# -- 4. ALIASES ---------------------------------------------------------------
Set-Alias -Name vim -Value nvim -ErrorAction SilentlyContinue
Set-Alias -Name ll -Value ls -ErrorAction SilentlyContinue

# -- 5. POWERSHELL ENHANCEMENTS (PSReadLine) ----------------------------------
if (Get-Module -ListAvailable -Name PSReadLine) {
    Set-PSReadLineOption -PredictionSource History
    Set-PSReadLineOption -PredictionViewStyle ListView
    Set-PSReadLineKeyHandler -Key Tab -Function MenuComplete
}

if (Get-Command starship.exe -ErrorAction SilentlyContinue) {
    Write-Host "󰇄  Entorno Windows Dotfiles Cargado" -ForegroundColor Cyan
}
{{- end -}}
