# Directorios de organizacion interna - nunca van a $HOME
home/
hosts/
scripts/
docs/

# Archivos generados dinamicamente
.config/kitty/colors.conf
.config/tmux/colors.conf
.config/sway/colors
.config/waybar/colors.css

# --- EXCLUSIONES POR OS ---

{{ if eq .chezmoi.os "windows" -}}
# Windows Only: Ignorar Justfile y scripts de Linux
Justfile
dot_Justfile
dot_Justfile.tmpl
script-linux-*
run_onchange_after_linux-orchestrator.sh
.config/sway/**
.config/waybar/**
.config/mako/**
.config/kitty/**
.config/flavours/**
.config/systemd/**
.config/zsh/**
.local/share/flavours/**
{{- end }}

{{ if eq .chezmoi.os "linux" -}}
# Linux: Ignorar scripts de Windows
run_once_*.ps1
{{- end }}

# Perfiles
{{ if not (and (hasKey . "isLaptop") .isLaptop) }}
hosts/laptop/**
{{ end }}
{{ if not (and (hasKey . "isDesktop") .isDesktop) }}
hosts/desktop/**
{{ end }}

# Sway: solo en Linux nativo
{{ if eq .chezmoi.os "windows" }}
home/profile_sway/**
home/os_linux/**
{{ end }}

# WSL
{{ if not (and (hasKey . "isWSL") .isWSL) }}
home/profile_wsl/**
{{ end }}

# Windows
{{ if ne .chezmoi.os "windows" }}
home/os_windows/**
{{ end }}
