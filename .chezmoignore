# .chezmoignore
# REGLA: patrones usan nombres del SOURCE (con dot_), no del destino

# ── Siempre ignorados ─────────────────────────────────────────────
docs/**
workspace/**
home/**
hosts/**
scripts/**
provision/**

# ── Headless (WSL + Server): ignorar scripts y configs de GUI ─────
{{ if or .isWSL .isServer -}}

# Configs de GUI (Desktop/Laptop only)
dot_config/sway/**
dot_config/waybar/**
dot_config/rofi/**
dot_config/wofi/**
dot_config/mako/**
dot_config/kitty/**
dot_config/gammastep/**
dot_config/wallust/**
dot_config/flavours/**
dot_config/gtk-3.0/**
dot_config/gtk-4.0/**
dot_mozilla/**

# Scripts de GUI que no aplican en headless
.chezmoiscripts/run_once_after_10-install-fonts.sh.tmpl
.chezmoiscripts/run_onchange_after_30-install-flatpaks.sh.tmpl
.chezmoiscripts/run_onchange_after_40-apply-theme.sh.tmpl

{{ end -}}

# ── Exclusiones dinámicas según el Entorno de Escritorio ──────────

# Si no se usa Sway, ignorar archivos específicos de Sway/Wayland
{{ if and (ne .desktopEnv "sway") (ne .desktopEnv "both") -}}
dot_config/sway/**
dot_config/waybar/**
dot_config/rofi/**
dot_config/wofi/**
dot_config/mako/**
dot_config/gammastep/**
dot_config/wallust/**
dot_config/flavours/**
{{ end -}}

# ── Archivos generados dinámicamente (todos los sistemas) ────────
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/waybar/colors.css
dot_config/sway/colors
