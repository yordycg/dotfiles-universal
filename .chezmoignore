# .chezmoignore
# REGLA: patrones usan nombres del SOURCE (con dot_), no del destino

# ── Siempre ignorados ─────────────────────────────────────────────
docs/**
workspace/**
home/**
hosts/**
scripts/**
os/linux/.chezmoiroot

# ── Headless (WSL + Server): ignorar scripts y configs de GUI ─────
{{ if or .isWSL .isServer -}}

# Configs de GUI (Desktop/Laptop only)
os/linux/**

# Scripts de GUI que no aplican en headless
.chezmoiscripts/after_10-install-fonts.sh
.chezmoiscripts/after_30-install-flatpaks.sh
.chezmoiscripts/after_apply-theme.sh
.chezmoiscripts/after_install-firenvim.sh
.chezmoiscripts/after_install-pixie-sddm.sh
.chezmoiscripts/after_install-tridactyl-native.sh
.chezmoiscripts/after_92-setup-tailscale.sh

{{ end -}}

# ── Archivos generados dinámicamente (todos los sistemas) ────────
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/waybar/colors.css
dot_config/sway/colors
