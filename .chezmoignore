# Directorios de organizacion interna - nunca van a $HOME
home/
hosts/
scripts/
docs/

# Archivos generados dinamicamente (Themes/Flavours/Locales)
.config/kitty/colors.conf
.config/tmux/colors.conf
.config/sway/colors
.config/waybar/colors.css

# Windows: Exclusiones específicas para evitar errores de templates de Linux
{{- if eq .chezmoi.os "windows" }}
.config/sway/**
.config/waybar/**
.config/mako/**
.config/kitty/**
.config/flavours/**
.config/systemd/**
.config/zsh/**
.local/share/flavours/**
scripts/run_after_92-setup-tailscale.sh.tmpl
scripts/run_after_95-trust-homelab-ca.sh.tmpl
scripts/run_after_50-setup-backup.sh.tmpl
scripts/run_after_10-install-fonts.sh.tmpl
{{- end }}

# Perfiles: solo aplicar el que corresponde
{{ if not .isLaptop }}
hosts/laptop/**
{{ end }}
{{ if not .isDesktop }}
hosts/desktop/**
{{ end }}

# Sway: solo en Linux nativo con entorno grafico
{{ if eq .chezmoi.os "windows" }}
home/profile_sway/**
home/os_linux/**
{{ end }}

# WSL: solo cuando estemos en WSL
{{ if not .isWSL }}
home/profile_wsl/**
{{ end }}

# Windows: solo en windows nativo
{{ if ne .chezmoi.os "windows" }}
home/os_windows/**
{{ end }}
