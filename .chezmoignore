# Directorios de organizacion interna - nunca van a $HOME
home/
hosts/
scripts/
docs/

# Archivos generados dinamicamente (Themes/Flavours/Locales)
.config/kitty/colors.conf
.config/tmux/colors.conf
.config/sway/colors
.config/waybar/colors.css

# --- EXCLUSIONES POR OS (CRITICO PARA BOOTSTRAP) ---

{{ if eq .chezmoi.os "windows" -}}
# Windows: Ignorar scripts de Linux para evitar errores de Win32 Application
run_*.sh
run_*.sh.tmpl
.config/sway/**
.config/waybar/**
.config/mako/**
.config/kitty/**
.config/flavours/**
.config/systemd/**
.config/zsh/**
.local/share/flavours/**
{{- end }}

{{ if eq .chezmoi.os "linux" -}}
# Linux: Ignorar scripts de Windows
run_*.ps1
run_*.ps1.tmpl
{{- end }}

# Perfiles: solo aplicar el que corresponde
{{ if not (and (hasKey . "isLaptop") .isLaptop) }}
hosts/laptop/**
{{ end }}
{{ if not (and (hasKey . "isDesktop") .isDesktop) }}
hosts/desktop/**
{{ end }}

# Sway: solo en Linux nativo con entorno grafico
{{ if eq .chezmoi.os "windows" }}
home/profile_sway/**
home/os_linux/**
{{ end }}

# WSL: solo cuando estemos en WSL
{{ if not (and (hasKey . "isWSL") .isWSL) }}
home/profile_wsl/**
{{ end }}

# Windows: solo en windows nativo
{{ if ne .chezmoi.os "windows" }}
home/os_windows/**
{{ end }}
