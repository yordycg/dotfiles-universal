# .chezmoignore
# REGLA: patrones usan nombres del SOURCE (con dot_), no del destino

# ── Siempre ignorados ─────────────────────────────────────────────
docs/**
workspace/**
home/**
hosts/**
scripts/**

# ── WINDOWS: ignora toda la carpeta de Linux ─────────────────────
{{ if eq .chezmoi.os "windows" -}}

os/linux/**
os/wsl/**

# Archivos generados por Linux que pudieran quedar en raíz
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/waybar/colors.css
dot_config/sway/colors

{{ end -}}

# ── LINUX nativo y WSL: ignora toda la carpeta de Windows ────────
{{ if ne .chezmoi.os "windows" -}}

os/windows/**

{{ end -}}

# ── WSL: headless, ignora scripts y configs de GUI de Linux ──────
{{ if and (hasKey . "isWSL") .isWSL -}}

os/linux/**

{{ end -}}

# ── SERVER: igual que WSL ─────────────────────────────────────────
{{ if and (hasKey . "isServer") .isServer -}}

os/linux/**

{{ end -}}

# ── Archivos generados dinámicamente (todos los OS) ───────────────
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/sway/colors
dot_config/waybar/colors.css
