# .chezmoignore
# REGLA: Los archivos que se copian al home usan nombres de TARGET (ej. .config/ en vez de dot_config/).
# Los scripts (que no tienen destino directo) usan sus nombres de SOURCE (ej. .chezmoiscripts/).

# ── Siempre ignorados ─────────────────────────────────────────────
docs/**
workspace/**
home/**
hosts/**
scripts/**
provision/**

# ── Headless (WSL + Server): ignorar configs de GUI ───────────────
{{ if or .isWSL .isServer -}}

# Configs de GUI (Desktop/Laptop only)
.config/sway/**
.config/waybar/**
.config/rofi/**
.config/wofi/**
.config/mako/**
.config/kitty/**
.config/gammastep/**
.config/wallust/**
.config/flavours/**
.config/gtk-3.0/**
.config/gtk-4.0/**
.mozilla/**

# Scripts de GUI que no aplican en headless
.chezmoiscripts/run_once_after_10-install-fonts.sh.tmpl
.chezmoiscripts/run_onchange_after_30-install-flatpaks.sh.tmpl
.chezmoiscripts/run_onchange_after_40-apply-theme.sh.tmpl


{{ end -}}

# ── Exclusiones dinámicas según el Entorno de Escritorio ──────────

# Identificar si se usará algún entorno basado en Wayland (Sway o Hyprland)
{{- $usesWayland := or (eq .desktopEnv "sway") (eq .desktopEnv "hyprland") (eq .desktopEnv "both") -}}

# Si no se usa ningún entorno Wayland, ignorar configuraciones comunes
{{- if not $usesWayland }}
.config/waybar/**
.config/rofi/**
.config/wofi/**
.config/mako/**
.config/gammastep/**
.config/wallust/**
{{- end }}

# Ignorar Sway si no está seleccionado
{{- if and (ne .desktopEnv "sway") (ne .desktopEnv "both") }}
.config/sway/**
{{- end }}

# Ignorar Hyprland si no está seleccionado O si el nodo NO es Desktop
{{- if or (and (ne .desktopEnv "hyprland") (ne .desktopEnv "both")) (not .isDesktop) }}
.config/hypr/**
{{- end }}

# ── Archivos generados dinámicamente (todos los sistemas) ────────
.config/LazyVim/lazy-lock.json
.config/kitty/colors.conf
.config/tmux/colors.conf
.config/waybar/colors.css
.config/sway/colors
.config/hypr/conf.d/theme-colors.conf
.config/mako/config
.config/rofi/colors.rasi
