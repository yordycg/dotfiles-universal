# Directorios de organización interna — nunca van a $HOME
docs/**
workspace/**
scripts/**

# Exclusiones Linux: ignorar archivos de Windows
{{ if ne .chezmoi.os "windows" -}}
run_once_before_01-clean-old-dotfiles.ps1.tmpl
run_once_after_99-windows-bootstrap.ps1.tmpl
AppData/**
Documents/PowerShell/**
{{ end -}}

# Exclusiones Windows: ignorar todo lo de Linux
{{ if eq .chezmoi.os "windows" -}}
script-linux-*
run_onchange_after_linux-orchestrator.sh.tmpl
run_onchange_after_linux-orchestrator.sh
dot_config/sway/**
dot_config/waybar/**
dot_config/mako/**
dot_config/kitty/**
dot_config/flavours/**
dot_config/systemd/**
dot_config/zsh/**
dot_local/share/flavours/**
dot_mozilla/**
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/sway/colors
dot_config/waybar/colors.css
{{ end -}}

# Archivos generados dinámicamente por scripts
dot_config/kitty/colors.conf
dot_config/tmux/colors.conf
dot_config/sway/colors
dot_config/waybar/colors.css
