# Directorios de organizacion interna - nunca van a $HOME
home/
hosts/
scripts/
docs/

# Archivos generados dinamicamente (Themes/Flavours/Locales)
.config/kitty/colors.conf
.config/tmux/colors.conf
.config/sway/colors
.config/waybar/colors.css

# Windows: Exclusión AGRESIVA de todo lo que sea Linux
{{- if eq .chezmoi.os "windows" }}
scripts/linux/**
.config/sway/**
.config/waybar/**
.config/mako/**
.config/kitty/**
.config/flavours/**
.config/systemd/**
.config/zsh/**
.local/share/flavours/**
{{- end }}

# Linux: Exclusión de scripts de Windows
{{- if eq .chezmoi.os "linux" }}
scripts/windows/**
{{- end }}

# Perfiles: solo aplicar el que corresponde
{{ if not .isLaptop }}
hosts/laptop/**
{{ end }}
{{ if not .isDesktop }}
hosts/desktop/**
{{ end }}

# Sway: solo en Linux nativo con entorno grafico
{{ if eq .chezmoi.os "windows" }}
home/profile_sway/**
home/os_linux/**
{{ end }}

# WSL: solo cuando estemos en WSL
{{ if not .isWSL }}
home/profile_wsl/**
{{ end }}

# Windows: solo en windows nativo
{{ if ne .chezmoi.os "windows" }}
home/os_windows/**
{{ end }}
