# Justfile -- Orquestador Global ({{ .chezmoi.hostname }})
# Generado por Chezmoi — no editar en $HOME directamente.

DOCKER := `if command -v podman >/dev/null 2>&1; then echo "podman"; else echo "docker"; fi`

default:
    @just --list

# ── Universales ───────────────────────────────────────────────────

apply:
    chezmoi apply

diff:
    chezmoi diff

update:
    chezmoi update

edit FILE:
    chezmoi edit {{`{{FILE}}` }} --apply

# chezmoi git corre git dentro del source-path sin cd ni -C ni tokens ilegales.
save MSG="feat: update dotfiles":
    cd $(chezmoi source-path) && git add . && git commit -m "{{`{{MSG}}`}}" && git push

# ── Linux / Workspace ──────────────────────────────────────────────

project-new NAME CATEGORY="personal" LANG="generic":
    @scaffold-project.sh {{`{{NAME}}` }} {{`{{CATEGORY}}` }} {{`{{LANG}}` }}

install:
    @if [ -f /etc/fedora-release ]; then \
        bash $(chezmoi source-path)/provision/installers/fedora.sh; \
    elif [ -f /etc/arch-release ]; then \
        bash $(chezmoi source-path)/scripts/packages/installers/arch.sh; \
    elif [ -f /etc/debian_version ]; then \
        bash $(chezmoi source-path)/provision/installers/debian.sh; \
    fi

{{ if and (hasKey . "isServer") .isServer }}
# ── Homelab ───────────────────────────────────────────────────────

homelab-status:
    cd $HOME/.local/share/homelab-infra && ./manage.sh status

homelab-logs SERVICE:
    cd $HOME/.local/share/homelab-infra && {{`{{DOCKER}}` }} compose -f containers/{{`{{SERVICE}}` }}/compose.yaml logs -f

homelab-update:
    cd $HOME/.local/share/homelab-infra && ./deploy.sh
{{ end }}
