# Justfile -- Orquestador Global ({{ .chezmoi.hostname }})
# Generado por Chezmoi: No editar manualmente en el HOME.

{{ if eq .chezmoi.os "windows" -}}
set windows-shell := ["powershell.exe", "-NoLogo", "-Command"]
{{- end }}

# --- Variables de Entorno y Configuracion ---
{{ if ne .chezmoi.os "windows" -}}
DOCKER := `if which podman >/dev/null 2>&1; then echo "podman"; else echo "docker"; fi`
{{- end }}

default:
	@just --list

# --- Comandos Universales (Dotfiles & Desarrollo) ---

# Aplicar todos los dotfiles (Chezmoi)
apply:
{{- if ne .chezmoi.os "windows" }}
	@sudo -v
	chezmoi apply
{{- else }}
	chezmoi apply
{{- end }}

# Ver cambios pendientes
diff:
	chezmoi diff

# Pull del repo + apply
update:
	chezmoi update

# Editar un dotfile y aplicar
edit FILE:
	chezmoi edit {{ "{{" }}FILE{{ "}}" }} --apply

{{ if ne .chezmoi.os "windows" -}}
# Crear un nuevo proyecto con la estructura estandar (Senior Blueprint)
project-new NAME CATEGORY="personal" LANG="generic":
	@bash $(chezmoi source-path)/scripts/scaffold-project.sh {{ "{{" }}NAME{{ "}}" }} {{ "{{" }}CATEGORY{{ "}}" }} {{ "{{" }}LANG{{ "}}" }}

# Instalar paquetes segun el distro actual
install:
	@if [ -f /etc/fedora-release ]; then \
		bash scripts/packages/installers/fedora.sh; \
	elif [ -f /etc/arch-release ]; then \
		bash scripts/packages/installers/arch.sh; \
	elif [ -f /etc/debian_version ]; then \
		bash scripts/packages/installers/debian.sh; \
	fi
{{- end }}

# Commit rapido del repo de dotfiles
save MSG="feat: update dotfiles":
{{- if eq .chezmoi.os "windows" }}
	git add .
	git commit -m '{{ "{{" }}MSG{{ "}}" }}'
	git push
{{- else }}
	cd $(chezmoi source-path) && git add . && git commit -m "{{ "{{" }}MSG{{ "}}" }}" && git push
{{- end }}

{{ if eq .chezmoi.os "windows" -}}
# [WINDOWS ONLY] Configurar la nueva distro WSL con toda la identidad
bootstrap-wsl:
	Write-Host "==> Inyectando identidad en WSL..." -ForegroundColor Cyan
	wsl -d Ubuntu-24.04 -- bash -c "mkdir -p ~/.config/chezmoi"
	if (Test-Path "$HOME\.config\chezmoi\key.txt") { Get-Content "$HOME\.config\chezmoi\key.txt" -Raw | wsl -d Ubuntu-24.04 -- bash -c "cat > ~/.config/chezmoi/key.txt" }
	Write-Host "==> Instalando chezmoi en WSL..." -ForegroundColor Cyan
	wsl -d Ubuntu-24.04 -- bash -c "curl -fsLS get.chezmoi.io | bash -s -- -b ~/.local/bin"
	Write-Host "==> Inicializando configuración..." -ForegroundColor Cyan
	wsl -d Ubuntu-24.04 -- bash -c "~/.local/bin/chezmoi init --apply --data githubToken=$(gh auth token) yordycg"
{{- end }}

# --- Comandos de Servidor / Infraestructura (Nodo 1) ---
{{- if and (ne .chezmoi.os "windows") (hasKey . "isServer") .isServer }}
# Ver estado de todos los contenedores del Homelab
homelab-status:
	cd $HOME/.local/share/homelab-infra && ./manage.sh status

# Ver logs de un servicio especifico del Homelab
homelab-logs SERVICE:
	cd $HOME/.local/share/homelab-infra && {{ "{{" }}DOCKER{{ "}}" }} compose -f containers/{{ "{{" }}SERVICE{{ "}}" }}/compose.yaml logs -f

# Actualizar y reiniciar la infraestructura
homelab-update:
	cd $HOME/.local/share/homelab-infra && ./deploy.sh
{{- end }}
