{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_15-setup-password-store.sh.tmpl
# Configuración del almacén de contraseñas de passage (Age-based)
# =============================================================================
set -euo pipefail

{{ include "provision/lib/logging.sh" }}

log_step "Configurando Password Store (passage)..."

# ── 1. Configurar Identidad de passage usando la llave de age ────────────────
AGE_KEY="$HOME/.config/age/key.txt"
CHEZMOI_KEY="$HOME/.config/chezmoi/key.txt"
PASSAGE_DIR="$HOME/.passage"
PASSAGE_STORE="$PASSAGE_DIR/store"

mkdir -p "$PASSAGE_DIR"

# Estandarizar la ubicación de la llave de age en una máquina nueva
if [ ! -f "$AGE_KEY" ] && [ -f "$CHEZMOI_KEY" ]; then
    log_info "Estandarizando llave de age de chezmoi a la ruta estándar (~/.config/age/key.txt)..."
    mkdir -p "$HOME/.config/age"
    run cp "$CHEZMOI_KEY" "$AGE_KEY"
    run chmod 600 "$AGE_KEY"
fi

if [ -f "$AGE_KEY" ]; then
    log_info "Enlazando identidad de passage con la llave de age..."
    run ln -sf "$AGE_KEY" "$PASSAGE_DIR/identities"
    log_ok "Identidad de passage configurada."
else
    log_warn "No se encontró la llave de age en $AGE_KEY ni en $CHEZMOI_KEY."
fi

# ── 2. Clonar el almacén remoto si no existe localmente ──────────────────────
# El origen principal es GitHub; Forgejo actúa como espejo/respaldo local.
REPO_URL="git@github.com:yordycg/password-store.git"

if [ ! -d "$PASSAGE_STORE" ]; then
    log_info "Clonando almacén privado de passage desde $REPO_URL..."
    if run git clone "$REPO_URL" "$PASSAGE_STORE"; then
        log_ok "Almacén de passage clonado con éxito desde GitHub."
    else
        # Si falla GitHub (ej. sin conexión externa), intentar clonar desde el espejo local de Forgejo
        FALLBACK_REPO="git@forgejo.home:yordycg/passage-store.git"
        log_info "Probando fallback al espejo local en Forgejo: $FALLBACK_REPO..."
        if run git clone "$FALLBACK_REPO" "$PASSAGE_STORE"; then
            log_ok "Almacén clonado con éxito desde el espejo de Forgejo."
        else
            # Si también falla, probar la ruta anterior de password-store de Forgejo
            FALLBACK_REPO_OLD="git@forgejo.home:yordycg/password-store.git"
            log_info "Probando fallback al repositorio de pass antiguo en Forgejo: $FALLBACK_REPO_OLD..."
            if run git clone "$FALLBACK_REPO_OLD" "$PASSAGE_STORE"; then
                log_ok "Almacén clonado desde el repositorio antiguo de Forgejo (requiere migración GPG a Age)."
            else
                log_warn "No se pudo clonar ningún repositorio de contraseñas. Se inicializará un almacén vacío."
                mkdir -p "$PASSAGE_STORE"
            fi
        fi
    fi
else
    log_info "El almacén ~/.passage/store ya existe. Omitiendo clonación."
fi

# ── 3. Asegurar destinatario .age-recipients si el almacén fue inicializado ──
if [ -d "$PASSAGE_STORE" ] && [ -f "$AGE_KEY" ]; then
    if [ ! -f "$PASSAGE_STORE/.age-recipients" ]; then
        log_info "Inicializando destinatarios del almacén (.age-recipients)..."
        run age-keygen -y "$AGE_KEY" > "$PASSAGE_STORE/.age-recipients"
        log_ok "Destinatarios inicializados con la clave de age pública."
    fi
fi

# ── 4. Descargar EFF Wordlist para passage-rofi ──────────────────────────────
WORDLIST_DIR="$HOME/.local/share/passage-rofi"
WORDLIST_PATH="$WORDLIST_DIR/eff_large_wordlist.txt"

if [ ! -f "$WORDLIST_PATH" ]; then
    log_info "Descargando EFF Wordlist para passage-rofi..."
    mkdir -p "$WORDLIST_DIR"
    if run curl -sSL -o "$WORDLIST_PATH" https://www.eff.org/files/2016/07/18/eff_large_wordlist.txt; then
        log_ok "EFF Wordlist descargada con éxito en $WORDLIST_PATH."
    else
        log_warn "Error al descargar la EFF Wordlist. Se omitirá."
    fi
fi
{{- end }}
