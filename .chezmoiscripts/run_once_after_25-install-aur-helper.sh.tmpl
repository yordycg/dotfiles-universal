{{- if eq .node.distro "arch" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_25-install-aur-helper.sh.tmpl
# Instalación del helper de AUR (yay) en espacio de usuario
# =============================================================================
set -euo pipefail

if command -v yay &>/dev/null; then
    echo "→ Yay ya está instalado. Saltando."
    exit 0
fi

echo "→ Instalando Yay (AUR Helper en Go)..."

# Dependencias para compilar/instalar yay-bin
sudo pacman -S --noconfirm --needed git base-devel

TEMP_DIR=$(mktemp -d)
git clone https://aur.archlinux.org/yay-bin.git "$TEMP_DIR"
cd "$TEMP_DIR"

# makepkg no se puede correr como root. Se ejecuta con el usuario actual.
makepkg -si --noconfirm

rm -rf "$TEMP_DIR"
echo "✓ Yay instalado correctamente."
{{- end }}
