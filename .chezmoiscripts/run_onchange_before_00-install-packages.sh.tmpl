{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_before_00-install-packages.sh.tmpl
# Bootstrap de Secretos y Paquetes del Sistema
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── 1. Gestión de Estado (Caché Senior) ──────────────────────────────────────
# Hashes de dependencias para forzar ejecución en cambios:
# {{ include "scripts/packages/packages.yaml" | sha256sum }} {{ include "scripts/packages/installers/fedora.sh" | sha256sum }} {{ include "scripts/packages/installers/debian.sh" | sha256sum }}

log_step "Paquetes del Sistema"

# ── 2. Bootstrap de Secretos (Age) ───────────────────────────────────────────
log_info "Configurando Secretos (Age)..."
AGE_KEY_FILE="$HOME/.config/age/key.txt"

if [ -z "${CHEZMOI_AGE_KEY:-}" ]; then
    log_info "Sin llave en entorno. Usando archivo local en $AGE_KEY_FILE"
else
    if [ ! -f "$AGE_KEY_FILE" ]; then
        mkdir -p "$(dirname "$AGE_KEY_FILE")"
        echo "$CHEZMOI_AGE_KEY" > "$AGE_KEY_FILE"
        chmod 600 "$AGE_KEY_FILE"
        log_ok "Llave age inyectada en $AGE_KEY_FILE"
    fi
fi

# ── 3. Instalación de Paquetes ───────────────────────────────────────────────
log_info "Detectando sistema y sincronizando paquetes..."

# Inyectar capacidades para los instaladores
export NODE_HAS_GUI="{{ .hasGUI }}"
export NODE_IS_SERVER="{{ .isServer }}"
export NODE_IS_WSL="{{ .isWSL }}"

if [ -f /etc/fedora-release ]; then
    bash "{{ .chezmoi.sourceDir }}/scripts/packages/installers/fedora.sh"
elif [ -f /etc/debian_version ]; then
    bash "{{ .chezmoi.sourceDir }}/scripts/packages/installers/debian.sh"
else
    log_warn "SO no soportado para instalación automática."
fi


# Guardar estado exitoso
log_ok "Instalación completada exitosamente."
{{- end }}