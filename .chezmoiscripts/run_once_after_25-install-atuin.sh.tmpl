{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_25-install-atuin.sh.tmpl
# Instalador universal de Atuin en espacio de usuario.
# =============================================================================
set -euo pipefail

{{ include "provision/lib/logging.sh" }}

# Asegurar que ~/.local/bin existe
mkdir -p "$HOME/.local/bin"

if [ ! -f "$HOME/.local/bin/atuin" ]; then
    log_step "Instalador de Atuin — Descargando la última versión oficial"
    # Descargamos e instalamos el binario de forma no interactiva y limpia en ~/.local/bin
    export ATUIN_NO_MODIFY_PATH=1
    export ATUIN_INSTALL_DIR="$HOME/.local/bin"
    if curl --proto '=https' --tlsv1.2 -LsSf https://github.com/atuinsh/atuin/releases/latest/download/atuin-installer.sh | sh; then
        log_ok "Atuin se instaló correctamente en ~/.local/bin/."
    else
        log_err "Fallo al instalar Atuin usando el script de descarga de binarios."
    fi
else
    log_info "Atuin ya está instalado localmente en ~/.local/bin (versión: $($HOME/.local/bin/atuin --version))."
fi
{{- end }}
