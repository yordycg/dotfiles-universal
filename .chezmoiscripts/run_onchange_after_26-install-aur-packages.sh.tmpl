{{- if eq .node.distro "arch" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_onchange_after_26-install-aur-packages.sh.tmpl
# Instalación y actualización automática de paquetes del AUR
# =============================================================================
# Hash de la matriz de paquetes: {{ include ".chezmoidata/packages.yaml" | sha256sum }}

set -euo pipefail

if command -v paru &>/dev/null && paru --version &>/dev/null; then
    AUR_HELPER="paru"
elif command -v yay &>/dev/null; then
    AUR_HELPER="yay"
else
    echo "! Ningún helper de AUR funcional (paru/yay) encontrado. Omitiendo instalación de paquetes AUR."
    exit 0
fi

echo "→ Sincronizando paquetes de AUR usando $AUR_HELPER..."
$AUR_HELPER -S --noconfirm --needed {{ range .arch.aur }}{{ . }} {{ end }}
echo "✓ Paquetes de AUR sincronizados."
{{- end }}
