{{/*
  DESACTIVADO (julio 2026): se abandonó el modelo cliente/servidor.
  Ahora se usa un flujo mono-máquina con restauración perezosa de
  tmux-continuum (ver tmux.conf.tmpl + funciones en tmux.sh).
  Para reactivar en el futuro (ej. volver a un nodo servidor headless),
  cambiar `false` por la condición real, p.ej.:
  {{ if and (eq .chezmoi.os "linux") .isServer -}}
*/}}
{{ if false -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_90-setup-tmux-service.sh.tmpl
# Configura y habilita el servicio de tmux de systemd de usuario
# =============================================================================
# Hash de dependencia para forzar ejecución al cambiar el archivo de servicio:
# {{ include "dot_config/systemd/user/tmux.service.tmpl.disabled" | sha256sum }}

set -euo pipefail

{{ include "provision/lib/logging.sh" }}

# Asegurar que systemctl --user pueda encontrar el bus de sesion,
# independiente del entorno desde el que chezmoi haya lanzado este script.
export XDG_RUNTIME_DIR="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
export DBUS_SESSION_BUS_ADDRESS="${DBUS_SESSION_BUS_ADDRESS:-unix:path=${XDG_RUNTIME_DIR}/bus}"

# Comprobar si systemd de usuario está disponible y activo
if systemctl --user &>/dev/null; then
    log_step "Configurando servicio de usuario de Systemd para Tmux"
    
    # Recargar el demonio para detectar el nuevo archivo de servicio
    systemctl --user daemon-reload
    
    # 1. Lingering: check robusto usando la property directamente
    linger_status="$(loginctl show-user "$USER" --property=Linger --value 2>/dev/null || echo "unknown")"

    if [[ "$linger_status" != "yes" ]]; then
        log_info "Habilitando lingering para el usuario $USER..."
        # No abortamos el script entero si esto falla: el lingering
        # es deseable pero no debe bloquear el enable del servicio.
        if ! loginctl enable-linger "$USER" 2>/dev/null; then
            log_warn "No se pudo habilitar lingering sin privilegios elevados. Intenta manualmente: sudo loginctl enable-linger $USER"
        else
            log_ok "Lingering habilitado correctamente."
        fi
    else
        log_info "Lingering ya esta habilitado para el usuario $USER."
    fi

    # 2. Habilitar y arrancar el servicio tmux.service
    if ! systemctl --user is-enabled tmux &>/dev/null; then
        log_info "Habilitando servicio tmux.service..."
        systemctl --user enable --now tmux
        log_ok "Servicio de tmux habilitado y arrancado correctamente."
    else
        log_info "El servicio tmux.service ya está habilitado."
        # Nos aseguramos de que esté corriendo sin reiniciar (para no matar sesiones activas)
        if ! systemctl --user is-active tmux &>/dev/null; then
            log_info "Iniciando servicio tmux.service (estaba habilitado pero detenido)..."
            systemctl --user start tmux
            log_ok "Servicio tmux.service iniciado."
        else
            log_info "El servicio tmux.service ya está corriendo."
        fi
    fi
else
    log_warn "Systemd de usuario no disponible o no activo. Saltando la configuración del servicio tmux."
fi
{{ end -}}
