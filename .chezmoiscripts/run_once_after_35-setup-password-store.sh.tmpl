{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_35-setup-password-store.sh.tmpl
# Clonado automático del almacén de contraseñas de pass
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
BLUE='\033[0;34m'
RESET='\033[0m'

echo -e "\n${BLUE}▶ Configurando Password Store (pass)...${RESET}"

# ── 1. Importar y configurar llave GPG si está sembrada ──────────────────────
GPG_KEYS_DIR="$HOME/.config/gpg_keys"
GPG_PUB_KEY="$GPG_KEYS_DIR/gpg_public.asc"
GPG_PRIV_KEY="$GPG_KEYS_DIR/gpg_private.asc"

if [ -f "$GPG_PRIV_KEY" ] && [ -f "$GPG_PUB_KEY" ]; then
    echo -e "${BLUE}  → Detectadas llaves GPG sembradas en $GPG_KEYS_DIR. Importando...${RESET}"
    gpg --import "$GPG_PUB_KEY"
    gpg --import "$GPG_PRIV_KEY"
    
    # Extraer ID de la llave importada para configurar confianza automática
    KEY_ID=$(gpg --show-keys --keyid-format=long "$GPG_PUB_KEY" | grep -E "^pub" | awk '{print $2}' | cut -d'/' -f2 || echo "")
    if [ -n "$KEY_ID" ]; then
        echo -e "${BLUE}  → Configurando confianza absoluta para la llave $KEY_ID...${RESET}"
        echo -e "5\ny\n" | gpg --command-fd 0 --expert --edit-key "$KEY_ID" trust
    fi
    
    # Eliminar llave privada del directorio temporal por seguridad (ya queda en el llavero de GPG)
    rm -f "$GPG_PRIV_KEY"
    echo -e "${GREEN}  ✓ Llaves GPG importadas con éxito y llave privada temporal eliminada.${RESET}"
fi

# URL por defecto del repositorio en Forgejo (con fallback)
REPO_URL="git@forgejo.home:yordycg/password-store.git"

if [ ! -d "$HOME/.password-store" ]; then
    echo -e "${BLUE}  → Clonando almacén privado desde $REPO_URL...${RESET}"
    if git clone "$REPO_URL" "$HOME/.password-store" 2>/dev/null; then
        echo -e "${GREEN}  ✓ Almacén de contraseñas clonado con éxito.${RESET}"
    else
        # Fallback a GitHub si no está en la red local de Forgejo
        FALLBACK_URL="git@github.com:yordycg/password-store.git"
        echo -e "${BLUE}  → Fallando a GitHub: $FALLBACK_URL...${RESET}"
        if git clone "$FALLBACK_URL" "$HOME/.password-store"; then
            echo -e "${GREEN}  ✓ Almacén clonado con éxito desde GitHub.${RESET}"
        else
            echo -e "${BLUE}  ⚠ No se pudo clonar el repositorio. Asegúrate de tener tu llave SSH cargada.${RESET}"
        fi
    fi
else
    echo -e "${BLUE}  → El almacén ~/.password-store ya existe. Omitiendo clonación.${RESET}"
fi
{{- end }}
