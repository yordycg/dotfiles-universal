{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_35-setup-password-store.sh.tmpl
# Configuración del almacén de contraseñas de passage (Age-based)
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
BLUE='\033[0;34m'
RESET='\033[0m'

echo -e "\n${BLUE}▶ Configurando Password Store (passage)...${RESET}"

# ── 1. Configurar Identidad de passage usando la llave de age ────────────────
AGE_KEY="$HOME/.config/age/key.txt"
CHEZMOI_KEY="$HOME/.config/chezmoi/key.txt"
PASSAGE_DIR="$HOME/.passage"
PASSAGE_STORE="$PASSAGE_DIR/store"

mkdir -p "$PASSAGE_DIR"

# Estandarizar la ubicación de la llave de age en una máquina nueva
if [ ! -f "$AGE_KEY" ] && [ -f "$CHEZMOI_KEY" ]; then
    echo -e "${BLUE}  → Estandarizando llave de age de chezmoi a la ruta estándar (~/.config/age/key.txt)...${RESET}"
    mkdir -p "$HOME/.config/age"
    cp "$CHEZMOI_KEY" "$AGE_KEY"
    chmod 600 "$AGE_KEY"
fi

if [ -f "$AGE_KEY" ]; then
    echo -e "${BLUE}  → Enlazando identidad de passage con la llave de age...${RESET}"
    ln -sf "$AGE_KEY" "$PASSAGE_DIR/identities"
    echo -e "${GREEN}  ✓ Identidad de passage configurada.${RESET}"
else
    echo -e "${BLUE}  ⚠ No se encontró la llave de age en $AGE_KEY ni en $CHEZMOI_KEY.${RESET}"
fi

# ── 2. Clonar el almacén remoto si no existe localmente ──────────────────────
# Intentar usar passage-store.git primero; si falla, password-store.git (que luego migraremos)
REPO_URL="git@forgejo.home:yordycg/passage-store.git"

if [ ! -d "$PASSAGE_STORE" ]; then
    echo -e "${BLUE}  → Clonando almacén privado de passage desde $REPO_URL...${RESET}"
    if git clone "$REPO_URL" "$PASSAGE_STORE" 2>/dev/null; then
        echo -e "${GREEN}  ✓ Almacén de passage clonado con éxito.${RESET}"
    else
        # Si no existe el repo de passage, intentar clonar el password-store (para luego migrar)
        FALLBACK_REPO="git@forgejo.home:yordycg/password-store.git"
        echo -e "${BLUE}  → Probando fallback al repositorio de pass original: $FALLBACK_REPO...${RESET}"
        if git clone "$FALLBACK_REPO" "$PASSAGE_STORE" 2>/dev/null; then
            echo -e "${GREEN}  ✓ Almacén clonado con éxito (requiere migración GPG a Age).${RESET}"
        else
            # Intentar desde GitHub en caso de estar fuera de la red local
            GITHUB_REPO="git@github.com:yordycg/password-store.git"
            echo -e "${BLUE}  → Probando fallback desde GitHub: $GITHUB_REPO...${RESET}"
            if git clone "$GITHUB_REPO" "$PASSAGE_STORE" 2>/dev/null; then
                echo -e "${GREEN}  ✓ Almacén clonado desde GitHub (requiere migración GPG a Age).${RESET}"
            else
                echo -e "${BLUE}  ⚠ No se pudo clonar ningún repositorio de contraseñas. Se inicializará un almacén vacío.${RESET}"
                mkdir -p "$PASSAGE_STORE"
            fi
        fi
    fi
else
    echo -e "${BLUE}  → El almacén ~/.passage/store ya existe. Omitiendo clonación.${RESET}"
fi

# ── 3. Asegurar destinatario .age-recipients si el almacén fue inicializado ──
if [ -d "$PASSAGE_STORE" ] && [ -f "$AGE_KEY" ]; then
    if [ ! -f "$PASSAGE_STORE/.age-recipients" ]; then
        echo -e "${BLUE}  → Inicializando destinatarios del almacén (.age-recipients)...${RESET}"
        age-keygen -y "$AGE_KEY" > "$PASSAGE_STORE/.age-recipients"
        echo -e "${GREEN}  ✓ Destinatarios inicializados con la clave de age pública.${RESET}"
    fi
fi
{{- end }}
