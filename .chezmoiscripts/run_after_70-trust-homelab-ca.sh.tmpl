{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_95-trust-homelab-ca.sh.tmpl
# Confianza SSL e Infraestructura PKI
# =============================================================================

# El servidor ES la fuente de los certificados, no necesita instalarlos
{{ if .isServer -}}
exit 0
{{- end }}

set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

DOMAIN="vault.home"
ROOT_CERT_NAME="homelab-root-ca.crt"
INT_CERT_NAME="homelab-intermediate-ca.crt"
BUNDLE_NAME="homelab-ca-bundle.crt"
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

# ── Caché: evitar SSH al servidor si el cert no cambió ───────────────────────
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
CA_STATE_FILE="$CACHE_DIR/homelab-ca-state"

# Determinar ruta del bundle instalado según distro
INSTALLED_BUNDLE=""
if [ -f /etc/debian_version ]; then
    INSTALLED_BUNDLE="/usr/local/share/ca-certificates/homelab-ca-bundle.crt"
elif [ -f /etc/fedora-release ]; then
    INSTALLED_BUNDLE="/etc/pki/ca-trust/source/anchors/homelab-ca-bundle.crt"
fi

# Si el bundle existe y el hash coincide con el guardado → salir en silencio
if [ -f "$INSTALLED_BUNDLE" ] && [ -f "$CA_STATE_FILE" ]; then
    CURRENT_HASH=$(sha256sum "$INSTALLED_BUNDLE" | awk '{print $1}')
    CACHED_HASH=$(cat "$CA_STATE_FILE")
    if [ "$CURRENT_HASH" = "$CACHED_HASH" ]; then
        exit 0  # Certificado sin cambios — silencio absoluto
    fi
fi

log_step "Confianza SSL (Homelab PKI)"

# ── 1. Obtención de Certificados (Root e Intermediate) ───────────────────────

fetch_certs() {
    local type=$1 # "root" o "intermediate"
    local filename="${type}.crt"
    local dst="$TEMP_DIR/$filename"

    # Método A: Docker Volumen (Si estamos en el servidor)
    if command -v docker &>/dev/null && docker ps &>/dev/null && docker volume inspect reverse-proxy_caddy_data &>/dev/null; then
        log_info "Buscando $filename en volumen Docker local..."
        docker run --rm -v reverse-proxy_caddy_data:/data alpine cat "/data/caddy/pki/authorities/local/$filename" > "$dst" 2>/dev/null || true
    fi

    # Método B: Rutas Locales (Legacy/Podman)
    if [ ! -s "$dst" ]; then
        local paths=(
            "/var/lib/docker/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/$filename"
            "/home/yordycg/.local/share/containers/storage/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/$filename"
        )
        for p in "${paths[@]}"; do
            if [ -f "$p" ]; then cp "$p" "$dst" && break; break; fi
        done
    fi

    # Método C: SSH desde el Servidor (Para Nodos N)
    if [ ! -s "$dst" ] && [ "{{ if (hasKey . "isServer") }}{{ .isServer }}{{ else }}false{{ end }}" != "true" ]; then
        SSH_OPTS="-o ConnectTimeout=3 -o StrictHostKeyChecking=accept-new -o BatchMode=yes"
        if ssh $SSH_OPTS homelab exit &>/dev/null; then
            log_info "Extrayendo $filename desde el servidor vía SSH..."
            if ! ssh -q $SSH_OPTS homelab "docker run --rm -v reverse-proxy_caddy_data:/data alpine cat /data/caddy/pki/authorities/local/$filename" > "$dst" 2>/dev/null; then
                ssh -q $SSH_OPTS homelab "cat /var/lib/docker/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/$filename" > "$dst" 2>/dev/null || true
            fi
        fi
    fi

    # Método D: Descarga Red (Fallback)
    if [ ! -s "$dst" ]; then
        if ping -c 1 -W 1 "$DOMAIN" &>/dev/null; then
            if [[ "$type" == "root" ]]; then
                log_info "Descargando Root CA desde https://${DOMAIN}/pki/ca/local..."
                curl -k -s "https://${DOMAIN}/pki/ca/local" -o "$dst" || true
            fi
        fi
    fi
    
    if [ -s "$dst" ]; then
        log_ok "Obtenido: $filename"
    else
        log_warn "No se pudo obtener $filename por ningún método."
    fi
}

fetch_certs "root"
fetch_certs "intermediate"

# Crear Bundle si tenemos ambos
if [[ -s "$TEMP_DIR/root.crt" && -s "$TEMP_DIR/intermediate.crt" ]]; then
    log_info "Creando bundle de certificados..."
    cat "$TEMP_DIR/root.crt" "$TEMP_DIR/intermediate.crt" > "$TEMP_DIR/bundle.crt"
    log_ok "Bundle homelab-ca-bundle.crt generado."
fi

# ── 2. Instalación en el Sistema ─────────────────────────────────────────────

install_cert() {
    local src=$1
    local name=$2
    
    if [ ! -s "$src" ]; then return; fi

    if [ -f /etc/debian_version ]; then
        local store="/usr/local/share/ca-certificates/${name}"
        [[ "$name" != *.crt ]] && store="${store}.crt"
        local update_cmd="sudo update-ca-certificates"
    elif [ -f /etc/fedora-release ]; then
        local store="/etc/pki/ca-trust/source/anchors/${name}"
        local update_cmd="sudo update-ca-trust"
    else
        return
    fi

    if [ -f "$store" ] && diff -q "$src" "$store" &>/dev/null; then
        log_ok "Certificado $name ya sincronizado."
    else
        log_info "Instalando $name..."
        sudo cp "$src" "$store"
        sudo chmod 644 "$store"
        $update_cmd > /dev/null
        log_ok "$name instalado."
    fi
}

install_cert "$TEMP_DIR/root.crt" "$ROOT_CERT_NAME"
install_cert "$TEMP_DIR/intermediate.crt" "$INT_CERT_NAME"
install_cert "$TEMP_DIR/bundle.crt" "$BUNDLE_NAME"

# Guardar hash del bundle recién instalado
if [ -f "$INSTALLED_BUNDLE" ]; then
    sha256sum "$INSTALLED_BUNDLE" | awk '{print $1}' > "$CA_STATE_FILE"
fi
{{- end }}