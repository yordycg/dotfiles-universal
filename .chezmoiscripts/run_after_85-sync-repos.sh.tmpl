{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/sync-forgejo-repos.sh.tmpl
# Sincronización automática de todos los repositorios de Forgejo
# =============================================================================
set -euo pipefail

# No ejecutar en el servidor
{{ if and (eq .chezmoi.os "linux") (hasKey . "isServer") .isServer -}}
exit 0
{{- end }}

# Colores
CYAN='\033[0;36m'
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${BLUE}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── Extracción de Secretos (Runtime Decryption) ──────────────────────────────
SECRETS_FILE="{{ .chezmoi.sourceDir }}/dot_config/homelab/private_secrets.yaml.age"
FORGEJO_TOKEN=""

if [ -f "$SECRETS_FILE" ] && command -v chezmoi &>/dev/null; then
    FORGEJO_TOKEN=$(chezmoi decrypt "$SECRETS_FILE" 2>/dev/null | grep "forgejo_token:" | awk '{print $2}' | tr -d '"' || echo "")
fi
FORGEJO_URL="http://192.168.18.99:3080/api/v1"
FORGEJO_TOKEN="{{ $forgejoToken }}"

if [ -z "$FORGEJO_TOKEN" ]; then
    log_warn "Forgejo Token no encontrado en secretos. Saltando sincronización de repositorios."
    exit 0
fi

# Verificar conexión con Forgejo (Aceptamos 401/405 como 'servidor vivo')
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 "$FORGEJO_URL/user" -H "Authorization: token $FORGEJO_TOKEN" || echo "000")

if [[ "$HTTP_STATUS" == "000" ]]; then
    log_warn "Servidor Forgejo no alcanzable en $FORGEJO_URL. Saltando sincronización."
    exit 0
fi

log_step "Sincronizando repositorios desde Forgejo"

# Obtener lista de repositorios del usuario
REPOS_JSON=$(curl -s -H "Authorization: token $FORGEJO_TOKEN" "$FORGEJO_URL/user/repos")

# Procesar cada repositorio
echo "$REPOS_JSON" | jq -c '.[]' | while read -r repo; do
    NAME=$(echo "$repo" | jq -r '.name')
    SSH_URL=$(echo "$repo" | jq -r '.ssh_url')
    
    # Exclusiones (Repositorios core que se manejan en otro script)
    if [[ "$NAME" == "dotfiles-universal" || "$NAME" == "homelab-infra" ]]; then
        continue
    fi

    # Determinar categoría basada en el nombre
    CATEGORY="ipvg" 
    
    # Excepciones
    if [[ "$NAME" == "wallpapers" || "$NAME" == "obsidian-notes" ]]; then
        CATEGORY="assets"
    elif [[ "$NAME" == "yordycg-portfolio" ]]; then
        CATEGORY="personal"
    fi

    TARGET_PATH="$HOME/workspace/$CATEGORY/$NAME"

    if [ ! -d "$TARGET_PATH" ]; then
        log_info "Clonando $NAME en $TARGET_PATH..."
        mkdir -p "$(dirname "$TARGET_PATH")"
        git clone -q "$SSH_URL" "$TARGET_PATH"
        log_ok "$NAME clonado."
    else
        log_info "$NAME ya existe, actualizando..."
        cd "$TARGET_PATH"
        if git diff-index --quiet HEAD --; then
            git pull -q --rebase
            log_ok "$NAME actualizado."
        else
            log_warn "$NAME tiene cambios locales, saltando pull."
        fi
        cd - > /dev/null
    fi
done
{{- end }}
