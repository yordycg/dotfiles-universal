{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_after_50-setup-ssh.sh.tmpl
# Registro de identidad SSH en GitHub y Forgejo.
# NO genera llaves — las llaves se siembran manualmente en cada nodo.
# =============================================================================
set -euo pipefail

# ── Guard de rol ──────────────────────────────────────────────────────────────
# El servidor no necesita registrar llaves como cliente
{{ if .isServer -}}
exit 0
{{- end }}

{{ include "provision/lib/logging.sh" }}

SSH_KEY_PATH="$HOME/.ssh/id_ed25519"
SSH_KEY_PUB_PATH="${SSH_KEY_PATH}.pub"
HOSTNAME="{{ .chezmoi.hostname }}"
KEY_TITLE="SSH Key: ${HOSTNAME}"
SSH_CONFIG_FILE="$HOME/.ssh/config"

# ── Caché: evitar trabajo repetido ───────────────────────────────────────────
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
STATE_FILE="$CACHE_DIR/ssh-state"

# El estado se basa en la existencia y fingerprint de la llave pública
if [ -f "$SSH_KEY_PUB_PATH" ] && [ -f "$STATE_FILE" ]; then
    CURRENT_FP=$(ssh-keygen -lf "$SSH_KEY_PUB_PATH" 2>/dev/null | awk '{print $2}' || echo "")
    CACHED_FP=$(cat "$STATE_FILE" 2>/dev/null || echo "")
    if [ "$CURRENT_FP" = "$CACHED_FP" ] && [ -n "$CURRENT_FP" ]; then
        exit 0  # Llave ya registrada en sesión anterior — silencio
    fi
fi

# ── 1. Verificar que la llave existe ─────────────────────────────────────────
log_step "Identidad SSH — ${HOSTNAME}"

if [ ! -f "$SSH_KEY_PATH" ] || [ ! -f "$SSH_KEY_PUB_PATH" ]; then
    log_warn "Llave SSH no encontrada en $SSH_KEY_PATH"
    log_warn "Protocolo de siembra manual: copia tu id_ed25519 antes de ejecutar chezmoi apply."
    log_warn "Saltando registro de identidad."
    exit 0  # No es un error fatal — el usuario debe sembrar la llave
fi

log_ok "Llave SSH encontrada: $SSH_KEY_PATH"

# ── 2. Extraer tokens de secretos ────────────────────────────────────────────
GITHUB_TOKEN=""
FORGEJO_TOKEN=""

# Buscar passage de forma robusta
PASSAGE_CMD="passage"
if [ -f "$HOME/.local/bin/passage" ]; then
    PASSAGE_CMD="$HOME/.local/bin/passage"
fi

if command -v "$PASSAGE_CMD" &>/dev/null; then
    GITHUB_TOKEN=$("$PASSAGE_CMD" chezmoi/github_token 2>/dev/null || echo "")
    FORGEJO_TOKEN=$("$PASSAGE_CMD" chezmoi/forgejo_token 2>/dev/null || echo "")
elif command -v pass &>/dev/null; then
    GITHUB_TOKEN=$(pass chezmoi/github_token 2>/dev/null || echo "")
    FORGEJO_TOKEN=$(pass chezmoi/forgejo_token 2>/dev/null || echo "")
fi

# ── 3. GitHub — autenticación ────────────────────────────────────────────────
if command -v gh &>/dev/null; then
    if ! gh auth status &>/dev/null; then
        if [ -n "$GITHUB_TOKEN" ]; then
            log_info "Autenticando en GitHub con token..."
            echo "$GITHUB_TOKEN" | gh auth login --with-token
            gh auth setup-git
            log_ok "Autenticado en GitHub."
        else
            log_warn "GitHub CLI no autenticado y no hay token en secrets."
            log_warn "Ejecuta manualmente: gh auth login"
        fi
    else
        gh auth setup-git > /dev/null 2>&1 || true
    fi

    # ── 4. Registrar llave pública en GitHub ─────────────────────────────────
    if gh auth status &>/dev/null; then
        if ! gh ssh-key list 2>/dev/null | grep -qF "$KEY_TITLE"; then
            log_info "Registrando llave en GitHub con título: $KEY_TITLE"
            if gh ssh-key add "$SSH_KEY_PUB_PATH" --title "$KEY_TITLE" 2>/dev/null; then
                log_ok "Llave registrada en GitHub."
            else
                log_warn "No se pudo registrar la llave en GitHub (puede que ya exista con otro título)."
            fi
        fi
    fi
fi

# ── 5. Forgejo — registrar llave pública ─────────────────────────────────────
if [ -n "$FORGEJO_TOKEN" ]; then
    FORGEJO_URL="http://{{ .homelab_ip_local }}:3080/api/v1"
    HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 "$FORGEJO_URL/user" || echo "000")

    if [ "$HTTP_STATUS" = "000" ]; then
        FORGEJO_URL="http://{{ .homelab_ip_ts }}:3080/api/v1"
        HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 "$FORGEJO_URL/user" || echo "000")
    fi

    if [ "$HTTP_STATUS" != "000" ]; then
        KEY_FINGERPRINT=$(ssh-keygen -lf "$SSH_KEY_PUB_PATH" | awk '{print $2}')
        ALREADY_REGISTERED=$(curl -s \
            -H "Authorization: token $FORGEJO_TOKEN" \
            "$FORGEJO_URL/user/keys" | grep -c "$KEY_FINGERPRINT" || echo "0")

        if [ "$ALREADY_REGISTERED" = "0" ]; then
            log_info "Registrando llave en Forgejo..."
            curl -s -X POST "$FORGEJO_URL/user/keys" \
                -H "Authorization: token $FORGEJO_TOKEN" \
                -H "Content-Type: application/json" \
                -d "{\"key\":\"$(cat "$SSH_KEY_PUB_PATH")\",\"read_only\":false,\"title\":\"$KEY_TITLE\"}" \
                > /dev/null
            log_ok "Llave registrada en Forgejo."
        fi
    else
        log_warn "Forgejo no alcanzable. La llave se registrará en el próximo apply."
    fi
fi



# ── Guardar estado exitoso ────────────────────────────────────────────────────
# Guardamos el fingerprint de la llave actual para evitar re-registro innecesario
ssh-keygen -lf "$SSH_KEY_PUB_PATH" 2>/dev/null | awk '{print $2}' > "$STATE_FILE"
log_ok "Identidad SSH configurada correctamente."
{{- end }}