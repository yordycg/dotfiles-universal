{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_85-sync-assets.sh.tmpl
# Sincronización de Assets (Wallpapers y Obsidian) - Solo clonación inicial
# =============================================================================
set -euo pipefail

{{ if not .hasGUI -}}
exit 0  # Sin entorno gráfico no necesitamos wallpapers ni Obsidian
{{- end }}

{{ include "provision/lib/logging.sh" }}

log_step "Recursos Gráficos (Assets)"

# ── 1. Clonar Repositorios Core de Assets si no existen ─────────────────────
WALLPAPERS_DIR="$HOME/workspace/assets/wallpapers"
OBSIDIAN_DIR="$HOME/workspace/assets/obsidian-notes"

# Clonar Wallpapers
if [ ! -d "$WALLPAPERS_DIR/.git" ]; then
    log_info "Clonando repositorio de Wallpapers en $WALLPAPERS_DIR..."
    mkdir -p "$(dirname "$WALLPAPERS_DIR")"
    run git clone "git@github.com:yordycg/wallpapers.git" "$WALLPAPERS_DIR" || log_warn "No se pudo clonar Wallpapers. Verifica conexión y llaves SSH."
fi

# Clonar Obsidian Notes
if [ ! -d "$OBSIDIAN_DIR/.git" ]; then
    log_info "Clonando repositorio de Obsidian Notes en $OBSIDIAN_DIR..."
    mkdir -p "$(dirname "$OBSIDIAN_DIR")"
    run git clone "git@github.com:yordycg/obsidian-notes.git" "$OBSIDIAN_DIR" || log_warn "No se pudo clonar Obsidian Notes. Verifica conexión y llaves SSH."
fi

# Clonar Learning Path (Estudio)
LEARNING_DIR="$HOME/workspace/personal/learning-path"
if [ ! -d "$LEARNING_DIR/.git" ]; then
    log_info "Clonando repositorio de Aprendizaje en $LEARNING_DIR..."
    mkdir -p "$(dirname "$LEARNING_DIR")"
    run git clone "git@github.com:yordycg/learning-path.git" "$LEARNING_DIR" || log_warn "No se pudo clonar Learning Path. Verifica conexión y llaves SSH."
fi

# ── 2. Crear Enlaces para Pictures ──────────────────────────────────────────
mkdir -p "$HOME/Pictures"

if [ ! -d "$HOME/Pictures/Wallpapers" ] && [ -d "$WALLPAPERS_DIR" ]; then
    log_info "Configurando enlaces de fondos de pantalla (Pictures)..."
    ln -sf "$WALLPAPERS_DIR" "$HOME/Pictures/Wallpapers"
    log_ok "Enlace de Wallpapers creado en ~/Pictures/Wallpapers."
fi

log_ok "Sincronización de assets finalizada."
{{- end }}