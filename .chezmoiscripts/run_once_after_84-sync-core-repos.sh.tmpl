{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_84-sync-core-repos.sh.tmpl
# Gestión específica de Repositorios de Infraestructura (Doble Remote)
# =============================================================================
set -euo pipefail

{{ include "provision/lib/logging.sh" }}

setup_dual_remote() {
    local path=$1
    local name=$2
    local forgejo_url=$3

    {{ if and (eq .chezmoi.os "linux") (hasKey . "isServer") .isServer -}}
    # En el servidor, Forgejo está en localhost:2222
    if [[ "$name" == "Chezmoi Source" ]]; then
        forgejo_url="ssh://git@localhost:2222/yordycg/dotfiles-universal.git"
    else
        forgejo_url="ssh://git@localhost:2222/yordycg/homelab-infra.git"
    fi
    {{- end }}

    if [ -d "$path/.git" ]; then
        cd "$path"
        if ! git remote | grep -q "forgejo"; then
            log_info "Añadiendo remoto Forgejo a $name..."
            git remote add forgejo "$forgejo_url"
            log_ok "Remoto forgejo añadido a $name."
        else
            # Actualizar la URL por si acaso
            git remote set-url forgejo "$forgejo_url"
        fi
        cd - > /dev/null
    fi
}

log_step "Configurando Remotos de Infraestructura (GitHub + Forgejo)"

# 1. Chezmoi Source (dotfiles-universal)
setup_dual_remote "{{ .chezmoi.sourceDir }}" "Chezmoi Source" "git@forgejo.home:yordycg/dotfiles-universal.git"

# 2. Homelab Infra (Solo si existe en el nodo actual)
if [ -d "$HOME/.local/share/homelab-infra" ]; then
    setup_dual_remote "$HOME/.local/share/homelab-infra" "Homelab Infra" "git@forgejo.home:yordycg/homelab-infra.git"
elif [ -d "$HOME/homelab-infra" ]; then
    setup_dual_remote "$HOME/homelab-infra" "Homelab Infra" "git@forgejo.home:yordycg/homelab-infra.git"
fi

log_ok "Configuración de remotes core finalizada."
{{- end }}
