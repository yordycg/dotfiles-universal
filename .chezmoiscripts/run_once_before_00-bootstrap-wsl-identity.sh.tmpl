{{ if .isWSL -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_before_00-bootstrap-wsl-identity.sh.tmpl
# "Identity Seed Puller" — Jala las llaves de Windows hacia WSL
# =============================================================================

# Colores Homelab-Style
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }

log_step "WSL Identity Bootstrap (Zero-Touch)"

# 1. Intentar detectar el usuario de Windows
# Normalmente es el mismo que el de WSL, o podemos sacarlo de la ruta de montaje
WIN_USER=$(powershell.exe -Command '$env:UserName' 2>/dev/null | tr -d '\r')
if [ -z "$WIN_USER" ]; then
    # Fallback: intentar inferir del path si powershell falla
    WIN_USER=$(ls /mnt/c/Users | grep -vE 'Public|Default|All Users|desktop.ini' | head -n 1)
fi

WIN_HOME="/mnt/c/Users/$WIN_USER"
log_info "Detectado usuario Windows: $WIN_USER"

# ── 2. Sincronización de Age (Semilla de Secretos) ──────────────────────────
AGE_DEST="$HOME/.config/age"
AGE_KEY_FILE="$AGE_DEST/key.txt"
WIN_AGE_FILE="$WIN_HOME/.config/age/key.txt"

if [ ! -f "$AGE_KEY_FILE" ]; then
    if [ -f "$WIN_AGE_FILE" ]; then
        log_info "Copiando llave de Age desde Windows..."
        mkdir -p "$AGE_DEST"
        cp "$WIN_AGE_FILE" "$AGE_KEY_FILE"
        chmod 600 "$AGE_KEY_FILE"
        log_ok "Llave de Age sincronizada."
    else
        log_warn "No se encontró llave de Age en Windows ($WIN_AGE_FILE)."
    fi
else
    log_ok "Llave de Age ya existe localmente."
fi

# ── 3. Sincronización de SSH ────────────────────────────────────────────────
SSH_DEST="$HOME/.ssh"
WIN_SSH_DIR="$WIN_HOME/.ssh"

if [ -d "$WIN_SSH_DIR" ]; then
    log_info "Sincronizando llaves SSH desde Windows..."
    mkdir -p "$SSH_DEST"
    chmod 700 "$SSH_DEST"
    
    # Copiar solo llaves privadas y públicas (id_ed25519, etc)
    # Evitamos copiar el config de Windows porque las rutas no coincidirían
    for key in "$WIN_SSH_DIR"/id_*; do
        if [ -f "$key" ]; then
            key_name=$(basename "$key")
            cp "$key" "$SSH_DEST/$key_name"
            chmod 600 "$SSH_DEST/$key_name"
            # Si tiene .pub, ajustar permisos
            if [[ "$key_name" == *.pub ]]; then
                chmod 644 "$SSH_DEST/$key_name"
            fi
        fi
    done
    log_ok "Llaves SSH sincronizadas."
else
    log_warn "No se encontró carpeta .ssh en Windows ($WIN_SSH_DIR)."
fi

log_info "Bootstrap de identidad finalizado. Chezmoi continuará con el apply."
{{ end -}}
