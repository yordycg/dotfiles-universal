{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_20-install-mise.sh.tmpl
# Gestión de Runtimes y Herramientas (Mise)
# =============================================================================
set -euo pipefail

{{ include "provision/lib/logging.sh" }}

# ── 1. Gestión de Estado (Caché Senior) ──────────────────────────────────────
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
STATE_FILE="$CACHE_DIR/mise-state"

# Hash de la configuración de Mise
CURRENT_HASH="{{ include "dot_config/mise/config.toml.tmpl" | sha256sum }}"

log_step "Gestión de Entornos (Mise)"

if [ -f "$STATE_FILE" ] && [ "$(cat "$STATE_FILE")" == "$CURRENT_HASH" ] && command -v mise &>/dev/null && command -v agy &>/dev/null; then
    log_ok "Node, Python y CLIs están sincronizados."
    exit 0
fi

# ── 2. Instalación/Sincronización ────────────────────────────────────────────

# Extraer token bajo demanda (pass)
GITHUB_TOKEN=""

# Buscar passage de forma robusta
PASSAGE_CMD="passage"
if [ -f "$HOME/.local/bin/passage" ]; then
    PASSAGE_CMD="$HOME/.local/bin/passage"
fi

if command -v "$PASSAGE_CMD" &>/dev/null; then
    GITHUB_TOKEN=$("$PASSAGE_CMD" chezmoi/github_token 2>/dev/null || echo "")
elif command -v pass &>/dev/null; then
    GITHUB_TOKEN=$(pass chezmoi/github_token 2>/dev/null || echo "")
fi

export GITHUB_TOKEN="$GITHUB_TOKEN"
export MISE_PYTHON_GITHUB_ATTESTATIONS=false
MISE_BIN="$HOME/.local/bin/mise"

if [ ! -f "$MISE_BIN" ]; then
    log_info "Instalando Mise..."
    curl -fsSL https://mise.run | sh -s -- --quiet
else
    log_info "Actualizando Mise..."
    "$MISE_BIN" self-update || true
fi

log_info "Sincronizando herramientas y CLIs globales..."
"$MISE_BIN" install -y

eval "$("$MISE_BIN" activate bash)"

# Instalar paquetes globales de Node/Python solo si son gestionados por mise
NPM_PATH=$(command -v npm 2>/dev/null || echo "")
if [ -n "$NPM_PATH" ] && [[ "$NPM_PATH" == *"/mise/"* ]] && npm --version &>/dev/null; then
    log_info "Instalando paquetes globales de Node en mise..."
    npm install -g neovim @bitwarden/cli --silent || true
fi

PIP_PATH=$(command -v pip 2>/dev/null || echo "")
if [ -n "$PIP_PATH" ] && [[ "$PIP_PATH" == *"/mise/"* ]] && pip --version &>/dev/null; then
    log_info "Instalando paquetes globales de Python en mise..."
    pip install pynvim --quiet || true
fi

# ── 3. Antigravity CLI (Sustituto de Gemini) ──────────────────────────────────
if command -v gemini &>/dev/null; then
    log_info "Eliminando Gemini CLI legacy..."
    if command -v npm &>/dev/null && npm --version &>/dev/null; then
        npm uninstall -g @google/gemini-cli --silent || true
    fi
fi

if ! command -v agy &>/dev/null; then
    log_info "Instalando Antigravity CLI..."
    curl -fsSL https://antigravity.google/cli/install.sh | bash
fi

# Guardar estado exitoso
echo "$CURRENT_HASH" > "$STATE_FILE"
log_ok "Entorno de desarrollo actualizado."
{{- end }}
