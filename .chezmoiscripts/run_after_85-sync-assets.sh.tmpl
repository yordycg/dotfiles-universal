{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_80-sync-assets.sh.tmpl
# Sincronización de Assets (Recursos Gráficos)
# Fase 4: Sincronización de Datos Externos
# =============================================================================
set -euo pipefail

{{ if not .hasGUI -}}
exit 0  # Sin entorno gráfico no necesitamos wallpapers ni Obsidian
{{- end }}

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── Funciones de Utilidad ────────────────────────────────────────────────────
sync_repo() {
    local github_url=$1
    local forgejo_url=$2
    local path=$3
    local name=$4

    local url=""
    {{ if .isServer -}}
    # En el servidor, siempre usamos Forgejo localmente
    url=$forgejo_url
    log_info "Entorno de servidor. Usando Forgejo para $name."
    {{- else -}}
    # En laptops/desktops, el origin principal es siempre GitHub
    url=$github_url
    log_info "Entorno cliente. Usando GitHub como origin para $name."
    {{- end }}

    if [ ! -d "$path/.git" ]; then
        log_info "Clonando repositorio de $name en $path..."
        mkdir -p "$(dirname "$path")"
        git clone -q "$url" "$path"
        log_ok "$name clonado exitosamente."
    else
        log_info "Actualizando $name..."
        cd "$path"
        git remote set-url origin "$url"

        # Limpiar cualquier pushurl configurado previamente
        git config --unset-all remote.origin.pushurl || true

        {{ if .isServer -}}
        # En el servidor, el push debe ir obligatoriamente a GitHub ya que el mirror en Forgejo es de solo lectura (Read-Only)
        git remote set-url --push origin "$github_url"
        log_info "  → Configurado push redirigido a GitHub (Forgejo es espejo de solo lectura)."
        {{- else -}}
        # Si estamos en cliente (laptop/desktop) y Forgejo es alcanzable, configuramos push doble
        if ssh -T -o ConnectTimeout=2 -o BatchMode=yes forgejo.home &>/dev/null; then
            git remote set-url --add --push origin "$github_url"
            git remote set-url --add --push origin "$forgejo_url"
            log_info "  → Configurado push doble (GitHub + Forgejo) para $name."
        fi
        {{- end }}
        
        if ! git diff-index --quiet HEAD --; then
            log_warn "Cambios locales detectados en $name. Realizando stash temporal..."
            git stash -q
            git pull -q --rebase
            git stash pop -q || log_warn "Conflicto de mezcla en $path. Se requiere intervención manual."
        else
            git pull -q --rebase
        fi
        cd - > /dev/null
        log_ok "$name está al día."
    fi
}

# ── 1. Sincronización de Recursos ────────────────────────────────────────────
# Throttle: no sincronizar más de una vez cada 24 horas
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
SYNC_STATE="$CACHE_DIR/assets-last-sync"

if [ -f "$SYNC_STATE" ]; then
    LAST_SYNC=$(cat "$SYNC_STATE")
    NOW=$(date +%s)
    DIFF=$(( NOW - LAST_SYNC ))
    if [ "$DIFF" -lt 86400 ]; then
        exit 0  # Sincronizado hace menos de 24h — silencio
    fi
fi

log_step "Sincronizando Recursos Gráficos"

sync_repo "git@github.com:yordycg/wallpapers.git" "git@forgejo.home:yordycg/wallpapers.git" "$HOME/workspace/assets/wallpapers" "Wallpapers"
sync_repo "git@github.com:yordycg/obsidian-notes.git" "git@forgejo.home:yordycg/obsidian-notes.git" "$HOME/workspace/assets/obsidian-notes" "Obsidian Notes"

log_ok "Sincronización de assets finalizada."
date +%s > "$SYNC_STATE"
{{- end }}