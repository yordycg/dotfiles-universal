{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_80-sync-assets.sh.tmpl
# Sincronización de Assets (Recursos Gráficos)
# Fase 4: Sincronización de Datos Externos
# =============================================================================
set -euo pipefail

{{ if not .hasGUI -}}
exit 0  # Sin entorno gráfico no necesitamos wallpapers ni Obsidian
{{- end }}

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── Funciones de Utilidad ────────────────────────────────────────────────────
sync_repo() {
    local github_url=$1
    local path=$2
    local name=$3

    if [ ! -d "$path/.git" ]; then
        log_info "Clonando repositorio de $name en $path..."
        mkdir -p "$(dirname "$path")"
        git clone -q "$github_url" "$path"
        log_ok "$name clonado exitosamente."
    else
        log_info "Actualizando $name..."
        cd "$path"
        git remote set-url origin "$github_url"

        # Limpiar cualquier pushurl configurado previamente para usar el por defecto de GitHub
        git config --unset-all remote.origin.pushurl || true
        
        if ! git diff-index --quiet HEAD --; then
            log_warn "Cambios locales detectados en $name. Realizando stash temporal..."
            git stash -q
            git pull -q --rebase
            git stash pop -q || log_warn "Conflicto de mezcla en $path. Se requiere intervención manual."
        else
            git pull -q --rebase
        fi
        cd - > /dev/null
        log_ok "$name está al día."
    fi
}

# ── 1. Sincronización de Recursos ────────────────────────────────────────────
# Throttle: no sincronizar más de una vez cada 24 horas
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
SYNC_STATE="$CACHE_DIR/assets-last-sync"

if [ -f "$SYNC_STATE" ]; then
    LAST_SYNC=$(cat "$SYNC_STATE")
    NOW=$(date +%s)
    DIFF=$(( NOW - LAST_SYNC ))
    if [ "$DIFF" -lt 86400 ]; then
        exit 0  # Sincronizado hace menos de 24h — silencio
    fi
fi

log_step "Sincronizando Recursos Gráficos"

sync_repo "git@github.com:yordycg/wallpapers.git" "$HOME/workspace/assets/wallpapers" "Wallpapers"
sync_repo "git@github.com:yordycg/obsidian-notes.git" "$HOME/workspace/assets/obsidian-notes" "Obsidian Notes"

log_ok "Sincronización de assets finalizada."
date +%s > "$SYNC_STATE"
{{- end }}