{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_80-sync-assets.sh.tmpl
# SincronizaciГіn de Assets (Recursos GrГЎficos)
# Fase 4: SincronizaciГіn de Datos Externos
# =============================================================================
set -euo pipefail

{{ if not .hasGUI -}}
exit 0  # Sin entorno grГЎfico no necesitamos wallpapers ni Obsidian
{{- end }}

{{ include "provision/lib/logging.sh" }}

# в”Ђв”Ђ Funciones de Utilidad в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
sync_repo() {
    local github_url=$1
    local path=$2
    local name=$3

    if [ ! -d "$path/.git" ]; then
        log_info "Clonando repositorio de $name en $path..."
        mkdir -p "$(dirname "$path")"
        git clone -q "$github_url" "$path"
        log_ok "$name clonado exitosamente."
    else
        log_info "Actualizando $name..."
        cd "$path"
        git remote set-url origin "$github_url"

        # Limpiar cualquier pushurl configurado previamente para usar el por defecto de GitHub
        git config --unset-all remote.origin.pushurl || true
        
        if ! git diff-index --quiet HEAD --; then
            log_warn "Cambios locales detectados en $name. Realizando stash temporal..."
            git stash -q
            git pull -q --rebase
            git stash pop -q || log_warn "Conflicto de mezcla en $path. Se requiere intervenciГіn manual."
        else
            git pull -q --rebase
        fi
        cd - > /dev/null
        log_ok "$name estГЎ al dГ­a."
    fi
}

# в”Ђв”Ђ 1. SincronizaciГіn de Recursos в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Throttle: no sincronizar mГЎs de una vez cada 24 horas
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
SYNC_STATE="$CACHE_DIR/assets-last-sync"

if [ -f "$SYNC_STATE" ]; then
    LAST_SYNC=$(cat "$SYNC_STATE")
    NOW=$(date +%s)
    DIFF=$(( NOW - LAST_SYNC ))
    if [ "$DIFF" -lt 86400 ]; then
        exit 0  # Sincronizado hace menos de 24h вЂ” silencio
    fi
fi

log_step "Sincronizando Recursos GrГЎficos"

sync_repo "git@github.com:yordycg/wallpapers.git" "$HOME/workspace/assets/wallpapers" "Wallpapers"
sync_repo "git@github.com:yordycg/obsidian-notes.git" "$HOME/workspace/assets/obsidian-notes" "Obsidian Notes"

log_ok "SincronizaciГіn de assets finalizada."
date +%s > "$SYNC_STATE"
{{- end }}