{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_after_45-setup-kde-theme.sh.tmpl
# Automatización no bloqueante del tema KDE/macOS.
# Corre después de cada apply, saltando en 1ms si ya fue exitoso en el pasado.
# =============================================================================

# Detección de entorno: Solo corre si el nodo es KDE
{{- if not (or (eq .desktopEnv "kde") (eq .desktopEnv "both")) }}
exit 0
{{- end }}

set -euo pipefail

{{ include "provision/lib/logging.sh" }}

STAMPS_DIR="${XDG_CACHE_HOME:-$HOME/.cache}/kde-macos-themes/.stamps"
STAMP_FILE="$STAMPS_DIR/global-kde-theme-success"

# 1. Verificar si ya se completó exitosamente en el pasado
if [ -f "$STAMP_FILE" ]; then
    exit 0 # Salida silenciosa y ultra rápida en applies diarios
fi

log_step "KDE Theme Auto-Installer — Iniciando configuración del tema macOS ({{ .kdeTheme }})"

# 2. Ejecutar instalador del tema
THEME_SCRIPT="{{ .chezmoi.sourceDir }}/provision/system/setup-kde-macos-theme.sh"

if [ -f "$THEME_SCRIPT" ]; then
    # Ejecutamos el setup en un subshell para capturar errores sin tumbar la ejecución principal
    if bash "$THEME_SCRIPT" "{{ .kdeTheme }}"; then
        mkdir -p "$STAMPS_DIR"
        touch "$STAMP_FILE"
        log_ok "Tema KDE macOS instalado y configurado correctamente."
    else
        log_warn "Fallo en la instalación del tema KDE macOS. Se reintentará en el próximo apply."
        log_warn "Puedes verificar logs de dependencias o conectividad e intentar de nuevo."
    fi
else
    log_err "Script de instalación no encontrado en: $THEME_SCRIPT"
fi

exit 0
{{- end }}
