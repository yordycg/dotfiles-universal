#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_before_00-provision-system.sh.tmpl
# Orquestador de Aprovisionamiento del Sistema (Sudo-Space)
# =============================================================================
# Hashes de dependencias para forzar ejecución en cambios:
# {{ include "provision/installers/fedora.sh" | sha256sum }}
# {{ include "provision/installers/arch.sh" | sha256sum }}
# {{ include "provision/installers/debian.sh" | sha256sum }}
# {{ include "provision/system/trust-homelab-ca.sh" | sha256sum }}
# {{ include "provision/system/setup-sddm-theme.sh" | sha256sum }}
# {{ include "provision/system/setup-tailscale.sh" | sha256sum }}
# {{ include "provision/system/setup-snapper.sh" | sha256sum }}
# {{ include "provision/system/setup-virtualization.sh" | sha256sum }}
# {{ include "provision/system/setup-nvidia.sh" | sha256sum }}
# {{ include "provision/system/setup-dualboot-fixes.sh" | sha256sum }}
# {{ include "provision/system/cleanup-kde.sh" | sha256sum }}
# {{ include ".chezmoidata/packages.yaml" | sha256sum }}
# {{ include "provision/system/setup-wsl-systemd.sh" | sha256sum }}

set -euo pipefail

{{ include "provision/lib/logging.sh" }}

# Exportar variables de contexto para los scripts hijos
export NODE_HAS_GUI="{{ .hasGUI }}"
export NODE_IS_SERVER="{{ .isServer }}"
export NODE_IS_WSL="{{ .isWSL }}"
export NODE_DESKTOP_ENV="{{ .desktopEnv }}"
export NODE_IS_DESKTOP="{{ .isDesktop }}"
export HOMELAB_IP_LOCAL="{{ .homelab_ip_local }}"
export HOMELAB_IP_TS="{{ .homelab_ip_ts }}"
export CHEZMOI_SOURCE_DIR="{{ .chezmoi.sourceDir }}"

PROVISION_DIR="{{ .chezmoi.sourceDir }}/provision"

# Solicitar contraseña de sudo al inicio para toda la sesión
log_step "Iniciando Aprovisionamiento del Sistema (Sudo-Space)"
log_info "Esta fase requiere permisos de administrador. Por favor introduce tu contraseña:"
sudo -v

# Mantener sudo activo en segundo plano mientras corre el script
while true; do sudo -n true; sleep 60; kill -0 "$$" || exit; done 2>/dev/null &

# 0. Habilitar Systemd en WSL si aplica
if [ "$NODE_IS_WSL" = "true" ]; then
    log_step "Configurando WSL Systemd..."
    bash "$PROVISION_DIR/system/setup-wsl-systemd.sh"
fi

# 1. Ejecutar instalación de paquetes del sistema
log_step "1/8. Instalando paquetes del sistema..."
if [ -f /etc/fedora-release ]; then
    bash "$PROVISION_DIR/installers/fedora.sh"
elif [ -f /etc/arch-release ]; then
    bash "$PROVISION_DIR/installers/arch.sh"
elif [ -f /etc/debian_version ]; then
    bash "$PROVISION_DIR/installers/debian.sh"
else
    log_warn "Distribución no soportada oficialmente para auto-instalación de paquetes."
fi

# 2. Configurar Tailscale
log_step "2/8. Configurando Tailscale VPN..."
bash "$PROVISION_DIR/system/setup-tailscale.sh"

# 3. Confianza SSL (Homelab PKI)
log_step "3/8. Configurando Confianza SSL (Homelab PKI)..."
bash "$PROVISION_DIR/system/trust-homelab-ca.sh"

# 4. Configurar Snapper para snapshots automáticos
if [ "$NODE_IS_SERVER" != "true" ] && [ "$NODE_IS_WSL" != "true" ]; then
    log_step "4/8. Configurando Snapper..."
    bash "$PROVISION_DIR/system/setup-snapper.sh"
else
    log_step "4/8. Saltando Snapper (No es native desktop/laptop)."
fi

# 5. Configurar controladores de GPU NVIDIA
if [ "$NODE_IS_SERVER" != "true" ] && [ "$NODE_IS_WSL" != "true" ]; then
    log_step "5/8. Configurando controladores NVIDIA..."
    bash "$PROVISION_DIR/system/setup-nvidia.sh"
else
    log_step "5/8. Saltando controladores NVIDIA (No es native desktop/laptop)."
fi

# 6. Configurar Virtualización
if [ "$NODE_IS_SERVER" != "true" ] && [ "$NODE_IS_WSL" != "true" ]; then
    log_step "6/8. Configurando Virtualización..."
    bash "$PROVISION_DIR/system/setup-virtualization.sh"
else
    log_step "6/8. Saltando Virtualización (No es native desktop/laptop)."
fi

# 7. Soluciones comunes de Dual-Boot (Hora y GRUB)
if [ "$NODE_IS_SERVER" != "true" ] && [ "$NODE_IS_WSL" != "true" ]; then
    log_step "7/8. Aplicando correcciones de Dual-Boot..."
    bash "$PROVISION_DIR/system/setup-dualboot-fixes.sh"
else
    log_step "7/8. Saltando correcciones de Dual-Boot (No es native desktop/laptop)."
fi

# 8. Configurar temas de sistema y limpieza KDE
if [ "$NODE_HAS_GUI" = "true" ]; then
    log_step "8/8. Configurando temas gráficos del sistema y limpiando paquetes..."
    bash "$PROVISION_DIR/system/setup-sddm-theme.sh"
    bash "$PROVISION_DIR/system/cleanup-kde.sh"

    # Configurar overrides de Flatpak para temas si aplica
    {{- if .hasGUI }}
    if command -v flatpak &>/dev/null; then
        log_info "→ Aplicando overrides sudo para Flatpak (acceso a temas GTK)..."
        sudo flatpak override --filesystem=xdg-config/gtk-3.0 || true
        sudo flatpak override --filesystem=xdg-config/gtk-4.0 || true
    fi
    {{- end }}
else
    log_step "8/8. Sistema Headless (sin GUI), saltando SDDM theme y limpieza KDE."
fi

log_ok "Aprovisionamiento del sistema completado con éxito."
