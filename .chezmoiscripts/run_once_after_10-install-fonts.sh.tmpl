{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
{{ if not .needsFonts -}}
exit 0
{{- end }}
# =============================================================================
# scripts/run_after_10-install-fonts.sh.tmpl
# Instalación de Nerd Fonts
# =============================================================================
set -euo pipefail

{{ if and (eq .chezmoi.os "linux") (hasKey . "isServer") .isServer -}}
exit 0
{{- end }}

{{ include "provision/lib/logging.sh" }}

# ── 1. Gestión de Estado (Caché Senior) ──────────────────────────────────────
CACHE_DIR="$HOME/.cache/chezmoi-scripts"
mkdir -p "$CACHE_DIR"
STATE_FILE="$CACHE_DIR/fonts-state"

# Hash del propio script para detectar cambios en la lista de fuentes
CURRENT_HASH="{{ include ".chezmoiscripts/run_once_after_10-install-fonts.sh.tmpl" | sha256sum }}"

log_step "Tipografías (Nerd Fonts)"

if [ -f "$STATE_FILE" ] && [ "$(cat "$STATE_FILE")" == "$CURRENT_HASH" ]; then
    log_ok "Fuentes JetBrains, FiraCode, Lilex y Apple SF están al día."
    exit 0
fi

# ── 2. Instalación ───────────────────────────────────────────────────────────
VERSION="3.3.0"
FONTS_DIR="${HOME}/.local/share/fonts"
declare -a fonts=(JetBrainsMono FiraCode Lilex CaskaydiaCove)

mkdir -p "$FONTS_DIR"

for font in "${fonts[@]}"; do
    if [ ! -d "$FONTS_DIR/$font" ]; then
        log_info "Descargando $font..."
        zip_file="${font}.zip"
        download_url="https://github.com/ryanoasis/nerd-fonts/releases/download/v${VERSION}/${zip_file}"
        if wget -q --show-progress "$download_url"; then
            unzip -o -q "$zip_file" -d "$FONTS_DIR/$font"
            rm "$zip_file"
        fi
    fi
done

# ── 3. Fuentes Apple SF (San Francisco) ──────────────────────────────────────
# Descargar Apple SF Pro
if [ ! -d "$FONTS_DIR/AppleSFPro" ]; then
    log_info "Descargando Apple SF Pro..."
    mkdir -p "$FONTS_DIR/AppleSFPro"
    if wget -q --show-progress -O "/tmp/AppleSFPro.zip" "https://github.com/sahibjotsaggu/San-Francisco-Pro-Fonts/archive/refs/heads/master.zip"; then
        unzip -q -o "/tmp/AppleSFPro.zip" -d "/tmp/AppleSFPro"
        find "/tmp/AppleSFPro" \( -name "*.otf" -o -name "*.ttf" \) -exec cp {} "$FONTS_DIR/AppleSFPro/" \;
        rm -rf "/tmp/AppleSFPro.zip" "/tmp/AppleSFPro"
    fi
fi

# Descargar Apple SF Mono
if [ ! -d "$FONTS_DIR/AppleSFMono" ]; then
    log_info "Descargando Apple SF Mono..."
    mkdir -p "$FONTS_DIR/AppleSFMono"
    if wget -q --show-progress -O "/tmp/AppleSFMono.zip" "https://github.com/supercomputra/SF-Mono-Font/archive/refs/heads/master.zip"; then
        unzip -q -o "/tmp/AppleSFMono.zip" -d "/tmp/AppleSFMono"
        find "/tmp/AppleSFMono" \( -name "*.otf" -o -name "*.ttf" \) -exec cp {} "$FONTS_DIR/AppleSFMono/" \;
        rm -rf "/tmp/AppleSFMono.zip" "/tmp/AppleSFMono"
    fi
fi

log_info "Actualizando caché del sistema..."
find "$FONTS_DIR" -name '*Windows Compatible*' -delete &>/dev/null || true
fc-cache -f > /dev/null

# Guardar estado exitoso
echo "$CURRENT_HASH" > "$STATE_FILE"
log_ok "Fuentes instaladas y sincronizadas."
{{- end }}