{{ if and (eq .chezmoi.os "linux") (or (eq .desktopEnv "kde") (eq .desktopEnv "both")) -}}
#!/usr/bin/env bash
# =============================================================================
# .chezmoiscripts/run_once_after_45-install-theme.sh.tmpl
# Instalación automática del tema para KDE Plasma 6 (MacSequoia) y GTK (WhiteSur)
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── 1. Instalar Tema de KDE ──────────────────────────────────────────────────
log_step "Instalando tema para KDE Plasma 6..."
THEME_REPO="https://github.com/vinceliuice/MacSequoia-kde.git"
TEMP_DIR=$(mktemp -d)

log_info "Clonando repositorio del tema KDE: $THEME_REPO..."
if git clone --depth 1 "$THEME_REPO" "$TEMP_DIR"; then
    log_info "Ejecutando instalador del tema KDE..."
    cd "$TEMP_DIR"
    if ./install.sh; then
        log_ok "Tema KDE (MacSequoia) instalado correctamente."
    else
        log_warn "Ocurrió un error al ejecutar el instalador del tema KDE."
    fi
else
    log_warn "No se pudo clonar el repositorio del tema KDE."
fi
rm -rf "$TEMP_DIR"

# ── 2. Instalar Tema GTK (para sincronización de Apps) ───────────────────────
log_step "Instalando tema GTK WhiteSur para aplicaciones..."
GTK_REPO="https://github.com/vinceliuice/WhiteSur-gtk-theme.git"
TEMP_GTK_DIR=$(mktemp -d)

log_info "Clonando repositorio del tema GTK: $GTK_REPO..."
if git clone --depth 1 "$GTK_REPO" "$TEMP_GTK_DIR"; then
    log_info "Ejecutando instalador del tema GTK..."
    cd "$TEMP_GTK_DIR"
    # El instalador de vinceliuice instala localmente en $HOME/.local/share/themes sin root
    if ./install.sh -d "$HOME/.local/share/themes"; then
        log_ok "Tema GTK (WhiteSur) instalado correctamente."
    else
        log_warn "Ocurrió un error al ejecutar el instalador del tema GTK."
    fi
else
    log_warn "No se pudo clonar el repositorio del tema GTK."
fi
rm -rf "$TEMP_GTK_DIR"

log_ok "Proceso de personalización visual finalizado."
{{- end }}
