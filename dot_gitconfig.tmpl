[user]
	name = {{ .gitName }}
	email = {{ .gitEmail }}

[core]
	editor = nvim
	pager = delta
	autocrlf = input

[delta]
	navigate = true
	line-numbers = true
	side-by-side = true
	theme = gruvbox-dark

[merge]
	conflictstyle = diff3

[diff]
	colorMoved = default

[pull]
	rebase = true

[push]
	autoSetupRemote = true

[alias]
	st = status -sb
	lg = log --oneline --graph --decorate --all
	undo = reset --soft HEAD~1
	aliases = config --get-regexp alias

[init]
	defaultBranch = main
