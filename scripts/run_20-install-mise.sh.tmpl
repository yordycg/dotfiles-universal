#!/usr/bin/env bash

# ----------------------------------------------------------------------
# Bootstrap Mise (Universal Tool Manager)
# ----------------------------------------------------------------------

set -euo pipefail

# Exportar token para evitar rate limits de GitHub
export GITHUB_TOKEN={{ .githubToken | quote }}
# Desactivar attestations de python
export MISE_PYTHON_GITHUB_ATTESTATIONS=false

MISE_BIN="$HOME/.local/bin/mise"

if [ ! -f "$MISE_BIN" ]; then
    echo "== Instalando mise..."
    curl https://mise.jdx.dev/install.sh | sh
fi

echo "== Verificando herramientas de mise..."
# Forzar la instalacion de las herramientas y runtimes (Node, Python, Lua)
"$MISE_BIN" install -y

# ----------------------------------------------------------------------
# Post-Install: Providers & CLIs
# ----------------------------------------------------------------------
echo "== Configurando providers y herramientas globales..."

# Activar Mise para que npm y pip estén disponibles en el script
eval "$("$MISE_BIN" activate bash)"

# Provider de Node.js / Global Packages
if command -v npm &>/dev/null; then
    echo "  - Verificando paquetes npm globales..."
    npm install -g neovim @google/gemini-cli @bitwarden/cli --silent
fi

# Provider de Python
if command -v pip &>/dev/null; then
    echo "  - Verificando paquetes python globales..."
    pip install pynvim --quiet
fi

echo "[OK] Mise y herramientas configuradas."
