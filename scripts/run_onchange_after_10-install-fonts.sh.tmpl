#!/usr/bin/env bash
# =============================================================================
# scripts/run_onchange_after_10-install-fonts.sh.tmpl
# Instalación de Nerd Fonts (Linux)
# Fase 1: Entorno Visual
# =============================================================================
set -euo pipefail

{{ if .isServer -}}
exit 0
{{- end }}

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

VERSION="3.3.0"
FONTS_DIR="${HOME}/.local/share/fonts"

# ── 1. Preparación ───────────────────────────────────────────────────────────
log_step "Preparando Entorno de Fuentes"

declare -a fonts=(
  JetBrainsMono
  FiraCode
  Lilex
  CaskaydiaCove
)

if [[ ! -d "$FONTS_DIR" ]]; then
  log_info "Creando directorio de fuentes en $FONTS_DIR..."
  mkdir -p "$FONTS_DIR"
fi

# ── 2. Descarga e Instalación ────────────────────────────────────────────────
log_step "Instalación de Nerd Fonts"

for font in "${fonts[@]}"; do
  if [ ! -d "$FONTS_DIR/$font" ]; then
    log_info "Instalando $font Nerd Font (v$VERSION)..."
    zip_file="${font}.zip"
    download_url="https://github.com/ryanoasis/nerd-fonts/releases/download/v${VERSION}/${zip_file}"
    
    if wget -q --show-progress "$download_url"; then
      unzip -o -q "$zip_file" -d "$FONTS_DIR/$font"
      rm "$zip_file"
      log_ok "$font instalada correctamente."
    else
      log_warn "No se pudo descargar $font. Verifica tu conexión o el enlace."
    fi
  else
    log_ok "$font ya está instalada."
  fi
done

# ── 3. Optimización y Caché ──────────────────────────────────────────────────
log_step "Finalizando Instalación"

log_info "Limpiando archivos innecesarios..."
find "$FONTS_DIR" -name '*Windows Compatible*' -delete &>/dev/null || true

log_info "Actualizando caché de fuentes (fc-cache)..."
fc-cache -f > /dev/null
log_ok "Caché de fuentes actualizada."

log_ok "¡Instalación de fuentes completada!"
