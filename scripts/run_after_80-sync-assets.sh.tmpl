{{ if eq .chezmoi.os "linux" -}}
#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_80-sync-assets.sh.tmpl
# Sincronización de Assets (Recursos Gráficos)
# Fase 4: Sincronización de Datos Externos
# =============================================================================
set -euo pipefail

{{ if and (eq .chezmoi.os "linux") (hasKey . "isServer") .isServer -}}
exit 0
{{- end }}

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── Funciones de Utilidad ────────────────────────────────────────────────────
sync_repo() {
    local github_url=$1
    local forgejo_url=$2
    local path=$3
    local name=$4

    local url=$github_url
    if ssh -o ConnectTimeout=2 -o BatchMode=yes forgejo.home exit &>/dev/null; then
        log_info "Servidor Forgejo detectado. Usando mirror local para $name."
        url=$forgejo_url
    else
        log_info "Servidor Forgejo no alcanzable. Usando GitHub para $name."
    fi

    if [ ! -d "$path/.git" ]; then
        log_info "Clonando repositorio de $name en $path..."
        mkdir -p "$(dirname "$path")"
        git clone -q "$url" "$path"
        log_ok "$name clonado exitosamente."
    else
        log_info "Actualizando $name..."
        cd "$path"
        # Cambiar el remote si es necesario para reflejar el estado actual de la red
        git remote set-url origin "$url"
        
        if ! git diff-index --quiet HEAD --; then
            log_warn "Cambios locales detectados en $name. Realizando stash temporal..."
            git stash -q
            git pull -q --rebase
            git stash pop -q || log_warn "Conflicto de mezcla en $path. Se requiere intervención manual."
        else
            git pull -q --rebase
        fi
        cd - > /dev/null
        log_ok "$name está al día."
    fi
}

# ── 1. Sincronización de Recursos ────────────────────────────────────────────
log_step "Sincronizando Recursos Gráficos"

sync_repo "git@github.com:yordycg/wallpapers.git" "git@forgejo.home:yordycg/wallpapers.git" "$HOME/workspace/assets/wallpapers" "Wallpapers"
sync_repo "git@github.com:yordycg/obsidian-notes.git" "git@forgejo.home:yordycg/obsidian-notes.git" "$HOME/workspace/assets/obsidian-notes" "Obsidian Notes"

log_ok "Sincronización de assets finalizada."
{{- end }}
