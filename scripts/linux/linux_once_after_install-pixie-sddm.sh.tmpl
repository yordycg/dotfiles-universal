#!/usr/bin/env bash
# {{ if eq .chezmoi.os "linux" }}
# {{ if eq .chezmoi.osRelease.id "fedora" }}
# =============================================================================
# scripts/run_once_after_install-pixie-sddm.sh.tmpl
# Instalación y configuración del tema Pixie para SDDM
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

log_step "Configuración de Pixie SDDM"

THEME_DIR="/usr/share/sddm/themes/pixie"
REPO_URL="https://github.com/xCaptaiN09/pixie-sddm.git"

# ── 1. Instalación del Tema ──────────────────────────────────────────────────
if [ ! -f "$THEME_DIR/main.qml" ]; then
    log_info "Instalando pixie-sddm en $THEME_DIR..."
    TMP_DIR=$(mktemp -d)
    
    if git clone --depth 1 "$REPO_URL" "$TMP_DIR"; then
        # Normalizar nombres de archivos (algunos sistemas buscan main.qml en minúsculas)
        if [ -f "$TMP_DIR/Main.qml" ]; then
            mv "$TMP_DIR/Main.qml" "$TMP_DIR/main.qml"
            sed -i 's/MainScript=Main.qml/MainScript=main.qml/' "$TMP_DIR/metadata.desktop"
        fi

        if [ -f "$TMP_DIR/main.qml" ]; then
            sudo mkdir -p "$THEME_DIR"
            sudo cp -ra "$TMP_DIR"/. "$THEME_DIR/"
            
            # Asegurar permisos (crucial para que el usuario 'sddm' pueda leerlo)
            log_info "Asegurando permisos correctos en $THEME_DIR..."
            sudo chown -R root:root "$THEME_DIR"
            sudo find "$THEME_DIR" -type d -exec chmod 755 {} +
            sudo find "$THEME_DIR" -type f -exec chmod 644 {} +
            sudo chmod +x "$THEME_DIR/install.sh" 2>/dev/null || true
            
            log_ok "Archivos del tema copiados y permisos configurados."
        else
            log_err "El repositorio clonado no contiene main.qml. Abortando."
        fi
        rm -rf "$TMP_DIR"
    else
        log_err "No se pudo clonar el repositorio del tema."
    fi
else
    log_ok "El tema pixie-sddm ya está instalado y validado."
fi

# ── 2. Configuración de SDDM ─────────────────────────────────────────────────
SDDM_CONF_DIR="/etc/sddm.conf.d"
CONF_FILE="$SDDM_CONF_DIR/zz-pixie.conf"
OLD_CONF="$SDDM_CONF_DIR/pixie.conf"

log_info "Asegurando directorio de configuración $SDDM_CONF_DIR..."
sudo mkdir -p "$SDDM_CONF_DIR"

if [ -f "$OLD_CONF" ]; then
    log_info "Limpiando configuración antigua..."
    sudo rm -f "$OLD_CONF"
fi

log_info "Configurando SDDM para usar el tema pixie..."
sudo tee "$CONF_FILE" > /dev/null <<EOF
[Theme]
Current=pixie
EOF

log_ok "Configuración de SDDM aplicada en $CONF_FILE."

# ── 3. Validación de Seguridad ───────────────────────────────────────────────
log_warn "⚠️  IMPORTANTE: ¡PRUEBA EL TEMA ANTES DE REINICIAR! ⚠️"
echo -e "${RESET}Ejecuta el siguiente comando para probar en VENTANA (no bloquea):"
echo -e "\n    ${BOLD}sddm-greeter-qt6 --test-mode --theme $THEME_DIR --qwindowgeometry 800x600${RESET}\n"
echo -e "${RESET}Si ves errores de archivos no encontrados, asegúrate de que el directorio"
echo -e "$THEME_DIR contiene el archivo ${BOLD}theme.conf${RESET} o ${BOLD}Main.qml${RESET}."
echo -e "Si el comando falla, borra la configuración: ${RED}sudo rm $CONF_FILE${RESET}"

# {{ end }}
# {{ end }}
