#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_95-trust-homelab-ca.sh.tmpl
# Automatiza la confianza en la CA interna de Caddy (Nodo 1)
# =============================================================================

{{ if not (or .isLaptop .isDesktop) -}}
exit 0
{{- end }}

set -euo pipefail

# Estándares de color
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
RESET='\033[0m'

log_info() { echo -e "${CYAN}[INFO]${RESET} $1"; }
log_ok() { echo -e "${GREEN}[ OK ]${RESET} $1"; }
log_warn() { echo -e "${YELLOW}[WARN]${RESET} $1"; }
log_err() { echo -e "${RED}[ERR ]${RESET} $1"; }

DOMAIN="vault.home"
CERT_NAME="homelab-caddy-ca.crt"
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

log_info "Iniciando proceso de confianza SSL para ${DOMAIN}..."

# 1. Verificar si el dominio es alcanzable
if ! ping -c 1 -W 1 "$DOMAIN" &>/dev/null; then
    log_warn "${DOMAIN} no es alcanzable. Saltando."
    exit 0
fi

# 2. Intentar obtener Root CA (Varios métodos)
# Método A: Endpoint de Caddy (Network-only)
log_info "Intentando obtener Root CA vía HTTP..."
curl -k -s "https://${DOMAIN}/pki/ca/local" -o "$TEMP_DIR/root.crt" || true

# Método B: SSH al servidor (Si el endpoint está bloqueado)
if [ ! -s "$TEMP_DIR/root.crt" ]; then
    log_info "Endpoint HTTP vacío. Intentando obtener Root CA vía SSH desde Nodo 1..."
    SERVER_IP=$(getent hosts "$DOMAIN" | awk '{print $1}')
    REMOTE_PATH="/home/yordycg/.local/share/containers/storage/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/root.crt"
    ssh -o BatchMode=yes -o ConnectTimeout=2 "yordycg@${SERVER_IP}" "cat ${REMOTE_PATH}" > "$TEMP_DIR/root.crt" 2>/dev/null || true
fi

# Método C: Archivos locales (Fallback manual)
if [ ! -s "$TEMP_DIR/root.crt" ] && [ -f "$HOME/root.crt" ]; then
    log_info "Usando root.crt encontrado en el HOME."
    cp "$HOME/root.crt" "$TEMP_DIR/root.crt"
fi

# 3. Intentar obtener Intermediate CA
log_info "Obteniendo Intermediate CA..."
# Intentar extracción del handshake
openssl s_client -showcerts -connect "${DOMAIN}:443" </dev/null 2>/dev/null | \
    awk -v dir="$TEMP_DIR" '/BEGIN CERTIFICATE/,/END CERTIFICATE/{ if(/BEGIN CERTIFICATE/){a++}; out=dir"/cert"a".crt"; print > out }'

if [ -f "$TEMP_DIR/cert2.crt" ]; then
    mv "$TEMP_DIR/cert2.crt" "$TEMP_DIR/intermediate.crt"
else
    # Fallback vía SSH
    SERVER_IP=$(getent hosts "$DOMAIN" | awk '{print $1}')
    REMOTE_PATH_INT="/home/yordycg/.local/share/containers/storage/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/intermediate.crt"
    ssh -o BatchMode=yes -o ConnectTimeout=2 "yordycg@${SERVER_IP}" "cat ${REMOTE_PATH_INT}" > "$TEMP_DIR/intermediate.crt" 2>/dev/null || true
fi

# 4. Construir el Bundle Maestro
if [ -s "$TEMP_DIR/root.crt" ] && [ -s "$TEMP_DIR/intermediate.crt" ]; then
    log_info "Generando bundle completo (Root + Intermediate)..."
    cat "$TEMP_DIR/root.crt" "$TEMP_DIR/intermediate.crt" > "$TEMP_DIR/$CERT_NAME"
elif [ -s "$TEMP_DIR/root.crt" ]; then
    log_warn "Solo se obtuvo el Root CA. El bundle podría estar incompleto para Node.js."
    cp "$TEMP_DIR/root.crt" "$TEMP_DIR/$CERT_NAME"
else
    log_err "No se pudo obtener el Root CA por ningún medio. Abortando."
    exit 1
fi

# 5. Instalar en el sistema
if [ -f /etc/fedora-release ]; then
    TRUST_STORE="/etc/pki/ca-trust/source/anchors/${CERT_NAME}"
    UPDATE_CMD="sudo update-ca-trust"
elif [ -f /etc/debian_version ]; then
    TRUST_STORE="/usr/local/share/ca-certificates/${CERT_NAME}"
    UPDATE_CMD="sudo update-ca-certificates"
else
    log_err "Distribución no soportada."
    exit 1
fi

if [ -f "$TRUST_STORE" ] && diff -q "$TEMP_DIR/$CERT_NAME" "$TRUST_STORE" &>/dev/null; then
    log_ok "La cadena de confianza ya está actualizada."
else
    log_info "Instalando bundle en el almacén del sistema..."
    sudo cp "$TEMP_DIR/$CERT_NAME" "$TRUST_STORE"
    $UPDATE_CMD
    log_ok "Sistema actualizado con la nueva CA."
fi
