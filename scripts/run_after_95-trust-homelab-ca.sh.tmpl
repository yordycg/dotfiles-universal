#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_95-trust-homelab-ca.sh.tmpl
# Confianza SSL e Infraestructura PKI
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

DOMAIN="vault.home"
CERT_NAME="homelab-caddy-ca.crt"
TEMP_DIR=$(mktemp -d)
trap 'rm -rf "$TEMP_DIR"' EXIT

log_step "Confianza SSL (Homelab PKI)"

# ── 1. Obtención de Certificado Raíz ─────────────────────────────────────────

# RUTA LOCAL (Si estamos en el servidor, el archivo está aquí)
LOCAL_CA_PATH="/home/yordycg/.local/share/containers/storage/volumes/reverse-proxy_caddy_data/_data/caddy/pki/authorities/local/root.crt"

if [ -s "$LOCAL_CA_PATH" ]; then
    log_info "Servidor detectado: Copiando certificado raíz localmente..."
    cp "$LOCAL_CA_PATH" "$TEMP_DIR/root.crt"
else
    # FLUJO CLIENTE (Laptop/Desktop): Descargar vía Red
    if ping -c 1 -W 1 "$DOMAIN" &>/dev/null; then
        log_info "Cliente detectado: Descargando certificado desde ${DOMAIN}..."
        curl -k -s "https://${DOMAIN}/pki/ca/local" -o "$TEMP_DIR/root.crt" || true
    fi
fi

# ── 2. Instalación en el Sistema ─────────────────────────────────────────────
if [ ! -s "$TEMP_DIR/root.crt" ]; then
    log_warn "No se pudo obtener el certificado raíz. Saltando confianza SSL."
    exit 0
fi

# Detectar Distro y Store
if [ -f /etc/debian_version ]; then
    TRUST_STORE="/usr/local/share/ca-certificates/${CERT_NAME}"
    UPDATE_CMD="sudo update-ca-certificates"
elif [ -f /etc/fedora-release ]; then
    TRUST_STORE="/etc/pki/ca-trust/source/anchors/${CERT_NAME}"
    UPDATE_CMD="sudo update-ca-trust"
else
    log_err "SO no soportado."
fi

# Aplicar solo si hay cambios
if [ -f "$TRUST_STORE" ] && diff -q "$TEMP_DIR/root.crt" "$TRUST_STORE" &>/dev/null; then
    log_ok "Cadena de confianza sincronizada."
else
    log_info "Instalando nueva CA en el sistema..."
    sudo cp "$TEMP_DIR/root.crt" "$TRUST_STORE"
    $UPDATE_CMD > /dev/null
    log_ok "Sistema actualizado con éxito."
fi
