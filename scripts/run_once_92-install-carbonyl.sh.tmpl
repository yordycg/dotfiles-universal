#!/usr/bin/env bash
# =============================================================================
# INSTALACIÓN DE CARBONYL (Navegador Chromium en Terminal)
# =============================================================================

set -euo pipefail

BIN_DIR="$HOME/.local/bin"
DEST="$BIN_DIR/carbonyl"

if command -v carbonyl &> /dev/null; then
    echo "Carbonyl ya está instalado. Omitiendo."
    exit 0
fi

echo "Instalando Carbonyl en $DEST..."
mkdir -p "$BIN_DIR"

# Detectar arquitectura
ARCH=$(uname -m)
case "$ARCH" in
    x86_64)  ARCH_URL="https://github.com/fathyb/carbonyl/releases/latest/download/carbonyl.linux-amd64.docker.tar.gz" ;;
    aarch64) ARCH_URL="https://github.com/fathyb/carbonyl/releases/latest/download/carbonyl.linux-arm64.docker.tar.gz" ;;
    *) echo "Arquitectura $ARCH no soportada para Carbonyl."; exit 0 ;;
esac

# Carbonyl es curioso: la forma más estable es usar el binario de su imagen docker o el standalone
# Bajaremos el binario standalone si es posible, o usaremos npm como fallback
if command -v npm &> /dev/null; then
    echo "Instalando via NPM para asegurar compatibilidad..."
    npm install -g carbonyl --prefix "$HOME/.local"
else
    echo "NPM no encontrado. Intentando descarga directa..."
    # (Este es un ejemplo simplificado, Carbonyl suele requerir node o docker)
    # Por ahora usaremos la recomendación oficial de npm para un entorno Senior con Mise
    echo "Por favor, instala carbonyl ejecutando: mise x node@latest -- npm install -g carbonyl"
fi
