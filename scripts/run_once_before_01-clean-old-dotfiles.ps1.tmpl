{{- if eq .chezmoi.os "windows" -}}
$legacyLinks = @(
    "$env:USERPROFILE\.gitconfig",
    "$env:USERPROFILE\.gitconfig-ipvg",
    "$env:USERPROFILE\.gitconfig-personal",
    "$env:USERPROFILE\.gitconfig-work",
    "$env:USERPROFILE\.config\starship.toml",
    "$env:USERPROFILE\.config\powershell\user_profile.ps1",
    "$env:USERPROFILE\.config\fastfetch",
    "$env:LOCALAPPDATA\Packages\Microsoft.WindowsTerminal_8wekyb3d8bbwe\LocalState\settings.json",
    "$env:USERPROFILE\.wslconfig"
)

Write-Host "==> Limpiando symlinks antiguos de dotfiles-2024..." -ForegroundColor Cyan

foreach ($link in $legacyLinks) {
    if (Test-Path $link) {
        $item = Get-Item $link
        if ($item.Attributes -match "ReparsePoint") {
            Write-Host "  Eliminando symlink: $link" -ForegroundColor Yellow
            Remove-Item $link -Force
        } else {
            Write-Host "  Saltando (no es symlink): $link" -ForegroundColor Gray
        }
    }
}
{{- end -}}
