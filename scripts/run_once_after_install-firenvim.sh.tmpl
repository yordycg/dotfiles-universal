#!/usr/bin/env bash
# =============================================================================
# scripts/run_once_after_install-firenvim.sh.tmpl
# Instala el native manifest de Firenvim para Firefox
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
BOLD='\033[1m'
CYAN='\033[0;36m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }

FIRENVIM_MANIFEST="$HOME/.mozilla/native-messaging-hosts/firenvim.json"

log_step "Firenvim Native Manifest"

if [[ -f "$FIRENVIM_MANIFEST" ]]; then
  log_ok "Native manifest ya existe, saltando..."
  exit 0
fi

log_info "Instalando native manifest via Neovim..."

# Asegurar que nvim esté disponible y los plugins cargados
export NVIM_APPNAME="LazyVim"

# Instalamos Firenvim (esto asume que lazy.nvim ya está configurado)
log_info "Sincronizando plugins..."
nvim --headless "+Lazy! sync" +qa 2>/dev/null || true

log_info "Generando manifest de Firenvim..."
# Forzar la carga del plugin antes de llamar a la función
nvim --headless \
    -c "set runtimepath+=~/.local/share/LazyVim/lazy/firenvim" \
    -c "call firenvim#install(0)" \
    -c "qa"

if [[ -f "$FIRENVIM_MANIFEST" ]]; then
    log_ok "Native manifest instalado exitosamente en $FIRENVIM_MANIFEST"
else
    log_warn "No se pudo generar el manifest automáticamente."
fi
