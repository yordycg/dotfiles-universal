#!/usr/bin/env bash

# scaffold-project.sh
# Descripción: Crea la estructura estándar de un nuevo proyecto en la subcarpeta adecuada.

set -e 

GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Validar argumentos
PROJECT_NAME="$1"
CATEGORY="${2:-personal}"
LANGUAGE="${3:-generic}"

if [ -z "$PROJECT_NAME" ]; then
    echo -e "${YELLOW}Uso: just project-new <nombre_del_proyecto> [categoria] [lenguaje]${NC}"
    echo -e "Categorías: personal, work, ivpg, assets"
    echo -e "Lenguajes:  python, node, go, generic"
    exit 1
fi

TARGET_DIR="$HOME/workspace/$CATEGORY/$PROJECT_NAME"

# Verificar si el directorio ya existe
if [ -d "$TARGET_DIR" ]; then
    echo -e "Error: El proyecto ya existe en $TARGET_DIR"
    exit 1
fi

# Asegurar que la carpeta de la categoría existe
mkdir -p "$HOME/workspace/$CATEGORY"

echo -e "${BLUE}Creando proyecto $PROJECT_NAME ($LANGUAGE) en [$CATEGORY]...${NC}"

# Obtener la ruta de las plantillas
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TEMPLATE_DIR="$SCRIPT_DIR/templates/project-base"

# Crear y copiar estructura base
mkdir -p "$TARGET_DIR"
cp -r "$TEMPLATE_DIR/"* "$TARGET_DIR/"
cp "$TEMPLATE_DIR/.editorconfig" "$TARGET_DIR/"
cp "$TEMPLATE_DIR/.gitignore" "$TARGET_DIR/"
cp "$TEMPLATE_DIR/.env.example" "$TARGET_DIR/"
cp "$TEMPLATE_DIR/.envrc" "$TARGET_DIR/"
cp -r "$TEMPLATE_DIR/.forgejo" "$TARGET_DIR/"

# ── Personalización por Lenguaje ──────────────────────────────────────────────
cd "$TARGET_DIR"

case "$LANGUAGE" in
    python)
        sed -i 's/# layout python python3/layout python python3/' .envrc
        sed -i 's/FROM alpine:latest/FROM python:3.12-slim/' Dockerfile
        echo "requirements.txt" >> .gitignore
        touch requirements.txt
        ;;
    node)
        sed -i 's/# layout node/layout node/' .envrc
        sed -i 's/FROM alpine:latest/FROM node:22-alpine/' Dockerfile
        echo "node_modules/" >> .gitignore
        ;;
    go)
        sed -i 's/# layout go/layout go/' .envrc
        sed -i 's/FROM alpine:latest/FROM golang:1.22-alpine/' Dockerfile
        ;;
esac

# Inicializar Git
git init > /dev/null
git add .
git commit -m "chore: initial project scaffolding ($LANGUAGE)" > /dev/null

# Autorizar direnv automáticamente
if command -v direnv &>/dev/null; then
    direnv allow .
fi

# ── Integración con Forgejo ──────────────────────────────────────────────────
FORGEJO_TOKEN="{{ .forgejoToken }}"
FORGEJO_URL="http://forgejo.home:3080/api/v1"

if [ -n "$FORGEJO_TOKEN" ] && curl -s -o /dev/null -w "%{http_code}" --connect-timeout 2 "$FORGEJO_URL/user" -H "Authorization: token $FORGEJO_TOKEN" | grep -q "200"; then
    echo -e "${BLUE}Creando repositorio en Forgejo: $PROJECT_NAME...${NC}"
    
    RESPONSE=$(curl -s -X POST "$FORGEJO_URL/user/repos" \
        -H "accept: application/json" \
        -H "Authorization: token $FORGEJO_TOKEN" \
        -H "Content-Type: application/json" \
        -d "{
            \"name\": \"$PROJECT_NAME\",
            \"private\": true
        }")

    if echo "$RESPONSE" | jq -e '.name' >/dev/null; then
        git remote add origin "git@forgejo.home:yordycg/$PROJECT_NAME.git"
        echo -e "${GREEN}¡Repositorio creado en Forgejo y vinculado!${NC}"
    else
        echo -e "${YELLOW}Aviso: No se pudo crear el repo en Forgejo (¿Ya existe?).${NC}"
    fi
fi

echo -e "${GREEN}¡Proyecto creado exitosamente en $TARGET_DIR!${NC}"
echo ""
eza --tree --icons --level=2 "$TARGET_DIR"
echo ""
echo -e "Siguiente paso: cd $TARGET_DIR && just up"
