#!/usr/bin/env bash
# scripts/run_onchange_setup-distrobox.sh.tmpl
# hash: {{ include "scripts/distrobox/boxes.yaml" | sha256sum }}

# Este script se ejecuta automáticamente cuando boxes.yaml cambia.
# Requiere yq, distrobox y podman instalados en el host.

if ! command -v distrobox &>/dev/null; then
    echo "Distrobox no encontrado. Saltando configuración de contenedores."
    exit 0
fi

# Leer el archivo boxes.yaml y crear/actualizar cada box
# Usamos un bucle simple para procesar la lista
BOXES_FILE="/home/yordycg/.local/share/chezmoi/scripts/distrobox/boxes.yaml"

echo "== Sincronizando contenedores Distrobox..."

# Nota: Esto es un ejemplo simplificado de cómo podrías automatizarlo.
# Por ahora, crearemos las boxes manualmente si no existen.

for name in $(yq e '.boxes[].name' "$BOXES_FILE"); do
    image=$(yq e ".boxes[] | select(.name == \"$name\") | .image" "$BOXES_FILE")
    
    if ! distrobox list | grep -q "$name"; then
        echo "   -> Creando box: $name ($image)"
        distrobox create --name "$name" --image "$image" --yes
    else
        echo "   -> Box $name ya existe."
    fi
done

echo "[OK] Sincronización de Distrobox finalizada."
