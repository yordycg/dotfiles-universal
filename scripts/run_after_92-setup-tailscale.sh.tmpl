#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_92-setup-tailscale.sh.tmpl
# Automatización de Tailscale (VPN Mesh)
# =============================================================================
{{ if eq .chezmoi.os "linux" -}}
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
CYAN='\033[0;36m'
RESET='\033[0m'

log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }

if ! command -v tailscale &>/dev/null; then
    exit 0
fi

log_info "Verificando estado de Tailscale..."

# 1. Asegurar que el servicio esté corriendo
if systemctl list-unit-files tailscaled.service &>/dev/null; then
    if ! systemctl is-active --quiet tailscaled; then
        log_info "Activando servicio tailscaled..."
        sudo systemctl enable --now tailscaled
    fi
fi

# 2. Verificar autenticación
if tailscale status &>/dev/null; then
    log_ok "Tailscale está activo y autenticado."
else
    log_warn "Tailscale no está autenticado. Iniciando proceso de unión..."
    # Ejecutamos 'up'. Si es la primera vez, mostrará la URL de login.
    # Usamos --accept-dns=true para integrar con nuestro AdGuard.
    sudo tailscale up --accept-dns=true
fi
{{ end -}}
