#!/usr/bin/env bash
# =============================================================================
# scripts/run_once_after_90-setup-ssh.sh.tmpl
# Configuración de Identidad SSH y Vinculación con GitHub
# Fase 4: Seguridad e Identidad
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# Variables de Identidad
HOSTNAME="{{ .hostname }}"
KEY_COMMENT="Key for ${HOSTNAME} (managed by chezmoi)"
KEY_TITLE="SSH Key: ${HOSTNAME}"

# Rutas
SSH_DIR="$HOME/.ssh"
SSH_KEY_NAME="id_ed25519"
SSH_KEY_PATH="$SSH_DIR/$SSH_KEY_NAME"
SSH_KEY_PUB_PATH="${SSH_KEY_PATH}.pub"
SSH_CONFIG_FILE="$SSH_DIR/config"

# ── 1. Verificaciones Previas ────────────────────────────────────────────────
log_step "Validando Dependencias"

for cmd in gh ssh-keygen jq; do
    if ! command -v "$cmd" &>/dev/null; then
        log_err "'$cmd' no encontrado. Asegúrate de que los paquetes core se instalaron correctamente."
    fi
done
log_ok "Dependencias verificadas."

# ── 2. Autenticación con GitHub ──────────────────────────────────────────────
log_step "Autenticación de GitHub CLI"

if ! gh auth status &>/dev/null; then
    if [ -n "{{ .githubToken }}" ]; then
        log_info "No autenticado. Usando GITHUB_TOKEN proporcionado por Chezmoi..."
        echo "{{ .githubToken }}" | gh auth login --with-token
        gh auth setup-git
        log_ok "Autenticación automática completada."
    else
        log_warn "No autenticado y no se encontró token. Iniciando flujo interactivo..."
        gh auth login --hostname github.com --scopes "admin:public_key,admin:ssh_signing_key" --web || log_err "Falló la autenticación."
        gh auth setup-git
    fi
else
    # Asegurar que Git esté configurado incluso si ya estábamos logueados
    gh auth setup-git
    log_ok "Autenticación activa en GitHub."
fi

# ── 3. Generación de Llaves ──────────────────────────────────────────────────
log_step "Gestión de Llaves SSH"

mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"

if [[ -f "$SSH_KEY_PATH" && -f "$SSH_KEY_PUB_PATH" ]]; then
    log_ok "La llave SSH ya existe. Reutilizando."
else
    log_info "Generando nueva llave ed25519 para ${HOSTNAME}..."
    ssh-keygen -t ed25519 -f "$SSH_KEY_PATH" -N "" -C "$KEY_COMMENT" -q
    chmod 600 "$SSH_KEY_PATH"
    chmod 644 "$SSH_KEY_PUB_PATH"
    log_ok "Llave generada exitosamente en $SSH_KEY_PATH"
fi

# ── 4. Sincronización con GitHub ─────────────────────────────────────────────
log_step "Sincronización de Llave Pública"

EXISTING_KEY_ID=$(gh ssh-key list 2>/dev/null | grep -F "$KEY_TITLE" | awk '{print $1}' || true)

if [[ -n "$EXISTING_KEY_ID" ]]; then
    log_ok "Esta llave ya está registrada en GitHub (ID: $EXISTING_KEY_ID)."
else
    log_info "Subiendo nueva llave a GitHub con título: $KEY_TITLE"
    if gh ssh-key add "$SSH_KEY_PUB_PATH" --title "$KEY_TITLE"; then
        log_ok "Llave pública vinculada a GitHub correctamente."
    else
        log_warn "No se pudo subir la llave. Es posible que ya exista con otro nombre."
    fi
fi

# ── 5. Configuración de Acceso ───────────────────────────────────────────────
log_step "Configuración de SSH Config"

if [[ ! -f "$SSH_CONFIG_FILE" ]] || ! grep -q "Host github.com" "$SSH_CONFIG_FILE"; then
    log_info "Añadiendo configuración base para GitHub en $SSH_CONFIG_FILE..."
    cat >> "$SSH_CONFIG_FILE" <<EOF

Host github.com
    HostName github.com
    User git
    IdentityFile ${SSH_KEY_PATH}
    IdentitiesOnly yes
EOF
    chmod 600 "$SSH_CONFIG_FILE"
    log_ok "Configuración de SSH actualizada."
else
    log_ok "La configuración de GitHub ya existe en $SSH_CONFIG_FILE."
fi

# ── 6. Verificación Final ────────────────────────────────────────────────────
log_step "Verificación de Conexión"

log_info "Probando conexión SSH con git@github.com..."
if ssh -T git@github.com -o StrictHostKeyChecking=accept-new -o ConnectTimeout=5 2>&1 | grep -q "successfully authenticated"; then
    log_ok "Conexión verificada: El equipo está listo para operar con SSH."
else
    log_warn "La conexión falló o requiere intervención, pero la identidad está configurada."
fi
