{{- if eq .chezmoi.os "windows" -}}
Write-Host "==> Iniciando Bootstrap de Windows (Senior Workflow)..." -ForegroundColor Cyan

# 1. Asegurar Scoop
if (-not (Get-Command scoop -ErrorAction SilentlyContinue)) {
    Write-Host "  Instalando Scoop..." -ForegroundColor Yellow
    Invoke-RestMethod -Uri https://get.scoop.sh | Invoke-Expression
}

# 2. Paquetes críticos via Winget (Idempotente)
$wingetPkgs = @(
    "Git.Git",
    "Microsoft.PowerShell",
    "Starship.Starship",
    "Microsoft.WindowsTerminal"
)

foreach ($pkg in $wingetPkgs) {
    if (-not (winget list --id $pkg -e --source winget 2>$null)) {
        Write-Host "  Instalando $pkg via Winget..." -ForegroundColor Yellow
        winget install --id $pkg -e --source winget --silent --accept-package-agreements --accept-source-agreements
    }
}

# 3. Paquetes Dev via Scoop
$scoopApps = @(
    "neovim", "fzf", "ripgrep", "fd", "just", "zoxide", "lazygit", 
    "JetBrainsMono-NF-Mono", "FiraCode-NF-Mono", "Lilex-NF"
)

Write-Host "  Actualizando Scoop e instalando apps..." -ForegroundColor Yellow
scoop update
foreach ($app in $scoopApps) {
    if (-not (scoop list $app 2>$null)) {
        scoop install $app
    }
}

# 4. WSL Setup: Instalar Ubuntu-24.04 si no existe
$wslDistros = wsl --list --quiet
if ($wslDistros -notmatch "Ubuntu-24.04") {
    Write-Host "  Instalando Ubuntu-24.04 en WSL..." -ForegroundColor Yellow
    wsl --install -d Ubuntu-24.04 --no-launch
} else {
    Write-Host "  Ubuntu-24.04 ya está instalado en WSL." -ForegroundColor Green
}

Write-Host "==> Bootstrap de Windows completado." -ForegroundColor Green
{{- end -}}
