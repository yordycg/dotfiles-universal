# Direnv - Carga automática de entorno
# -----------------------------------------------------------------------------
# Este archivo carga variables de entorno y activa entornos virtuales al entrar.
# -----------------------------------------------------------------------------

# Carga .env automáticamente si existe
watch_file .env
if [ -f .env ]; then
  dotenv
fi

# -- Configuración por Lenguaje (Descomentar según corresponda) --

# Python: Crea y activa un .venv automáticamente
# export VIRTUAL_ENV=.venv
# layout python python3

# Node: Agrega ./node_modules/.bin al PATH
# layout node

# Go: Configura el GOPATH local
# layout go
