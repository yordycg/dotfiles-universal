#!/usr/bin/env bash
# =============================================================================
# scripts/run_after_99-change-shell.sh.tmpl
# Configuración del Shell Predeterminado (ZSH)
# Fase 99: Finalización del Despliegue
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── 1. Verificación del Shell Actual ─────────────────────────────────────────
log_step "Gestión del Shell del Usuario"

DESIRED_SHELL=$(command -v zsh)
CURRENT_SHELL=$(getent passwd "$USER" | cut -d: -f7)

if [ "$CURRENT_SHELL" = "$DESIRED_SHELL" ]; then
    log_ok "El shell predeterminado ya es ZSH ($CURRENT_SHELL)."
else
    log_info "Cambiando shell predeterminado de $CURRENT_SHELL a $DESIRED_SHELL..."
    log_info "Se requiere elevación de privilegios (sudo) para cambiar el shell del sistema."
    
    if sudo chsh -s "$DESIRED_SHELL" "$USER"; then
        log_ok "Shell cambiado exitosamente. Los cambios surtirán efecto en el próximo inicio de sesión."
    else
        log_warn "No se pudo cambiar el shell automáticamente vía chsh."
    fi
fi

log_ok "Configuración final completada."
