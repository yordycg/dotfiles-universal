#!/usr/bin/env bash
# =============================================================================
# scripts/run_onchange_before_00-install-packages.sh.tmpl
# Bootstrap de Secretos y Paquetes del Sistema
# Fase 0: Preparación del entorno base
#
# Dependencias (Caché):
# packages.yaml hash: {{ include "scripts/packages/packages.yaml" | sha256sum }}
# fedora.sh hash: {{ include "scripts/packages/installers/fedora.sh" | sha256sum }}
# debian.sh hash: {{ include "scripts/packages/installers/debian.sh" | sha256sum }}
# arch.sh hash: {{ include "scripts/packages/installers/arch.sh" | sha256sum }}
# =============================================================================
set -euo pipefail

# Colores Homelab-Style
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── 1. Bootstrap de Secretos (Age) ───────────────────────────────────────────
log_step "Configurando Secretos (Age)"

AGE_KEY_FILE="$HOME/.config/chezmoi/key.txt"

if [ -z "${CHEZMOI_AGE_KEY:-}" ]; then
    log_info "No se detectó CHEZMOI_AGE_KEY en el entorno. Saltando bootstrap de secrets."
else
    if [ ! -f "$AGE_KEY_FILE" ]; then
        log_info "Configurando llave age desde variable de entorno..."
        mkdir -p "$(dirname "$AGE_KEY_FILE")"
        echo "$CHEZMOI_AGE_KEY" > "$AGE_KEY_FILE"
        chmod 600 "$AGE_KEY_FILE"
        log_ok "Llave age configurada exitosamente."
    else
        log_ok "El archivo de llave age ya existe."
    fi
fi

# ── 2. Instalación de Paquetes del Sistema ───────────────────────────────────
log_step "Instalación de Paquetes Base"

log_info "Detectando sistema operativo..."

if [ -f /etc/fedora-release ]; then
    log_info "Sistema detectado: Fedora"
    bash "{{ .chezmoi.sourceDir }}/scripts/packages/installers/fedora.sh"
elif [ -f /etc/arch-release ]; then
    log_info "Sistema detectado: Arch Linux"
    bash "{{ .chezmoi.sourceDir }}/scripts/packages/installers/arch.sh"
elif [ -f /etc/debian_version ]; then
    log_info "Sistema detectado: Debian/Ubuntu"
    bash "{{ .chezmoi.sourceDir }}/scripts/packages/installers/debian.sh"
else
    log_warn "Sistema operativo no soportado para instalación automática."
fi

log_ok "Instalación de paquetes del sistema completada."
