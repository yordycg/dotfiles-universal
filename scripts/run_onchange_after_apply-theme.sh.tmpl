#!/usr/bin/env bash
# =============================================================================
# scripts/run_onchange_after_apply-theme.sh.tmpl
# Automatización de Temas (GTK, Kvantum, Qt) - Senior Logic
# =============================================================================
{{ if .isServer -}}
# El servidor es headless, no aplicamos temas graficos
exit 0
{{- end }}

set -euo pipefail

# -- Trigger de Cambio --
# Este script se ejecutara solo si cambia el config de flavours
# Hash: {{ include "dot_config/flavours/config.toml.tmpl" | sha256sum }}

# Colores Homelab-Style
GREEN='\033[0;32m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }

# ── 1. Preparación de Directorios ───────────────────────────────────────────
log_step "Configurando Entorno Gráfico (Themes)"

mkdir -p "$HOME/.local/share/themes"
mkdir -p "$HOME/.icons"
mkdir -p "$HOME/.config/Kvantum"

# ── 2. Instalación de Temas GTK (Catppuccin Mocha) ──────────────────────────
THEME_NAME="Catppuccin-Mocha-Standard-Blue-Dark"
if [ ! -d "$HOME/.local/share/themes/$THEME_NAME" ]; then
    log_info "Instalando tema GTK: $THEME_NAME..."
    # Usamos la version oficial compilada para evitar dependencias de compilacion
    TEMP_DIR=$(mktemp -d)
    curl -sL "https://github.com/catppuccin/gtk/releases/download/v1.0.3/Catppuccin-Mocha-Standard-Blue-Dark.zip" -o "$TEMP_DIR/theme.zip"
    unzip -q "$TEMP_DIR/theme.zip" -d "$HOME/.local/share/themes/"
    rm -rf "$TEMP_DIR"
    log_ok "Tema GTK instalado."
else
    log_ok "Tema GTK ya presente."
fi

# ── 3. Configuración de Kvantum (Qt) ─────────────────────────────────────────
KVANTUM_THEME="Catppuccin-Mocha-Blue"
if [ ! -d "$HOME/.config/Kvantum/$KVANTUM_THEME" ]; then
    log_info "Configurando tema Kvantum: $KVANTUM_THEME..."
    mkdir -p "$HOME/.config/Kvantum/$KVANTUM_THEME"
    # Descargamos directamente los archivos de configuracion del repo oficial
    curl -sL "https://raw.githubusercontent.com/catppuccin/Kvantum/main/src/Catppuccin-Mocha-Blue/Catppuccin-Mocha-Blue.kvconfig" -o "$HOME/.config/Kvantum/$KVANTUM_THEME/$KVANTUM_THEME.kvconfig"
    curl -sL "https://raw.githubusercontent.com/catppuccin/Kvantum/main/src/Catppuccin-Mocha-Blue/Catppuccin-Mocha-Blue.svg" -o "$HOME/.config/Kvantum/$KVANTUM_THEME/$KVANTUM_THEME.svg"
    
    # Activar el tema en Kvantum
    echo "theme=$KVANTUM_THEME" > "$HOME/.config/Kvantum/kvantum.kvconfig"
    log_ok "Tema Kvantum configurado."
fi

# ── 4. Sincronización de Colores (Flavours) ──────────────────────────────────
if command -v flavours &>/dev/null; then
    log_info "Sincronizando paleta de terminal con Flavours..."
    # Intentamos aplicar el esquema catppuccin-mocha si esta disponible
    flavours apply catppuccin-mocha || log_info "Flavours: Esquema no encontrado, omitiendo..."
    log_ok "Colores de terminal actualizados."
fi

log_ok "Personalización visual completada exitosamente."
