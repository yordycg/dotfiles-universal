#!/usr/bin/env bash
# =============================================================================
# scripts/run_onchange_after_apply-theme.sh.tmpl
# Automatización de Temas (GTK, Kvantum, Qt) - Senior Logic
# =============================================================================
{{ if .isServer -}}
# El servidor es headless, no aplicamos temas graficos
exit 0
{{- end }}

set -euo pipefail

# -- Trigger de Cambio --
# Este script se ejecutara solo si cambia el config de flavours
# Hash: {{ include "dot_config/flavours/config.toml.tmpl" | sha256sum }}

# Colores Homelab-Style
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
BOLD='\033[1m'
RESET='\033[0m'

log_step() { echo -e "\n${CYAN}${BOLD}▶ $1${RESET}"; }
log_ok()   { echo -e "${GREEN}  ✓ $1${RESET}"; }
log_info() { echo -e "${CYAN}  → $1${RESET}"; }
log_warn() { echo -e "${YELLOW}  ⚠ $1${RESET}"; }
log_err()  { echo -e "${RED}  ✗ $1${RESET}"; exit 1; }

# ── 1. Preparación de Directorios ───────────────────────────────────────────
log_step "Configurando Entorno Gráfico (Themes)"

mkdir -p "$HOME/.local/share/themes"
mkdir -p "$HOME/.icons"
mkdir -p "$HOME/.config/Kvantum"

# ── 2. Instalación de Temas GTK (Catppuccin Mocha) ──────────────────────────
THEME_DIR_NAME="catppuccin-mocha-blue-standard+default"
if [ ! -d "$HOME/.local/share/themes/$THEME_DIR_NAME" ]; then
    log_info "Instalando tema GTK: Mocha Blue..."
    TEMP_DIR=$(mktemp -d)
    # URL corregida según los releases oficiales de Catppuccin
    ZIP_URL="https://github.com/catppuccin/gtk/releases/download/v1.0.3/catppuccin-mocha-blue-standard+default.zip"
    
    if curl -sL "$ZIP_URL" -o "$TEMP_DIR/theme.zip"; then
        # Verificar que sea un ZIP valido antes de intentar descomprimir
        if file "$TEMP_DIR/theme.zip" | grep -q "Zip archive data"; then
            unzip -q "$TEMP_DIR/theme.zip" -d "$HOME/.local/share/themes/"
            log_ok "Tema GTK instalado correctamente."
        else
            log_warn "El archivo descargado no es un ZIP valido. Es posible que la URL haya cambiado."
        fi
    else
        log_warn "Error al descargar el tema desde GitHub."
    fi
    rm -rf "$TEMP_DIR"
else
    log_ok "Tema GTK ya presente."
fi

# ── 3. Configuración de Kvantum (Qt) ─────────────────────────────────────────
KVANTUM_THEME_NAME="catppuccin-mocha-blue"
KVANTUM_DIR="$HOME/.config/Kvantum/$KVANTUM_THEME_NAME"

# Si el archivo SVG es invalido (HTML 404), forzamos re-descarga
if [ -f "$KVANTUM_DIR/$KVANTUM_THEME_NAME.svg" ] && ! grep -q "<svg" "$KVANTUM_DIR/$KVANTUM_THEME_NAME.svg"; then
    log_warn "Detectado archivo Kvantum corrupto. Re-descargando..."
    rm -rf "$KVANTUM_DIR"
fi

if [ ! -d "$KVANTUM_DIR" ]; then
    log_info "Configurando tema Kvantum: $KVANTUM_THEME_NAME..."
    mkdir -p "$KVANTUM_DIR"
    # URLs corregidas (Repo: catppuccin/kvantum, Path: themes/catppuccin-mocha-blue/...)
    BASE_URL="https://raw.githubusercontent.com/catppuccin/kvantum/main/themes/catppuccin-mocha-blue"
    curl -sL "$BASE_URL/catppuccin-mocha-blue.kvconfig" -o "$KVANTUM_DIR/$KVANTUM_THEME_NAME.kvconfig"
    curl -sL "$BASE_URL/catppuccin-mocha-blue.svg" -o "$KVANTUM_DIR/$KVANTUM_THEME_NAME.svg"
    
    # Activar el tema en Kvantum
    echo "theme=$KVANTUM_THEME_NAME" > "$HOME/.config/Kvantum/kvantum.kvconfig"
    log_ok "Tema Kvantum configurado ($KVANTUM_THEME_NAME)."
fi

# ── 4. Sincronización de GSettings (GTK Sync) ────────────────────────────────
if command -v gsettings &>/dev/null; then
    log_info "Sincronizando GSettings con el tema actual..."
    gsettings set org.gnome.desktop.interface gtk-theme "$THEME_DIR_NAME"
    gsettings set org.gnome.desktop.interface icon-theme "Papirus-Dark"
    gsettings set org.gnome.desktop.interface font-name "JetBrainsMono Nerd Font 10"
    gsettings set org.gnome.desktop.interface color-scheme "prefer-dark"
    log_ok "GSettings sincronizados (nwg-look actualizado)."
fi

# ── 5. Sincronización de Colores (Flavours) ──────────────────────────────────
if command -v flavours &>/dev/null; then
    log_info "Sincronizando paleta de terminal con Flavours..."
    # Intentamos aplicar el esquema catppuccin-mocha si esta disponible
    flavours apply catppuccin-mocha || log_info "Flavours: Esquema no encontrado, omitiendo..."
    log_ok "Colores de terminal actualizados."
fi

log_ok "Personalización visual completada exitosamente."
