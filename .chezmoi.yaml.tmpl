{{/* ══════════════════════════════════════════════════════════════
     .chezmoi.yaml.tmpl
     Detección limpia de 7 escenarios. Sin decrypt si no hay key.
     Sin prompt si ya tenemos el token.
     ══════════════════════════════════════════════════════════════ */}}

{{/* ── PASO 1: Variables base (mutuamente excluyentes) ────────── */}}
{{- $isWindows := eq .chezmoi.os "windows" -}}
{{- $isWSL     := and (not $isWindows) (env "WSL_DISTRO_NAME" | not | not) -}}
{{- $isServer  := and (not $isWindows) (not $isWSL)
      (or (eq .chezmoi.hostname "homelab")
          (eq .chezmoi.hostname "servidor")
          (eq .chezmoi.hostname "vault")) -}}
{{- $isLaptop  := and (not $isWindows) (not $isWSL) (not $isServer)
      (stat "/sys/class/power_supply/BAT0" | not | not) -}}
{{- $isDesktop := and (not $isWindows) (not $isWSL)
      (not $isServer) (not $isLaptop) -}}

{{/* ── PASO 2: Variables derivadas (semántica de alto nivel) ───── */}}
{{- $isNativeLinux := or $isLaptop $isDesktop -}}
{{- $isGUI         := or $isNativeLinux $isWindows -}}
{{- $isHeadless    := or $isServer $isWSL -}}

{{/* ── PASO 3: GitHub token — cadena de precedencia segura ─────── */}}
{{- $ghToken := "" -}}
{{- if env "GITHUB_TOKEN" -}}
{{-   $ghToken = env "GITHUB_TOKEN" -}}
{{- else if and (hasKey . "githubToken") .githubToken -}}
{{-   $ghToken = .githubToken -}}
{{- else if lookPath "gh" -}}
{{-   $ghToken = (output "gh" "auth" "token" | trim) -}}
{{- end -}}
{{- if not $ghToken -}}
{{-   $ghToken = promptStringOnce . "githubToken" "GitHub token" -}}
{{- end -}}

{{/* ── PASO 4: Age encryption — SOLO si key.txt existe ─────────── */}}
{{- $keyPath := joinPath .chezmoi.homeDir ".config/age/key.txt" -}}
{{- if not (stat $keyPath) -}}
{{-   $keyPath = joinPath .chezmoi.homeDir ".config/chezmoi/key.txt" -}}
{{- end -}}
{{- $hasKey  := and (not $isWindows) (stat $keyPath | not | not) -}}

{{/* ── PASO 5: Forgejo token — SOLO si key + archivo .age existen  */}}
{{- $forgejoToken := "" -}}
{{- if $hasKey -}}
{{-   $ageFile := joinPath .chezmoi.sourceDir
        "dot_config/homelab/private_secrets.yaml.age" -}}
{{-   if stat $ageFile -}}
{{-     $forgejoToken = (include $ageFile | decrypt | fromYaml).forgejo_token -}}
{{-   end -}}
{{- end -}}

{{/* ── OUTPUT YAML ─────────────────────────────────────────────── */}}
{{ if $hasKey -}}
encryption: "age"
age:
  identity: {{ $keyPath | quote }}
  recipient: "age1w93unwnu802h9vkygj2d4dxmu23yghw9kd39thwgc0susmsu7spscwp0wa"
{{ end -}}

bitwarden:
  base_url: "https://vaultwarden.tudominio.local"

data:
  # ── Variables base (5 escenarios mutuamente excluyentes) ──
  isWindows: {{ $isWindows }}
  isWSL:     {{ $isWSL }}
  isServer:  {{ $isServer }}
  isLaptop:  {{ $isLaptop }}
  isDesktop: {{ $isDesktop }}

  # ── Variables derivadas (para templates más legibles) ──────
  isNativeLinux: {{ $isNativeLinux }}
  isGUI:         {{ $isGUI }}
  isHeadless:    {{ $isHeadless }}

  # ── Metadata ───────────────────────────────────────────────
  os:       {{ .chezmoi.os }}
  hostname: {{ .chezmoi.hostname }}
  fontSizeTerminal: {{ if $isDesktop }}15{{ else }}13{{ end }}

  # ── Identidad ──────────────────────────────────────────────
  gitName:      "yordycg"
  gitEmail:     "yordy.carmona8@gmail.com"
  githubToken:  {{ $ghToken | quote }}
  forgejoToken: {{ $forgejoToken | quote }}
  homelab_ip:   "192.168.18.99"
  adguard_ip:   "192.168.18.99"
