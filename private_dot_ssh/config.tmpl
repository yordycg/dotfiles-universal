# -- Configuración Global de Multiplexación (Acelera conexiones secundarias) --
Host *
    ControlMaster auto
    ControlPath ~/.ssh/master-%r@%h:%p
    ControlPersist 10m
    ConnectTimeout 3
    ServerAliveInterval 10
    ServerAliveCountMax 3

{{- if .needsSSHcfg }}
# -- Detección Dinámica de Red (Local vs Tailscale) --
# Si el ping a la IP local tiene éxito, usamos la ruta más rápida.
Match host homelab,forgejo.home exec "ping -c 1 -W 1 {{ .homelab_ip_local }} >/dev/null 2>&1"
    HostName {{ .homelab_ip_local }}
{{- end }}


# -- Servidor Homelab --
Host homelab
    {{- if .isServer }}
    HostName 127.0.0.1
    {{- else }}
    HostName {{ .homelab_ip_ts }}
    {{- end }}
    User yordycg
    Port 22
    IdentityFile ~/.ssh/id_ed25519
    AddKeysToAgent yes
    ForwardAgent yes
    Compression yes
    # Port Forwarding Automático (Senior Workflow)
    LocalForward 3000 localhost:3000
    LocalForward 5173 localhost:5173
    LocalForward 8000 localhost:8000
    LocalForward 8080 localhost:8080
    LocalForward 4321 localhost:4321
    LocalForward 5432 localhost:5432

# -- Repositorio Local (Forgejo) --
Host forgejo.home
    {{- if .isServer }}
    HostName 127.0.0.1
    Port 2222
    {{- else }}
    HostName {{ .homelab_ip_ts }}
    Port 2222
    {{- end }}
    User git
    IdentityFile ~/.ssh/id_ed25519
    IdentitiesOnly yes

# -- GitHub --
Host github.com
	HostName github.com
	User git
	IdentityFile ~/.ssh/id_ed25519
	IdentitiesOnly yes
