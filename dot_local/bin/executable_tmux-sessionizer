#!/usr/bin/env bash
# tmux-sessionizer v2.4 ŌĆö dynamic height + floating popup + session deletion (Ctrl-D)
set -euo pipefail

WORKSPACE="$HOME/workspace"
DEPTH=2
IGNORE_NAMES=("wallpapers" ".git" "node_modules" "target" "dist" ".venv" "venv")

should_ignore() {
    local base
    base=$(basename "$1")
    for ig in "${IGNORE_NAMES[@]}"; do
        [[ "$base" == "$ig" ]] && return 0
    done
    return 1
}

# --- Generar lista de entradas (usado para render inicial y reload) ---
generate_entries() {
    declare -A session_by_path
    if tmux_list=$(tmux list-sessions -F "#{session_name}	#{session_path}" 2>/dev/null); then
        while IFS=$'\t' read -r name path; do
            [[ -n "$name" ]] && session_by_path["$path"]="$name"
        done <<< "$tmux_list"
    fi

    entries=()

    for path in "${!session_by_path[@]}"; do
        name="${session_by_path[$path]}"
        entries+=("¾░īī  ${name}  (${path/#$HOME/\~})"$'\t'"$path")
    done

    if [[ -d "$WORKSPACE" ]]; then
        while IFS= read -r dir; do
            should_ignore "$dir" && continue
            [[ -n "${session_by_path[$dir]:-}" ]] && continue
            entries+=("’ü╝  ${dir/#$HOME/\~}"$'\t'"$dir")
        done < <(find "$WORKSPACE" -mindepth "$DEPTH" -maxdepth "$DEPTH" -type d 2>/dev/null | sort)

        while IFS= read -r dir; do
            should_ignore "$dir" && continue
            [[ -n "${session_by_path[$dir]:-}" ]] && continue
            if ! find "$dir" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | grep -q .; then
                entries+=("’ü╝  ${dir/#$HOME/\~}"$'\t'"$dir")
            fi
        done < <(find "$WORKSPACE" -mindepth 1 -maxdepth 1 -type d 2>/dev/null | sort)
    fi

    printf '%s\n' "${entries[@]}"
}

# --- Subcomando interno para imprimir lista (para +reload de fzf) ---
if [[ "${1:-}" == "--list" ]]; then
    generate_entries
    exit 0
fi

# --- 1. Si no estamos en popup-child y estamos dentro de TMUX, calcular altura y lanzar popup ---
if [[ "${1:-}" != "--popup-child" ]] && [[ -n "${TMUX:-}" ]]; then
    count=$(generate_entries | wc -l)

    height=$(( count + 8 ))
    if (( height < 14 )); then height=14; fi
    if (( height > 24 )); then height=24; fi

    exec tmux display-popup -E -w 55% -h "$height" -b rounded -T " ¾░īī  Tmux Sessionizer " "$0 --popup-child"
fi

# Si se pas├│ un argumento de ruta directa (ej: tmux-sessionizer /ruta/dir)
if [[ $# -eq 1 ]] && [[ "$1" != "--popup-child" ]]; then
    selected_path=$1
    selected_name=$(basename "$selected_path" | tr . _ | tr ' ' _)
else
    # --- Interfaz FZF dentro del popup ---
    declare -A session_by_path
    if tmux_list=$(tmux list-sessions -F "#{session_name}	#{session_path}" 2>/dev/null); then
        while IFS=$'\t' read -r name path; do
            [[ -n "$name" ]] && session_by_path["$path"]="$name"
        done <<< "$tmux_list"
    fi

    PREVIEW_CMD='p=$(echo {} | awk -F"\t" "{print \$NF}"); if [ -d "$p" ]; then eza --tree --level=2 --icons --group-directories-first "$p" 2>/dev/null || ls -la "$p"; fi'
    KILL_CMD='p=$(echo {} | awk -F"\t" "{print \$NF}"); s=$(tmux list-sessions -F "#{session_name}	#{session_path}" 2>/dev/null | grep "$p" | awk -F"\t" "{print \$1}"); [ -n "$s" ] && tmux kill-session -t "$s"'

    chosen=$(generate_entries | fzf \
        --delimiter=$'\t' \
        --with-nth=1 \
        --prompt=" ’Ćé  sesi├│n/dir > " \
        --pointer="ŌØ»" \
        --marker="Ō£ō" \
        --border=none \
        --header="[Enter]: Ir  |  [Ctrl-D]: Eliminar  |  [Ctrl-P]: Vista previa  |  [Esc]: Salir" \
        --color=header:italic,prompt:blue,pointer:bright-blue \
        --preview="$PREVIEW_CMD" \
        --preview-window="right:50%:wrap:hidden" \
        --bind="ctrl-p:toggle-preview" \
        --bind="ctrl-d:execute($KILL_CMD)+reload($0 --list)" || true)

    if [[ -z "${chosen:-}" ]]; then
        exit 0
    fi

    selected_path=$(echo "$chosen" | awk -F'\t' '{print $NF}')

    if [[ -n "${session_by_path[$selected_path]:-}" ]]; then
        selected_name="${session_by_path[$selected_path]}"
    else
        selected_name=$(basename "$selected_path" | tr . _ | tr ' ' _)
    fi
fi

# --- Crear / cambiar de sesi├│n ---
tmux_running=$(pgrep tmux || true)

if [[ -z "${TMUX:-}" ]] && [[ -z "$tmux_running" ]]; then
    tmux new-session -s "$selected_name" -c "$selected_path"
    exit 0
fi

if ! tmux has-session -t="$selected_name" 2>/dev/null; then
    tmux new-session -ds "$selected_name" -c "$selected_path"
fi

if [[ -n "${TMUX:-}" ]]; then
    tmux switch-client -t "$selected_name"
else
    tmux attach-session -t "$selected_name"
fi
