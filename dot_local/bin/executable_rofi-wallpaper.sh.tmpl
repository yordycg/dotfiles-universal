#!/usr/bin/env bash

# Asegurar rutas de mise, cargo y locales para ejecuciones desde el compositor
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# Senior Rofi Wallpaper Picker & Navigator
# Scans wallpapers, generates square thumbnails, and applies selection via swww.
# Supports CLI arguments for next, prev, random, and color theme modes (0, 1, 2, 3).

ACTIVE_THEME_FILE="$HOME/.cache/themes/active_theme"
ACTIVE_THEME="kanagawa"
if [ -f "$ACTIVE_THEME_FILE" ]; then
    ACTIVE_THEME=$(cat "$ACTIVE_THEME_FILE")
fi
WALLPAPER_DIR="$HOME/.config/themes/$ACTIVE_THEME/wallpapers"

# Si el directorio del tema no existe o está vacío, hacemos fallback al directorio global
if [ ! -d "$WALLPAPER_DIR" ] || [ -z "$(ls -A "$WALLPAPER_DIR" 2>/dev/null)" ]; then
    WALLPAPER_DIR="$HOME/workspace/assets/wallpapers"
fi
THUMB_DIR="$HOME/.cache/wallpaper-thumbnails"
ROFI_THEME="$HOME/.config/rofi/wallpaper.rasi"
CACHE_FILE="$HOME/.cache/.current_wallpaper"
MODE_FILE="$HOME/.cache/wallust/theme_mode"

mkdir -p "$THUMB_DIR"
mkdir -p "$(dirname "$MODE_FILE")"

# Get sorted list of wallpapers in an array
shopt -s nullglob
wallpapers=("$WALLPAPER_DIR"/*.{jpg,jpeg,png,webp})
shopt -u nullglob

if [ ${#wallpapers[@]} -eq 0 ]; then
    echo "No wallpapers found in $WALLPAPER_DIR"
    exit 1
fi

# Function to apply a wallpaper and regenerate colors based on the mode
apply_wallpaper() {
    local wp_path="$1"
    if [ ! -f "$wp_path" ]; then
        echo "Error: Wallpaper file not found: $wp_path"
        return 1
    fi

    # Leer el modo de tema activo (por defecto 2: Forzar Oscuro)
    local mode="2"
    if [ -f "$MODE_FILE" ]; then
        mode=$(cat "$MODE_FILE")
    fi

    echo "Applying wallpaper (Mode $mode): $wp_path"
    
    # 1. Aplicar con swww
    if swww query &>/dev/null; then
        swww img "$wp_path" --transition-type grow --transition-pos center --transition-duration 1.5
    fi
    
    # Guardar wallpaper actual para persistencia
    echo "$wp_path" > "$CACHE_FILE"

    # Si el modo es 0 (Solo Wallpaper), terminamos aquí sin tocar colores
    if [ "$mode" = "0" ]; then
        echo "Mode 0: Wallpaper applied. Colors unchanged."
        return 0
    fi

    # Determinar el filtro de wallust
    local filter="dark16"
    if [ "$mode" = "1" ]; then
        # Modo Auto: Detectar tema claro/oscuro del sistema usando DBus (Portal de Freedesktop)
        # 1 = Oscuro, 2 = Claro, 0 = Sin preferencia (usamos oscuro por defecto)
        local dbus_val
        dbus_val=$(dbus-send --print-reply --dest=org.freedesktop.portal.Desktop \
            /org/freedesktop/portal/desktop \
            org.freedesktop.portal.Settings.Read \
            string:org.freedesktop.appearance string:color-scheme 2>/dev/null | grep "uint32" | awk '{print $2}')
        
        if [ "$dbus_val" = "2" ]; then
            filter="light16"
            echo "Auto Mode: System Light theme detected."
        else
            filter="dark16"
            echo "Auto Mode: System Dark theme detected."
        fi
    elif [ "$mode" = "3" ]; then
        filter="light16"
        echo "Forced Mode: Light theme."
    else
        filter="dark16"
        echo "Forced Mode: Dark theme."
    fi
    
    # 2. Actualizar colores con wallust
    if command -v wallust &> /dev/null; then
        echo "Running wallust..."
        wallust run --palette "$filter" --skip-sequences "$wp_path" &> /dev/null
        
        # 3. Recargar aplicaciones para aplicar nuevos colores
        if pgrep -x "Hyprland" > /dev/null; then
            hyprctl reload &> /dev/null
        elif pgrep -x "sway" > /dev/null; then
            swaymsg reload &> /dev/null
        fi
        pkill -USR1 kitty &> /dev/null
        pkill -USR2 waybar &> /dev/null
        if pgrep -x "quickshell" > /dev/null || pgrep -x "qs" > /dev/null; then
            qs -c desktop ipc call theme reload 2>/dev/null || true
        fi
        if command -v makoctl &> /dev/null && pgrep -x "mako" > /dev/null; then
            makoctl reload &> /dev/null
        fi
    fi
}

# Get current wallpaper index
current_wp=""
if [ -f "$CACHE_FILE" ]; then
    current_wp=$(cat "$CACHE_FILE")
fi

current_index=-1
for i in "${!wallpapers[@]}"; do
    if [ "${wallpapers[$i]}" = "$current_wp" ]; then
        current_index=$i
        break
    fi
done

# --- ARGUMENT PARSING ---
case "$1" in
    --restore)
        # Restore logic
        if [ -z "$current_wp" ] || [ ! -f "$current_wp" ]; then
            current_wp="$WALLPAPER_DIR/macos-00.jpg"
            if [ ! -f "$current_wp" ]; then
                current_wp="${wallpapers[0]}"
            fi
        fi

        # Wait for swww-daemon to be ready (up to 3 seconds)
        for i in {1..15}; do
            if swww query &>/dev/null; then
                break
            fi
            sleep 0.2
        done

        apply_wallpaper "$current_wp"
        exit 0
        ;;
        
    -n|--next)
        if [ $current_index -eq -1 ]; then
            next_index=0
        else
            next_index=$(( (current_index + 1) % ${#wallpapers[@]} ))
        fi
        apply_wallpaper "${wallpapers[$next_index]}"
        exit 0
        ;;
        
    -p|--prev)
        if [ $current_index -eq -1 ]; then
            prev_index=0
        else
            prev_index=$(( (current_index - 1 + ${#wallpapers[@]}) % ${#wallpapers[@]} ))
        fi
        apply_wallpaper "${wallpapers[$prev_index]}"
        exit 0
        ;;
        
    -r|--random)
        random_index=$(( RANDOM % ${#wallpapers[@]} ))
        apply_wallpaper "${wallpapers[$random_index]}"
        exit 0
        ;;

    -m|--toggle-mode)
        # Menú Rofi para seleccionar el modo de color (estilo wallbashtoggle.sh -m)
        options="0 󰸉 Solo Wallpaper (Sin cambios de color)\n1 󰖨 Auto (Sigue tema claro/oscuro)\n2 🌑 Forzar Oscuro\n3 ☀️ Forzar Claro"
        chosen=$(echo -e "$options" | rofi -dmenu -i -p "🎨 Modo de Color:" -theme "$HOME/.config/rofi/config.rasi")
        
        if [ -n "$chosen" ]; then
            new_mode=$(echo "$chosen" | awk '{print $1}')
            echo "$new_mode" > "$MODE_FILE"
            
            if command -v notify-send &>/dev/null; then
                notify-send -i preferences-desktop-theme "Modo de Color" "Cambiado a: $(echo "$chosen" | cut -d' ' -f2-)"
            fi
            
            # Re-aplicar el fondo actual para actualizar la paleta de inmediato
            if [ -n "$current_wp" ] && [ -f "$current_wp" ]; then
                apply_wallpaper "$current_wp"
            fi
        fi
        exit 0
        ;;

    --theme-mode)
        # Permite cambiar el modo directamente por CLI (ej. rofi-wallpaper.sh --theme-mode 2)
        if [[ "$2" =~ ^[0-3]$ ]]; then
            echo "$2" > "$MODE_FILE"
            echo "Modo de color cambiado a: $2"
            if [ -n "$current_wp" ] && [ -f "$current_wp" ]; then
                apply_wallpaper "$current_wp"
            fi
        else
            echo "Error: El modo debe ser un valor entre 0 y 3."
            exit 1
        fi
        exit 0
        ;;
        
    -s|--select|"")
        # 1. Generate square thumbnails (optimized)
        for img in "${wallpapers[@]}"; do
            filename=$(basename "$img")
            thumb="$THUMB_DIR/$filename.png"
            
            if [ ! -f "$thumb" ]; then
                # Use magick or ffmpeg for fast square thumbnail generation (cropping to center)
                if command -v magick >/dev/null; then
                    magick "$img" -strip -thumbnail 200x200^ -gravity center -extent 200x200 "$thumb"
                elif command -v ffmpeg >/dev/null; then
                    ffmpeg -i "$img" -vf "thumbnail,scale=200:200:force_original_aspect_ratio=increase,crop=200:200" -frames:v 1 "$thumb" -y >/dev/null 2>&1
                fi
            fi
        done

        # 2. Build list for Rofi (Entry\0icon\x1fThumbPath)
        list_wallpapers() {
            for img in "${wallpapers[@]}"; do
                filename=$(basename "$img")
                thumb="$THUMB_DIR/$filename.png"
                echo -en "$filename\0icon\x1f$thumb\n"
            done
        }

        # 3. Launch Rofi using the HyDE-style theme
        selection=$(list_wallpapers | rofi -dmenu -i -p "󰸉 " -theme "$ROFI_THEME" -select "$(basename "$current_wp")")

        if [ -n "$selection" ]; then
            apply_wallpaper "$WALLPAPER_DIR/$selection"
        fi
        exit 0
        ;;
        
    *)
        echo "Usage: $0 [--restore | -n/--next | -p/--prev | -r/--random | -s/--select | -m/--toggle-mode | --theme-mode <0-3>]"
        exit 1
        ;;
esac
