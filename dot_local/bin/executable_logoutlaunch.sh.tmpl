#!/usr/bin/env bash

# =============================================================================
# logoutlaunch.sh — Lanzador Dinámico de wlogout (Estilo 2 de HyDE)
# Calcula márgenes y tamaños basados en la resolución del monitor activo
# para centrar una cuadrícula de 2x2 y lograr la animación de explosión.
# =============================================================================

# Si ya está ejecutándose, lo cerramos
if pgrep -x "wlogout" > /dev/null; then
    pkill -x "wlogout"
    exit 0
fi

# Detectar dimensiones y escala del monitor enfocado usando hyprctl
focused_mon=$(hyprctl -j monitors | jq '.[] | select(.focused == true)')
x_mon=$(echo "$focused_mon" | jq '.width')
y_mon=$(echo "$focused_mon" | jq '.height')
raw_scale=$(echo "$focused_mon" | jq '.scale')

# Limpiar y calcular la escala como un entero (ej: 1 -> 100, 1.25 -> 125, 1.5 -> 150)
scale_clean=$(echo "$raw_scale" | tr -d '.')
if [ ${#scale_clean} -eq 1 ]; then
    hypr_scale="${scale_clean}00"
elif [ ${#scale_clean} -eq 2 ]; then
    hypr_scale="${scale_clean}0"
else
    hypr_scale="$scale_clean"
fi

# Valores de configuración dinámicos (Estilo 2 - 2x2 grid)
export x_mgn=$(( x_mon * 35 / hypr_scale ))
export y_mgn=$(( y_mon * 25 / hypr_scale ))
export x_hvr=$(( x_mon * 32 / hypr_scale ))
export y_hvr=$(( y_mon * 20 / hypr_scale ))

# Tamaño de fuente y radios de borde
export fntSize=$(( y_mon * 2 / 100 ))
export active_rad=15
export button_rad=30

# Rutas de configuración
wlTmplt="$HOME/.config/wlogout/style_template.css"
wLayout="$HOME/.config/wlogout/layout"

if [ -f "$wlTmplt" ] && [ -f "$wLayout" ]; then
    # Procesar la plantilla CSS sustituyendo las variables de entorno
    wlStyle=$(envsubst < "$wlTmplt")
    # Lanzar wlogout con 2 botones por fila (-b 2) y el CSS procesado en caliente
    wlogout -b 2 -c 0 -r 0 -m 0 --layout "$wLayout" --css <(echo "$wlStyle") --protocol layer-shell
else
    # Fallback si no existen los archivos
    wlogout -b 2
fi
