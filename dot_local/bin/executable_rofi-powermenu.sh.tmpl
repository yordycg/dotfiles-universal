#!/usr/bin/env bash

# Rofi Powermenu - Senior Edition
# System actions with style.

uptime="$(uptime -p | sed -e 's/up //g')"

# Options
shutdown='’Ćæ Shutdown'
reboot='’ĆĪ Reboot'
lock='’ĆŻ Lock'
suspend='’åå Suspend'
logout='’éŗ Logout'

# Variable passed to rofi
options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

chosen="$(echo -e "$options" | rofi -dmenu -i -p "¾░Éź" -theme $HOME/.config/rofi/config.rasi)"

case $chosen in
    $shutdown)
        systemctl poweroff
        ;;
    $reboot)
        systemctl reboot
        ;;
    $lock)
        if pgrep -x "Hyprland" > /dev/null; then
            hyprlock
        else
            swaylock -c #282828
        fi
        ;;
    $suspend)
        mpc -q pause
        amixer set Master mute
        systemctl suspend
        ;;
    $logout)
        if pgrep -x "Hyprland" > /dev/null; then
            hyprctl dispatch exit
        elif pgrep -x "sway" > /dev/null; then
            swaymsg exit
        fi
        ;;
esac
