#!/usr/bin/env bash

# Rofi Powermenu - Senior Edition
# System actions with style.

uptime="$(uptime -p | sed -e 's/up //g')"

# Options
shutdown='ΎΑΣ Shutdown'
reboot='ΎΑκ Reboot'
lock='ΎΑμ Lock'
suspend='ΎΗΗ Suspend'
logout='ΎΓΜ Logout'

# Variable passed to rofi
options="$lock\n$suspend\n$logout\n$reboot\n$shutdown"

chosen="$(echo -e "$options" | rofi -dmenu -i -p "≤░Ρξ" -theme $HOME/.config/rofi/config.rasi)"

case $chosen in
    $shutdown)
        systemctl poweroff
        ;;
    $reboot)
        systemctl reboot
        ;;
    $lock)
        swaylock -c #282828
        ;;
    $suspend)
        mpc -q pause
        amixer set Master mute
        systemctl suspend
        ;;
    $logout)
        swaymsg exit
        ;;
esac
