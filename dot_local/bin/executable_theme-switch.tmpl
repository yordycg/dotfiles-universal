#!/usr/bin/env bash
# {{ .chezmoi.sourceDir }}/dot_local/bin/executable_theme-switch.tmpl
# Usage: theme-switch catppuccin-mocha

# Ensure ~/.local/share/mise/shims, ~/.local/bin and ~/.cargo/bin are in PATH
export PATH="$HOME/.local/share/mise/shims:$HOME/.local/bin:$HOME/.cargo/bin:$PATH"

# --- 1. Verificación de Entorno ---
# Si no hay flavours, no podemos generar ni listar temas.
if ! command -v flavours &> /dev/null; then
    echo "🎨 En este entorno (WSL/Servidor), los colores son gestionados por la terminal anfitriona."
    echo "   Para cambiar el tema del Homelab, ejecútalo desde tu Laptop principal."
    exit 0
fi

THEME="${1:-}"

# --- 2. Selección de Tema ---
if [ -z "$THEME" ]; then
    if ! command -v fzf &> /dev/null; then
        echo "⚠ fzf no encontrado. Instálalo o pasa un tema como argumento."
        exit 1
    fi
    
    # flavours list devuelve todo en una línea, lo convertimos a lista vertical
    THEME=$(flavours list | tr ' ' '\n' | grep -v '^$' | fzf --height 40% --reverse --header "Selecciona un tema base16:")
fi

# Salir si se canceló fzf o no se seleccionó nada
if [ -z "$THEME" ]; then
    echo "Operación cancelada."
    exit 0
fi

echo "→ Switching to theme: $THEME"

# --- 3. Aplicar Tema Local ---
flavours apply "$THEME"

{{ if and (eq .chezmoi.os "linux") (not .isServer) -}}
# --- 4. Propagación Remota (Homelab) ---
if ping -c 1 -W 1 homelab >/dev/null 2>&1; then
    echo "→ Propagando tema al servidor Homelab..."
    # Crear directorios remotos si no existen
    ssh homelab "mkdir -p ~/.config/tmux ~/.config/shell"
    # Copiar archivos de colores generados por flavours
    scp "$HOME/.config/tmux/colors.conf" "homelab:~/.config/tmux/colors.conf" >/dev/null 2>&1
    scp "$HOME/.config/shell/fzf_colors.sh" "homelab:~/.config/shell/fzf_colors.sh" >/dev/null 2>&1
    # Recargar tmux en el servidor
    ssh homelab "tmux source-file ~/.config/tmux/colors.conf" >/dev/null 2>&1
fi

# --- 5. Reload de Apps Gráficas Locales ---
if pgrep -x "Hyprland" > /dev/null; then
    hyprctl reload
elif pgrep -x "sway" > /dev/null; then
    swaymsg reload
fi
pgrep -x waybar > /dev/null && pkill -SIGUSR2 waybar
pgrep -x kitty > /dev/null && pkill -SIGUSR1 kitty
{{- end }}

# --- 6. Reload de Tmux Local ---
if [ -n "${TMUX:-}" ]; then
  echo "→ Reloading Tmux colors..."
  tmux source-file ~/.config/tmux/colors.conf
fi

echo "✓ Theme applied: $THEME"
{{ if and (eq .chezmoi.os "linux") (not .isServer) -}}
echo "  (Neovim might require restart or :colorscheme catppuccin)"
{{- end }}
