#!/usr/bin/env bash

# Set and show lightweight desktop notification reminders using systemd timers.
# Usage: reminder <minutes> [message] | show | clear

set -euo pipefail

format_remaining() {
  local seconds=$1
  local minutes=$((seconds / 60))
  local remainder=$((seconds % 60))

  if ((minutes > 0 && remainder > 0)); then
    echo "${minutes}m ${remainder}s"
  elif ((minutes > 0)); then
    echo "${minutes}m"
  else
    echo "${remainder}s"
  fi
}

show_reminders() {
  local timer next remaining body=""
  local reminder_dir="${XDG_RUNTIME_DIR:-/tmp}/reminder-reminders"
  local now=$(date +%s)

  while IFS=$'\t' read -r timer next; do
    [[ -z "$timer" || -z "$next" ]] && continue

    next=$((next / 1000000))
    ((next <= now)) && continue

    remaining=$((next - now))
    local reminder=${timer%.timer}
    reminder=${reminder#reminder-reminder-}
    local reminder_minutes=${reminder%%m-*}
    local reminder_message=""
    [[ -f "$reminder_dir/${timer%.timer}.message" ]] && reminder_message=$(<"$reminder_dir/${timer%.timer}.message")

    if [[ -n "$reminder_message" ]]; then
      body+="$reminder_message in $(format_remaining $remaining) ($(date -d "@$next" +%-H:%M))"$'\n'
    else
      body+="${reminder_minutes}-min reminder in $(format_remaining $remaining) ($(date -d "@$next" +%-H:%M))"$'\n'
    fi
  done < <(systemctl --user list-timers --all --output=json "reminder-reminder-*.timer" 2>/dev/null | jq -r '.[] | [.unit, .next] | @tsv')

  if [[ -z "$body" ]]; then
    notify-send -i appointment-soon "Upcoming reminders" "No outstanding reminders"
  else
    notify-send -i appointment-soon "Upcoming reminders" "${body%$'\n'}"
  fi
}

clear_reminders() {
  local units
  local reminder_dir="${XDG_RUNTIME_DIR:-/tmp}/reminder-reminders"

  units=$(systemctl --user list-timers --all --no-legend --no-pager "reminder-reminder-*.timer" 2>/dev/null | awk '{ print $(NF - 1), $NF }')

  if [[ -n "$units" ]]; then
      echo "$units" | while read -r unit _; do
          systemctl --user stop "$unit" || true
      done
  fi

  rm -f "$reminder_dir"/reminder-reminder-*.message 2>/dev/null || true
  notify-send -i appointment-soon "All reminders have been cleared"
}

case ${1:-} in
show | list)
  show_reminders
  exit 0
  ;;
clear)
  clear_reminders
  exit 0
  ;;
esac

minutes=${1:-}
shift || true
message="$*"
custom_message="$message"

if [[ -z "$minutes" ]] || [[ ! "$minutes" =~ ^[0-9]+$ ]] || ((minutes == 0)); then
  echo "Usage: reminder <minutes> [message]"
  echo "       reminder show"
  echo "       reminder clear"
  exit 1
fi

if [[ -z "$message" ]]; then
  message="Your ${minutes} minutes are up"
fi

set_at=$(date +%s)
remind_at=$(date -d "+${minutes} minutes" +%H:%M)
unit="reminder-reminder-${minutes}m-$set_at"
reminder_dir="${XDG_RUNTIME_DIR:-/tmp}/reminder-reminders"
message_file="$reminder_dir/$unit.message"
confirmation="You'll be reminded at $remind_at"
confirmation_title="Reminder set for ${minutes} minutes"

mkdir -p "$reminder_dir"

if [[ -n "$custom_message" ]]; then
  printf "%s" "$custom_message" >"$message_file"
  confirmation_title="$custom_message in ${minutes} minutes"
fi

systemd-run --user --quiet --collect --on-active="${minutes}m" --unit="$unit" \
  bash -c 'notify-send -i appointment-soon -u critical "Reminder" "$1"; rm -f "$2"' bash "$message" "$message_file"

notify-send -i appointment-soon "$confirmation_title" "$confirmation"
